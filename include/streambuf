#pragma once
#include <cstddef>
#include <ios>
#include <iosfwd>

namespace std {

template <typename Char, typename Traits> class basic_streambuf {
public:
  using char_type = Char;
  using traits_type = Traits;
  using int_type = typename Traits::int_type;

  virtual ~basic_streambuf() = default;

  // --- Put area ---
  char_type* pbase() const noexcept { return pbase_; }
  char_type* pptr() const noexcept { return pptr_; }
  char_type* epptr() const noexcept { return epptr_; }

  void pbump(int n) noexcept { pptr_ += n; }

  // write n chars to put area
  streamsize sputn(const char_type* s, streamsize n) { return xsputn(s, n); }

  int_type sputc(char_type c) {
    if (pptr_ < epptr_) {
      *pptr_++ = c;
      return traits_type::to_int_type(c);
    }
    return overflow(traits_type::to_int_type(c));
  }

  // --- Get area ---
  char_type* eback() const noexcept { return eback_; }
  char_type* gptr() const noexcept { return gptr_; }
  char_type* egptr() const noexcept { return egptr_; }

  void gbump(int n) noexcept { gptr_ += n; }

  // peek at next char without consuming
  int_type sgetc() {
    if (gptr_ < egptr_)
      return traits_type::to_int_type(*gptr_);
    return underflow();
  }

  // read and consume next char
  int_type sbumpc() {
    if (gptr_ < egptr_)
      return traits_type::to_int_type(*gptr_++);
    return uflow();
  }

  // put back one character (decrement get pointer)
  int_type sungetc() {
    if (eback_ < gptr_)
      return traits_type::to_int_type(*--gptr_);
    return pbackfail();
  }
  int_type sputbackc(char_type c) {
    if (eback_ < gptr_ && traits_type::eq(c, gptr_[-1]))
      return traits_type::to_int_type(*--gptr_);
    return pbackfail(traits_type::to_int_type(c));
  }

  // read up to n chars into s, return number read
  streamsize sgetn(char_type* s, streamsize n) { return xsgetn(s, n); }

  // seek to absolute position
  streampos pubseekpos(streampos pos,
                       ios_base::openmode which = ios_base::in |
                                                  ios_base::out) {
    return seekpos(pos, which);
  }

  // seek relative to current
  streampos pubseekoff(streamoff off, ios_base::seekdir dir,
                       ios_base::openmode which = ios_base::in |
                                                  ios_base::out) {
    return seekoff(off, dir, which);
  }

  // --- Sync ---
  int pubsync() { return sync(); }

protected:
  basic_streambuf() noexcept
      : pbase_(nullptr), pptr_(nullptr), epptr_(nullptr), eback_(nullptr),
        gptr_(nullptr), egptr_(nullptr) {}

  void setp(char_type* pbeg, char_type* pend) noexcept {
    pbase_ = pbeg;
    pptr_ = pbeg;
    epptr_ = pend;
  }
  void setg(char_type* gbeg, char_type* gcurr, char_type* gend) noexcept {
    eback_ = gbeg;
    gptr_ = gcurr;
    egptr_ = gend;
  }

  // Virtual hooks — subclasses override these
  virtual int_type overflow(int_type c = traits_type::eof()) {
    // default: unbuffered, every call is a failure
    (void)c;
    return traits_type::eof();
  }

  virtual int_type underflow() { return traits_type::eof(); }

  virtual int_type pbackfail(int_type c = traits_type::eof()) {
    (void)c;
    return traits_type::eof();
  }

  // Read and consume next char (default: underflow then bump)
  virtual int_type uflow() {
    int_type c = underflow();
    if (!traits_type::eq_int_type(c, traits_type::eof()) && gptr_ < egptr_)
      ++gptr_;
    return c;
  }

  virtual streamsize xsgetn(char_type* s, streamsize n) {
    streamsize got = 0;
    while (got < n) {
      int_type c = sbumpc();
      if (traits_type::eq_int_type(c, traits_type::eof()))
        break;
      s[got++] = traits_type::to_char_type(c);
    }
    return got;
  }

  virtual streamsize xsputn(const char_type* s, streamsize n) {
    streamsize written = 0;
    while (n-- > 0) {
      if (sputc(*s++) == traits_type::eof())
        break;
      ++written;
    }
    return written;
  }

  virtual int sync() { return 0; }

  virtual streampos seekpos(streampos, ios_base::openmode) {
    return streampos(-1);
  }
  virtual streampos seekoff(streamoff, ios_base::seekdir, ios_base::openmode) {
    return streampos(-1);
  }

private:
  char_type* pbase_;
  char_type* pptr_;
  char_type* epptr_;
  char_type* eback_;
  char_type* gptr_;
  char_type* egptr_;
};

using streambuf = basic_streambuf<char, char_traits<char>>;
using wstreambuf = basic_streambuf<wchar_t, char_traits<wchar_t>>;

} // namespace std
