#pragma once
#include <__psychicstd_algo>
#include <cstddef>
#include <initializer_list>
#include <iterator>
#include <memory>

namespace std {

template <typename T, typename Allocator = allocator<T>> class list {
  struct Node {
    T value;
    Node* prev = nullptr;
    Node* next = nullptr;
    template <typename... Args>
    Node(Args&&... args) : value(static_cast<Args&&>(args)...) {}
  };

  Node* head_ = nullptr;
  Node* tail_ = nullptr;
  size_t size_ = 0;
  Allocator alloc_{};

  void link_back(Node* n) {
    n->prev = tail_;
    n->next = nullptr;
    if (tail_)
      tail_->next = n;
    else
      head_ = n;
    tail_ = n;
    ++size_;
  }
  void unlink(Node* n) {
    if (n->prev)
      n->prev->next = n->next;
    else
      head_ = n->next;
    if (n->next)
      n->next->prev = n->prev;
    else
      tail_ = n->prev;
    --size_;
  }

public:
  using value_type = T;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using reference = T&;
  using const_reference = const T&;
  using pointer = T*;
  using const_pointer = const T*;

  struct iterator {
    using iterator_category = bidirectional_iterator_tag;
    using value_type = T;
    using difference_type = ptrdiff_t;
    using pointer = T*;
    using reference = T&;
    Node* n;
    iterator(Node* n = nullptr) : n(n) {}
    T& operator*() const { return n->value; }
    T* operator->() const { return &n->value; }
    iterator& operator++() {
      n = n->next;
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    iterator& operator--() {
      n = n->prev;
      return *this;
    }
    bool operator==(const iterator& o) const { return n == o.n; }
    bool operator!=(const iterator& o) const { return n != o.n; }
  };
  struct const_iterator {
    using iterator_category = bidirectional_iterator_tag;
    using value_type = T;
    using difference_type = ptrdiff_t;
    using pointer = const T*;
    using reference = const T&;
    const Node* n;
    const_iterator(const Node* n = nullptr) : n(n) {}
    const_iterator(iterator it) : n(it.n) {}
    const T& operator*() const { return n->value; }
    const T* operator->() const { return &n->value; }
    const_iterator& operator++() {
      n = n->next;
      return *this;
    }
    const_iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    const_iterator& operator--() {
      n = n->prev;
      return *this;
    }
    const_iterator operator--(int) {
      auto t = *this;
      --*this;
      return t;
    }
    bool operator==(const const_iterator& o) const { return n == o.n; }
    bool operator!=(const const_iterator& o) const { return n != o.n; }
  };

  using reverse_iterator = std::reverse_iterator<iterator>;
  using const_reverse_iterator = std::reverse_iterator<const_iterator>;

  list() = default;
  explicit list(const Allocator& alloc) : alloc_(alloc) {}
  list(initializer_list<T> il) {
    for (const auto& v : il)
      push_back(v);
  }
  list(size_type n, const T& val = T{}) {
    for (size_type i = 0; i < n; ++i)
      push_back(val);
  }
  template <typename It> list(It first, It last) {
    for (; first != last; ++first)
      push_back(*first);
  }
  list(const list& o) : alloc_(o.alloc_) {
    for (const auto& v : o)
      push_back(v);
  }
  list(list&& o) noexcept
      : head_(o.head_), tail_(o.tail_), size_(o.size_), alloc_(o.alloc_) {
    o.head_ = o.tail_ = nullptr;
    o.size_ = 0;
  }
  ~list() { clear(); }
  list& operator=(const list& o) {
    if (this != &o) {
      clear();
      alloc_ = o.alloc_;
      for (const auto& v : o)
        push_back(v);
    }
    return *this;
  }
  list& operator=(list&& o) noexcept {
    clear();
    head_ = o.head_;
    tail_ = o.tail_;
    size_ = o.size_;
    alloc_ = o.alloc_;
    o.head_ = o.tail_ = nullptr;
    o.size_ = 0;
    return *this;
  }

  iterator begin() { return {head_}; }
  iterator end() { return {nullptr}; }
  const_iterator begin() const { return {head_}; }
  const_iterator end() const { return {nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  reverse_iterator rbegin() { return reverse_iterator(end()); }
  reverse_iterator rend() { return reverse_iterator(begin()); }
  const_reverse_iterator rbegin() const {
    return const_reverse_iterator(end());
  }
  const_reverse_iterator rend() const {
    return const_reverse_iterator(begin());
  }
  const_reverse_iterator crbegin() const { return rbegin(); }
  const_reverse_iterator crend() const { return rend(); }

  size_type size() const noexcept { return size_; }
  bool empty() const noexcept { return size_ == 0; }
  allocator_type get_allocator() const noexcept { return alloc_; }

  T& front() { return head_->value; }
  const T& front() const { return head_->value; }
  T& back() { return tail_->value; }
  const T& back() const { return tail_->value; }

  void push_back(const T& v) { link_back(new Node(v)); }
  void push_back(T&& v) { link_back(new Node(static_cast<T&&>(v))); }
  void push_front(const T& v) {
    Node* n = new Node(v);
    n->next = head_;
    n->prev = nullptr;
    if (head_)
      head_->prev = n;
    else
      tail_ = n;
    head_ = n;
    ++size_;
  }
  void pop_back() {
    Node* n = tail_;
    unlink(n);
    delete n;
  }
  void pop_front() {
    Node* n = head_;
    unlink(n);
    delete n;
  }
  template <typename... Args> iterator emplace_back(Args&&... args) {
    Node* n = new Node(static_cast<Args&&>(args)...);
    link_back(n);
    return {n};
  }
  template <typename... Args> iterator emplace_front(Args&&... args) {
    Node* n = new Node(static_cast<Args&&>(args)...);
    n->next = head_;
    n->prev = nullptr;
    if (head_)
      head_->prev = n;
    else
      tail_ = n;
    head_ = n;
    ++size_;
    return {n};
  }
  void clear() {
    Node* n = head_;
    while (n) {
      Node* next = n->next;
      delete n;
      n = next;
    }
    head_ = tail_ = nullptr;
    size_ = 0;
  }
  iterator erase(iterator it) {
    Node* n = it.n;
    Node* next = n->next;
    unlink(n);
    delete n;
    return {next};
  }
  iterator erase(const_iterator it) {
    Node* n = const_cast<Node*>(it.n);
    Node* next = n->next;
    unlink(n);
    delete n;
    return {next};
  }
  iterator erase(const_iterator first, const_iterator last) {
    while (first != last)
      first = erase(first);
    return iterator{const_cast<Node*>(last.n)};
  }
  iterator insert(const_iterator pos, const T& v) {
    return insert(iterator{const_cast<Node*>(pos.n)}, v);
  }
  iterator insert(iterator pos, const T& v) {
    if (!pos.n) {
      push_back(v);
      return {tail_};
    }
    Node* n = new Node(v);
    Node* cur = pos.n;
    n->next = cur;
    n->prev = cur->prev;
    if (cur->prev)
      cur->prev->next = n;
    else
      head_ = n;
    cur->prev = n;
    ++size_;
    return {n};
  }
  template <typename It>
  iterator insert(const_iterator pos, It first, It last) {
    Node* cur = const_cast<Node*>(pos.n);
    for (; first != last; ++first) {
      Node* n = new Node(*first);
      n->next = cur;
      n->prev = cur ? cur->prev : tail_;
      if (cur) {
        if (cur->prev)
          cur->prev->next = n;
        else
          head_ = n;
        cur->prev = n;
      } else {
        if (tail_)
          tail_->next = n;
        else
          head_ = n;
        tail_ = n;
      }
      ++size_;
    }
    return {pos.n ? const_cast<Node*>(pos.n) : tail_};
  }
  void sort() {
    if (size_ <= 1)
      return;
    for (Node* i = head_->next; i; i = i->next) {
      T key = i->value;
      Node* j = i->prev;
      while (j && j->value > key) {
        j->next->value = j->value;
        j = j->prev;
      }
      (j ? j->next : head_)->value = key;
    }
  }
  template <typename Compare> void sort(Compare comp) {
    if (size_ <= 1)
      return;
    for (Node* i = head_->next; i; i = i->next) {
      T key = i->value;
      Node* j = i->prev;
      while (j && comp(key, j->value)) {
        j->next->value = j->value;
        j = j->prev;
      }
      (j ? j->next : head_)->value = key;
    }
  }
  void remove(const T& val) {
    Node* n = head_;
    while (n) {
      Node* next = n->next;
      if (n->value == val) {
        unlink(n);
        delete n;
      }
      n = next;
    }
  }
  template <typename Pred> size_type remove_if(Pred pred) {
    size_type removed = 0;
    Node* n = head_;
    while (n) {
      Node* next = n->next;
      if (pred(n->value)) {
        unlink(n);
        delete n;
        ++removed;
      }
      n = next;
    }
    return removed;
  }
  void unique() {
    Node* n = head_;
    while (n && n->next) {
      if (n->value == n->next->value) {
        Node* dup = n->next;
        unlink(dup);
        delete dup;
      } else {
        n = n->next;
      }
    }
  }
  void splice(const_iterator pos, list& other) {
    if (other.size_ == 0)
      return;
    Node* at = const_cast<Node*>(pos.n);
    for (Node* n = other.head_; n;) {
      Node* next = n->next;
      n->prev = at ? at->prev : tail_;
      n->next = at;
      if (at) {
        if (at->prev)
          at->prev->next = n;
        else
          head_ = n;
        at->prev = n;
      } else {
        if (tail_)
          tail_->next = n;
        else
          head_ = n;
        tail_ = n;
      }
    }
    size_ += other.size_;
    other.head_ = other.tail_ = nullptr;
    other.size_ = 0;
  }
  void splice(const_iterator pos, list& other, const_iterator first,
              const_iterator last) {
    if (first == last)
      return;
    Node* f = const_cast<Node*>(first.n);
    Node* l = const_cast<Node*>(last.n);
    // Detach range [f, l) from other
    Node* prev = f->prev;
    Node* before_last = l ? l->prev : other.tail_;
    if (prev)
      prev->next = l;
    else
      other.head_ = l;
    if (l)
      l->prev = prev;
    else
      other.tail_ = prev;
    // Count and adjust other size
    size_t n = 0;
    for (Node* cur = f; cur != l; cur = cur->next)
      ++n;
    if (n > other.size_)
      n = other.size_;
    other.size_ -= n;
    // Insert into this list before pos
    Node* at = const_cast<Node*>(pos.n);
    if (at) {
      if (at->prev)
        at->prev->next = f;
      else
        head_ = f;
      f->prev = at->prev;
      if (before_last)
        before_last->next = at;
      at->prev = before_last;
    } else {
      if (tail_) {
        tail_->next = f;
        f->prev = tail_;
      } else
        head_ = f;
      tail_ = before_last ? before_last : f;
      if (tail_)
        tail_->next = nullptr;
    }
    size_ += n;
  }
};

template <typename T, typename A>
bool operator==(const list<T, A>& a, const list<T, A>& b) {
  if (a.size() != b.size())
    return false;
  auto ai = a.begin(), bi = b.begin();
  for (; ai != a.end(); ++ai, ++bi)
    if (!(*ai == *bi))
      return false;
  return true;
}
template <typename T, typename A>
bool operator!=(const list<T, A>& a, const list<T, A>& b) {
  return !(a == b);
}
template <typename T, typename A>
bool operator<(const list<T, A>& a, const list<T, A>& b) {
  return __lexicographical_compare(a.begin(), a.end(), b.begin(), b.end());
}

} // namespace std
