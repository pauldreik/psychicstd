#pragma once
#include <cstddef>
#include <initializer_list>
#include <iterator>
#include <memory>

namespace std {

template <typename T, typename Allocator = allocator<T>> class list {
  struct Node {
    T value;
    Node* prev = nullptr;
    Node* next = nullptr;
    template <typename... Args>
    Node(Args&&... args) : value(static_cast<Args&&>(args)...) {}
  };

  Node* head_ = nullptr;
  Node* tail_ = nullptr;
  size_t size_ = 0;

  void link_back(Node* n) {
    n->prev = tail_;
    n->next = nullptr;
    if (tail_)
      tail_->next = n;
    else
      head_ = n;
    tail_ = n;
    ++size_;
  }
  void unlink(Node* n) {
    if (n->prev)
      n->prev->next = n->next;
    else
      head_ = n->next;
    if (n->next)
      n->next->prev = n->prev;
    else
      tail_ = n->prev;
    --size_;
  }

public:
  using value_type = T;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using reference = T&;
  using const_reference = const T&;
  using pointer = T*;
  using const_pointer = const T*;

  struct iterator {
    using iterator_category = bidirectional_iterator_tag;
    using value_type = T;
    using difference_type = ptrdiff_t;
    using pointer = T*;
    using reference = T&;
    Node* n;
    iterator(Node* n = nullptr) : n(n) {}
    T& operator*() const { return n->value; }
    T* operator->() const { return &n->value; }
    iterator& operator++() {
      n = n->next;
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    iterator& operator--() {
      n = n->prev;
      return *this;
    }
    bool operator==(const iterator& o) const { return n == o.n; }
    bool operator!=(const iterator& o) const { return n != o.n; }
  };
  struct const_iterator {
    using iterator_category = bidirectional_iterator_tag;
    using value_type = T;
    using difference_type = ptrdiff_t;
    using pointer = const T*;
    using reference = const T&;
    const Node* n;
    const_iterator(const Node* n = nullptr) : n(n) {}
    const_iterator(iterator it) : n(it.n) {}
    const T& operator*() const { return n->value; }
    const T* operator->() const { return &n->value; }
    const_iterator& operator++() {
      n = n->next;
      return *this;
    }
    const_iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    bool operator==(const const_iterator& o) const { return n == o.n; }
    bool operator!=(const const_iterator& o) const { return n != o.n; }
  };

  list() = default;
  explicit list(const Allocator&) {}
  list(initializer_list<T> il) {
    for (const auto& v : il)
      push_back(v);
  }
  list(size_type n, const T& val = T{}) {
    for (size_type i = 0; i < n; ++i)
      push_back(val);
  }
  template <typename It> list(It first, It last) {
    for (; first != last; ++first)
      push_back(*first);
  }
  list(const list& o) {
    for (const auto& v : o)
      push_back(v);
  }
  list(list&& o) noexcept : head_(o.head_), tail_(o.tail_), size_(o.size_) {
    o.head_ = o.tail_ = nullptr;
    o.size_ = 0;
  }
  ~list() { clear(); }
  list& operator=(const list& o) {
    if (this != &o) {
      clear();
      for (const auto& v : o)
        push_back(v);
    }
    return *this;
  }
  list& operator=(list&& o) noexcept {
    clear();
    head_ = o.head_;
    tail_ = o.tail_;
    size_ = o.size_;
    o.head_ = o.tail_ = nullptr;
    o.size_ = 0;
    return *this;
  }

  iterator begin() { return {head_}; }
  iterator end() { return {nullptr}; }
  const_iterator begin() const { return {head_}; }
  const_iterator end() const { return {nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  size_type size() const noexcept { return size_; }
  bool empty() const noexcept { return size_ == 0; }

  T& front() { return head_->value; }
  const T& front() const { return head_->value; }
  T& back() { return tail_->value; }
  const T& back() const { return tail_->value; }

  void push_back(const T& v) { link_back(new Node(v)); }
  void push_back(T&& v) { link_back(new Node(static_cast<T&&>(v))); }
  void push_front(const T& v) {
    Node* n = new Node(v);
    n->next = head_;
    n->prev = nullptr;
    if (head_)
      head_->prev = n;
    else
      tail_ = n;
    head_ = n;
    ++size_;
  }
  void pop_back() {
    Node* n = tail_;
    unlink(n);
    delete n;
  }
  void pop_front() {
    Node* n = head_;
    unlink(n);
    delete n;
  }
  template <typename... Args> iterator emplace_back(Args&&... args) {
    Node* n = new Node(static_cast<Args&&>(args)...);
    link_back(n);
    return {n};
  }
  void clear() {
    Node* n = head_;
    while (n) {
      Node* next = n->next;
      delete n;
      n = next;
    }
    head_ = tail_ = nullptr;
    size_ = 0;
  }
  iterator erase(iterator it) {
    Node* n = it.n;
    Node* next = n->next;
    unlink(n);
    delete n;
    return {next};
  }
  iterator insert(iterator pos, const T& v) {
    if (!pos.n) {
      push_back(v);
      return {tail_};
    }
    Node* n = new Node(v);
    Node* cur = pos.n;
    n->next = cur;
    n->prev = cur->prev;
    if (cur->prev)
      cur->prev->next = n;
    else
      head_ = n;
    cur->prev = n;
    ++size_;
    return {n};
  }
  void sort() {
    if (size_ <= 1)
      return;
    // insertion sort (fine for a stub)
    for (Node* i = head_->next; i; i = i->next) {
      T key = i->value;
      Node* j = i->prev;
      while (j && j->value > key) {
        j->next->value = j->value;
        j = j->prev;
      }
      (j ? j->next : head_)->value = key;
    }
  }
  void remove(const T& val) {
    Node* n = head_;
    while (n) {
      Node* next = n->next;
      if (n->value == val) {
        unlink(n);
        delete n;
      }
      n = next;
    }
  }
  void unique() {
    Node* n = head_;
    while (n && n->next) {
      if (n->value == n->next->value) {
        Node* dup = n->next;
        unlink(dup);
        delete dup;
      } else {
        n = n->next;
      }
    }
  }
};

} // namespace std
