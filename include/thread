namespace std {

[[noreturn]] void terminate() noexcept;

namespace __thread_detail {
inline unsigned long __id_value(pthread_t t) noexcept {
#ifdef __APPLE__
  return reinterpret_cast<unsigned long>(t); // pthread_t is a pointer on Darwin
#else
  return static_cast<unsigned long>(t);
#endif
}
template <typename F, typename Tuple, size_t... Is>
constexpr decltype(auto) __invoke_from_tuple(F&& f, Tuple& args,
                                             index_sequence<Is...>) {
  return detail::__invoke(
      static_cast<F&&>(f),
      static_cast<tuple_element_t<Is, Tuple>&&>(get<Is>(args))...);
}
template <typename F, typename Tuple>
constexpr decltype(auto) __invoke_from_tuple(F&& f, Tuple& args) {
  return __invoke_from_tuple(static_cast<F&&>(f), args,
                             make_index_sequence<tuple_size_v<Tuple>>{});
}
template <typename F, typename Token, typename Tuple, size_t... Is>
constexpr decltype(auto) __invoke_from_tuple_token(F&& f, Token&& token,
                                                   Tuple& args,
                                                   index_sequence<Is...>) {
  return detail::__invoke(
      static_cast<F&&>(f), static_cast<Token&&>(token),
      static_cast<tuple_element_t<Is, Tuple>&&>(get<Is>(args))...);
}
template <typename F, typename Token, typename Tuple>
constexpr decltype(auto) __invoke_from_tuple_token(F&& f, Token&& token,
                                                   Tuple& args) {
  return __invoke_from_tuple_token(static_cast<F&&>(f),
                                   static_cast<Token&&>(token), args,
                                   make_index_sequence<tuple_size_v<Tuple>>{});
}
} // namespace __thread_detail

class thread {
  friend class jthread;
  pthread_t handle_{};
  bool joinable_ = false;

  struct __state {
    virtual ~__state() = default;
    virtual void run() noexcept = 0;
  };
  template <typename F, typename... Args> struct __state_impl final : __state {
    F function;
    tuple<Args...> arguments;
    template <typename Fn, typename... Ts>
    explicit __state_impl(Fn&& f, Ts&&... args)
        : function(static_cast<Fn&&>(f)),
          arguments(static_cast<Ts&&>(args)...) {}
    void run() noexcept override {
      __thread_detail::__invoke_from_tuple(static_cast<F&&>(function),
                                           arguments);
    }
  };
  static void* __start(void* ptr) noexcept {
    __state* state = static_cast<__state*>(ptr);
    state->run();
    delete state;
    return nullptr;
  }

public:
  class id {
    unsigned long val_ = 0;
    friend class thread;

  public:
    id(unsigned long v) noexcept : val_(v) {}
    id() noexcept = default;
    unsigned long _value() const noexcept { return val_; }
    bool operator!=(id o) const noexcept { return val_ != o.val_; }
    bool operator<(id o) const noexcept { return val_ < o.val_; }
  };

  thread() = default;
  template <typename F, typename... Args>
  explicit thread(F&& f, Args&&... args) {
    using Fn = decay_t<F>;
    using State = __state_impl<Fn, decay_t<Args>...>;
    static_assert(is_invocable_v<Fn, decay_t<Args>...>,
                  "psychicstd::thread callable is not invocable with args");
    auto* state = new State(static_cast<F&&>(f), static_cast<Args&&>(args)...);
    if (::pthread_create(&handle_, nullptr, __start, state) != 0) {
      delete state;
      __builtin_trap();
    }
    joinable_ = true;
  }
  thread(thread&& other) noexcept
      : handle_(other.handle_), joinable_(other.joinable_) {
    other.joinable_ = false;
  }
  thread& operator=(thread&& other) noexcept {
    if (this != &other) {
      if (joinable_)
        terminate();
      handle_ = other.handle_;
      joinable_ = other.joinable_;
      other.joinable_ = false;
    }
    return *this;
  }
  thread(const thread&) = delete;
  thread& operator=(const thread&) = delete;
  ~thread() {
    if (joinable_)
      terminate();
  }
  bool joinable() const noexcept { return joinable_; }
  void join() {
    if (!joinable_ || ::pthread_join(handle_, nullptr) != 0)
      __builtin_trap();
    joinable_ = false;
  }
  void detach() {
    if (!joinable_ || ::pthread_detach(handle_) != 0)
      __builtin_trap();
    joinable_ = false;
  }
  id get_id() const noexcept {
    return joinable_ ? id(__thread_detail::__id_value(handle_)) : id();
  }
  static unsigned hardware_concurrency() noexcept {
#ifdef __APPLE__
    long n = sysconf(58); /* _SC_NPROCESSORS_ONLN */
#else
    long n = sysconf(84); /* _SC_NPROCESSORS_ONLN */
#endif
    return n > 0 ? (unsigned)n : 1;
  }
};

class jthread {
  thread thread_{};
  stop_source source_{nostopstate};

  template <typename F, typename... Args> struct __state : thread::__state {
    F function;
    stop_token token;
    tuple<Args...> arguments;
    template <typename Fn, typename... Ts>
    explicit __state(Fn&& f, stop_token t, Ts&&... args)
        : function(static_cast<Fn&&>(f)), token(static_cast<stop_token&&>(t)),
          arguments(static_cast<Ts&&>(args)...) {}
    void run() noexcept {
      if constexpr (is_invocable_v<F, stop_token, Args...>) {
        __thread_detail::__invoke_from_tuple_token(
            static_cast<F&&>(function), static_cast<stop_token&&>(token),
            arguments);
      } else {
        __thread_detail::__invoke_from_tuple(static_cast<F&&>(function),
                                             arguments);
      }
    }
  };

  template <typename F, typename... Args> void __start(F&& f, Args&&... args) {
    using Fn = decay_t<F>;
    using State = __state<Fn, decay_t<Args>...>;
    static_assert(is_invocable_v<Fn, decay_t<Args>...> ||
                      is_invocable_v<Fn, stop_token, decay_t<Args>...>,
                  "psychicstd::jthread callable is not invocable");
    auto* state = new State(static_cast<F&&>(f), source_.get_token(),
                            static_cast<Args&&>(args)...);
    if (::pthread_create(&thread_.handle_, nullptr, thread::__start, state) !=
        0) {
      delete state;
      __builtin_trap();
    }
    thread_.joinable_ = true;
  }

public:
  jthread() noexcept = default;

  template <typename F, typename... Args>
  explicit jthread(F&& f, Args&&... args) : source_() {
    __start(static_cast<F&&>(f), static_cast<Args&&>(args)...);
  }

  jthread(jthread&&) noexcept = default;
  jthread& operator=(jthread&& other) noexcept {
    if (this != &other) {
      if (joinable()) {
        request_stop();
        join();
      }
      thread_ = static_cast<thread&&>(other.thread_);
      source_ = static_cast<stop_source&&>(other.source_);
    }
    return *this;
  }
  ~jthread() {
    if (joinable()) {
      request_stop();
      join();
    }
  }

  jthread(const jthread&) = delete;
  jthread& operator=(const jthread&) = delete;

  bool joinable() const noexcept { return thread_.joinable(); }
  void join() { thread_.join(); }
  void detach() { thread_.detach(); }
  thread::id get_id() const noexcept { return thread_.get_id(); }
  static unsigned hardware_concurrency() noexcept {
    return thread::hardware_concurrency();
  }
  stop_source get_stop_source() const noexcept { return source_; }
  stop_token get_stop_token() const noexcept { return source_.get_token(); }
  bool request_stop() noexcept { return source_.request_stop(); }
};

inline bool operator==(thread::id a, thread::id b) noexcept {
  // Compare values directly: '!(a != b)' would recurse under C++20 rewritten
  // candidates, since 'a != b' can resolve back to this operator==.
  return a._value() == b._value();
}
inline auto operator<=>(thread::id a, thread::id b) noexcept {
  return a.operator<(b)   ? strong_ordering::less
         : b.operator<(a) ? strong_ordering::greater
                          : strong_ordering::equal;
}
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        thread::id value) {
  return os << value._value();
}

namespace this_thread {

inline thread::id get_id() noexcept {
  return thread::id(__thread_detail::__id_value(::pthread_self()));
}

template <typename Rep, typename Period>
void sleep_for(const chrono::duration<Rep, Period>& d) {
  auto ns = chrono::duration_cast<chrono::nanoseconds>(d).count();
  if (ns <= 0)
    return;
  struct timespec ts;
  ts.tv_sec = ns / 1'000'000'000LL;
  ts.tv_nsec = ns % 1'000'000'000LL;
  ::nanosleep(&ts, nullptr);
}

template <typename Clock, typename Duration>
void sleep_until(const chrono::time_point<Clock, Duration>& abs_time) {
  auto now = Clock::now();
  if (abs_time > now)
    sleep_for(abs_time - now);
}

inline void yield() noexcept { ::sched_yield(); }

} // namespace this_thread
} // namespace std
