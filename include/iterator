};

template <typename Container>
front_insert_iterator<Container> front_inserter(Container& c) {
  return front_insert_iterator<Container>(c);
}

// istream_iterator
template <typename T, typename Char = char, typename Traits = char_traits<char>,
          typename Dist = ptrdiff_t>
class istream_iterator {
public:
  using iterator_category = input_iterator_tag;
  using value_type = T;
  using difference_type = Dist;
  using pointer = const T*;
  using reference = const T&;
  using char_type = Char;
  using traits_type = Traits;
  using istream_type = basic_istream<Char, Traits>;

  istream_iterator() noexcept : is_(nullptr) {}
  explicit istream_iterator(istream_type& is) : is_(&is) { advance(); }

  const T& operator*() const noexcept { return val_; }
  const T* operator->() const noexcept { return &val_; }

  istream_iterator& operator++() {
    advance();
    return *this;
  }
  istream_iterator operator++(int) {
    auto tmp = *this;
    advance();
    return tmp;
  }

  friend bool operator==(const istream_iterator& a,
                         const istream_iterator& b) noexcept {
    return a.is_ == b.is_;
  }
  friend bool operator!=(const istream_iterator& a,
                         const istream_iterator& b) noexcept {
    return !(a == b);
  }

private:
  istream_type* is_;
  T val_{};

  void advance() {
    if (is_ && !(*is_ >> val_))
      is_ = nullptr;
  }
};

// ostream_iterator
template <typename T, typename Char = char, typename Traits = char_traits<char>>
class ostream_iterator {
public:
  using iterator_category = output_iterator_tag;
  using value_type = void;
  using difference_type = ptrdiff_t;
  using pointer = void;
  using reference = void;
  using char_type = Char;
  using traits_type = Traits;
  using ostream_type = basic_ostream<Char, Traits>;

  ostream_iterator(ostream_type& os, const Char* delim = nullptr)
      : os_(&os), delim_(delim) {}

  ostream_iterator& operator=(const T& v) {
    *os_ << v;
    if (delim_)
      *os_ << delim_;
    return *this;
  }
  ostream_iterator& operator*() { return *this; }
  ostream_iterator& operator++() { return *this; }
  ostream_iterator operator++(int) { return *this; }

private:
  ostream_type* os_;
  const Char* delim_;
};

// istreambuf_iterator
template <typename Char, typename Traits = char_traits<Char>>
class istreambuf_iterator {
public:
  using iterator_category = input_iterator_tag;
  using value_type = Char;
  using difference_type = ptrdiff_t;
  using pointer = Char*;
  using reference = Char;
  using char_type = Char;
  using traits_type = Traits;
  using int_type = typename Traits::int_type;
  using streambuf_type = basic_streambuf<Char, Traits>;
  using istream_type = basic_istream<Char, Traits>;

  istreambuf_iterator() noexcept : sb_(nullptr), eof_(true) {}
  explicit istreambuf_iterator(streambuf_type* sb) : sb_(sb), eof_(false) {
    fetch();
  }
  explicit istreambuf_iterator(istream_type& is)
      : sb_(is.rdbuf()), eof_(false) {
    fetch();
  }

  Char operator*() const { return val_; }
  istreambuf_iterator& operator++() {
    fetch();
    return *this;
  }
  istreambuf_iterator operator++(int) {
    auto tmp = *this;
    fetch();
    return tmp;
  }

  bool equal(const istreambuf_iterator& o) const { return eof_ == o.eof_; }

  friend bool operator==(const istreambuf_iterator& a,
                         const istreambuf_iterator& b) {
    return a.equal(b);
  }
  friend bool operator!=(const istreambuf_iterator& a,
                         const istreambuf_iterator& b) {
    return !a.equal(b);
  }

private:
  streambuf_type* sb_;
  Char val_{};
  bool eof_;

  void fetch() {
    auto c = sb_ ? sb_->sbumpc() : Traits::eof();
    if (Traits::eq_int_type(c, Traits::eof())) {
      eof_ = true;
      sb_ = nullptr;
    } else {
      val_ = Traits::to_char_type(c);
    }
  }
};

// move_iterator
template <typename It> class move_iterator {
  It it_;
public:
  using iterator_type = It;
  using iterator_category = typename iterator_traits<It>::iterator_category;
  using value_type = typename iterator_traits<It>::value_type;
  using difference_type = typename iterator_traits<It>::difference_type;
  using pointer = It;
  using reference = value_type&&;
  constexpr move_iterator() = default;
  constexpr explicit move_iterator(It it) : it_(it) {}
  constexpr It base() const { return it_; }
  constexpr reference operator*() const { return static_cast<reference>(*it_); }
  constexpr move_iterator& operator++() { ++it_; return *this; }
  constexpr move_iterator operator++(int) { auto t = *this; ++it_; return t; }
  friend constexpr bool operator==(const move_iterator& a, const move_iterator& b) { return a.it_ == b.it_; }
  friend constexpr bool operator!=(const move_iterator& a, const move_iterator& b) { return a.it_ != b.it_; }
};

template <typename It>
constexpr move_iterator<It> make_move_iterator(It it) { return move_iterator<It>(it); }

} // namespace std
