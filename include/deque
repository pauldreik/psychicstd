#pragma once
#include <__psychicstd_config>
#include <__psychicstd_contiguous_compare>
#include <__psychicstd_contiguous_iterator>
#include <__psychicstd_except>
#include <__psychicstd_iterator_core>
#include <cstddef>
#include <initializer_list>
#include <memory>
#include <type_traits>

#if _PSYCHICSTD_COMPATIBILITY_LEVEL >= _PSYCHICSTD_COMPAT_DROPIN
// libstdc++ exposes move_backward through <deque>.
#include <__psychicstd_algobase>
#endif

namespace std {

// deque implemented as a single contiguous buffer with slack at both ends
// (front_/size_/cap_), grown by doubling-and-recentering. push_front/
// push_back/pop_front/pop_back are O(1) amortized, and pop_front/pop_back
// never move surviving elements (so pointers/iterators/references to them
// stay valid), matching the standard's invalidation guarantees. Middle
// insert/erase shift whichever side (front or back) is shorter.
template <typename T, typename Allocator = allocator<T>> class deque {
public:
  using value_type = T;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using reference = T&;
  using const_reference = const T&;
  using pointer = T*;
  using const_pointer = const T*;
  // A raw pointer cannot be decremented/incremented as an rvalue (e.g.
  // `--v.end()`), which real STL containers support.
  using iterator = __vec_iter<T>;
  using const_iterator = __vec_iter<const T>;
  using reverse_iterator = std::reverse_iterator<iterator>;
  using const_reverse_iterator = std::reverse_iterator<const_iterator>;

private:
  T* data_;
  size_type start_;
  size_type size_;
  size_type cap_;
  [[no_unique_address]] Allocator alloc_;

  // Raw memory: always via std::allocator<T>, same rationale as vector (we
  // still store alloc_ for get_allocator()/POCCA/POCMA/POCS, but don't route
  // memory through custom allocators with fancy pointer types).
  static T* _alloc_mem(size_type n) { return allocator<T>{}.allocate(n); }
  static void _free_mem(T* p, size_type n) noexcept {
    if (p)
      allocator<T>{}.deallocate(p, n);
  }
  template <typename... Args> void _construct(T* p, Args&&... args) {
    // forward
    allocator_traits<Allocator>::construct(alloc_, p,
                                           static_cast<Args&&>(args)...);
  }
  void _destroy(T* p) noexcept {
    allocator_traits<Allocator>::destroy(alloc_, p);
  }
  void _destroy_all() noexcept {
    for (size_type i = 0; i < size_; ++i)
      _destroy(data_ + start_ + i);
  }

  static decltype(auto)
  _xfer(T& x) noexcept(is_nothrow_move_constructible_v<T>) {
    if constexpr (is_move_constructible_v<T>) {
      // move
      return static_cast<T&&>(x);
    } else
      return static_cast<const T&>(x);
  }

  // Move all live elements into a freshly allocated buffer of size new_cap,
  // placed starting at new_start; free the old buffer.
  void _recenter(size_type new_cap, size_type new_start) {
    T* np = _alloc_mem(new_cap);
    for (size_type i = 0; i < size_; ++i) {
      _construct(np + new_start + i, _xfer(data_[start_ + i]));
      _destroy(data_ + start_ + i);
    }
    _free_mem(data_, cap_);
    data_ = np;
    cap_ = new_cap;
    start_ = new_start;
  }

  // Ensure at least front_need free slots before start_ and back_need free
  // slots after start_+size_, recentering (and growing) if necessary.
  void _ensure_slack(size_type front_need, size_type back_need) {
    size_type free_front = start_;
    size_type free_back = cap_ - start_ - size_;
    if (free_front >= front_need && free_back >= back_need)
      return;
    size_type m = front_need > back_need ? front_need : back_need;
    size_type need = size_ + 2 * m;
    size_type nc = cap_ ? cap_ * 2 : 4;
    while (nc < need)
      nc *= 2;
    _recenter(nc, (nc - size_) / 2);
  }

  // Shift elements at relative [0, idx) left by n, into front slack that
  // _ensure_slack(n, 0) already guaranteed. Leaves a gap of n raw slots at
  // the new start_+idx (start_ is decremented by n as part of this).
  void _insert_shift_front(size_type idx, size_type n) {
    for (size_type i = 0; i < idx; ++i) {
      size_type dst = start_ - n + i;
      if (i < n)
        _construct(data_ + dst, _xfer(data_[start_ + i]));
      else
        data_[dst] = _xfer(data_[start_ + i]);
    }
    size_type first_dead = idx > n ? idx - n : 0;
    for (size_type i = first_dead; i < idx; ++i)
      _destroy(data_ + start_ + i);
    start_ -= n;
  }

  // Shift elements at relative [idx, size_) right by n, into back slack that
  // _ensure_slack(0, n) already guaranteed. Leaves a gap of n raw slots at
  // start_+idx.
  void _insert_shift_back(size_type idx, size_type n) {
    for (size_type i = size_; i-- > idx;) {
      if (i + n >= size_)
        _construct(data_ + start_ + i + n, _xfer(data_[start_ + i]));
      else
        data_[start_ + i + n] = _xfer(data_[start_ + i]);
    }
    size_type stop = idx + n < size_ ? idx + n : size_;
    for (size_type j = idx; j < stop; ++j)
      _destroy(data_ + start_ + j);
  }

  // Ensure slack and open an n-wide gap at relative position idx, shifting
  // whichever side (front or back) touches fewer elements. Does not update
  // size_; caller fills the gap at data_+start_+idx and then adds n to
  // size_.
  void _make_gap(size_type idx, size_type n) {
    size_type back_span = size_ - idx;
    if (idx <= back_span) {
      _ensure_slack(n, 0);
      _insert_shift_front(idx, n);
    } else {
      _ensure_slack(0, n);
      _insert_shift_back(idx, n);
    }
  }

  // Close an n-wide gap at relative [idx, idx+n) (the range being erased),
  // shifting whichever side touches fewer elements. Does not update size_;
  // caller subtracts n from size_.
  void _make_erase_gap(size_type idx, size_type n) {
    size_type back_span = size_ - idx - n;
    if (idx <= back_span) {
      for (size_type i = idx; i-- > 0;)
        data_[start_ + i + n] = _xfer(data_[start_ + i]);
      for (size_type i = 0; i < n; ++i)
        _destroy(data_ + start_ + i);
      start_ += n;
    } else {
      for (size_type i = idx + n; i < size_; ++i)
        data_[start_ + i - n] = _xfer(data_[start_ + i]);
      for (size_type i = size_ - n; i < size_; ++i)
        _destroy(data_ + start_ + i);
    }
  }

  template <typename It> void _range_init(It first, It last) {
    if constexpr (requires {
                    typename iterator_traits<It>::iterator_category;
                  } &&
                  is_base_of_v<
                      forward_iterator_tag,
                      typename iterator_traits<It>::iterator_category>) {
      size_type n = 0;
      for (auto it = first; it != last; ++it)
        ++n;
      if (n) {
        data_ = _alloc_mem(n);
        size_type i = 0;
        for (auto it = first; it != last; ++it)
          _construct(data_ + i++, *it);
        start_ = 0;
        size_ = n;
        cap_ = n;
      }
    } else {
      for (auto it = first; it != last; ++it)
        push_back(*it);
    }
  }

public:
  // Constructors

  deque() noexcept(is_nothrow_default_constructible_v<Allocator>)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_() {}
  explicit deque(const Allocator& a) noexcept
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {}

  explicit deque(size_type n)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_() {
    if (n) {
      data_ = _alloc_mem(n);
      for (size_type i = 0; i < n; ++i)
        _construct(data_ + i);
      size_ = n;
      cap_ = n;
    }
  }
  deque(size_type n, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    if (n) {
      data_ = _alloc_mem(n);
      for (size_type i = 0; i < n; ++i)
        _construct(data_ + i);
      size_ = n;
      cap_ = n;
    }
  }
  deque(size_type n, const T& v)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_() {
    if (n) {
      data_ = _alloc_mem(n);
      for (size_type i = 0; i < n; ++i)
        _construct(data_ + i, v);
      size_ = n;
      cap_ = n;
    }
  }
  deque(size_type n, const T& v, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    if (n) {
      data_ = _alloc_mem(n);
      for (size_type i = 0; i < n; ++i)
        _construct(data_ + i, v);
      size_ = n;
      cap_ = n;
    }
  }
  deque(initializer_list<T> il)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_() {
    if (il.size()) {
      data_ = _alloc_mem(il.size());
      size_type i = 0;
      for (const T& v : il)
        _construct(data_ + i++, v);
      size_ = il.size();
      cap_ = il.size();
    }
  }
  deque(initializer_list<T> il, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    if (il.size()) {
      data_ = _alloc_mem(il.size());
      size_type i = 0;
      for (const T& v : il)
        _construct(data_ + i++, v);
      size_ = il.size();
      cap_ = il.size();
    }
  }
  template <typename It>
    requires(!is_integral_v<It>)
  deque(It first, It last)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_() {
    _range_init(first, last);
  }
  template <typename It>
    requires(!is_integral_v<It>)
  deque(It first, It last, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    _range_init(first, last);
  }

  deque(const deque& o)
      : data_(nullptr), start_(0), size_(0), cap_(0),
        alloc_(
            allocator_traits<Allocator>::select_on_container_copy_construction(
                o.alloc_)) {
    if (o.size_) {
      data_ = _alloc_mem(o.size_);
      for (size_type i = 0; i < o.size_; ++i)
        _construct(data_ + i, o.data_[o.start_ + i]);
      size_ = o.size_;
      cap_ = o.size_;
    }
  }
  deque(const deque& o, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    if (o.size_) {
      data_ = _alloc_mem(o.size_);
      for (size_type i = 0; i < o.size_; ++i)
        _construct(data_ + i, o.data_[o.start_ + i]);
      size_ = o.size_;
      cap_ = o.size_;
    }
  }
  // move
  deque(deque&& o) noexcept
      : data_(o.data_), start_(o.start_), size_(o.size_), cap_(o.cap_),
        alloc_(static_cast<Allocator&&>(o.alloc_)) {
    o.data_ = nullptr;
    o.start_ = 0;
    o.size_ = 0;
    o.cap_ = 0;
  }
  deque(deque&& o, const Allocator& a)
      : data_(nullptr), start_(0), size_(0), cap_(0), alloc_(a) {
    if (a == o.alloc_) {
      data_ = o.data_;
      start_ = o.start_;
      size_ = o.size_;
      cap_ = o.cap_;
      o.data_ = nullptr;
      o.start_ = 0;
      o.size_ = 0;
      o.cap_ = 0;
    } else if (o.size_) {
      data_ = _alloc_mem(o.size_);
      for (size_type i = 0; i < o.size_; ++i)
        _construct(data_ + i, _xfer(o.data_[o.start_ + i]));
      size_ = o.size_;
      cap_ = o.size_;
    }
  }

  ~deque() {
    _destroy_all();
    _free_mem(data_, cap_);
  }

  deque& operator=(const deque& o) {
    if (this == &o)
      return *this;
    using traits = allocator_traits<Allocator>;
    if constexpr (traits::propagate_on_container_copy_assignment::value) {
      if (alloc_ != o.alloc_) {
        _destroy_all();
        _free_mem(data_, cap_);
        data_ = nullptr;
        start_ = 0;
        size_ = 0;
        cap_ = 0;
      }
      alloc_ = o.alloc_;
    }
    _destroy_all();
    if (o.size_ > cap_) {
      _free_mem(data_, cap_);
      data_ = o.size_ ? _alloc_mem(o.size_) : nullptr;
      cap_ = o.size_;
    }
    start_ = 0;
    for (size_type i = 0; i < o.size_; ++i)
      _construct(data_ + i, o.data_[o.start_ + i]);
    size_ = o.size_;
    return *this;
  }
  deque& operator=(deque&& o) noexcept(
      allocator_traits<
          Allocator>::propagate_on_container_move_assignment::value ||
      allocator_traits<Allocator>::is_always_equal::value) {
    if (this == &o)
      return *this;
    using traits = allocator_traits<Allocator>;
    if constexpr (traits::propagate_on_container_move_assignment::value) {
      _destroy_all();
      _free_mem(data_, cap_);
      data_ = o.data_;
      start_ = o.start_;
      size_ = o.size_;
      cap_ = o.cap_;
      // move
      alloc_ = static_cast<Allocator&&>(o.alloc_);
      o.data_ = nullptr;
      o.start_ = 0;
      o.size_ = 0;
      o.cap_ = 0;
    } else if (alloc_ == o.alloc_) {
      _destroy_all();
      _free_mem(data_, cap_);
      data_ = o.data_;
      start_ = o.start_;
      size_ = o.size_;
      cap_ = o.cap_;
      o.data_ = nullptr;
      o.start_ = 0;
      o.size_ = 0;
      o.cap_ = 0;
    } else {
      _destroy_all();
      if (o.size_ > cap_) {
        _free_mem(data_, cap_);
        data_ = o.size_ ? _alloc_mem(o.size_) : nullptr;
        cap_ = o.size_;
      }
      start_ = 0;
      for (size_type i = 0; i < o.size_; ++i) {
        // move
        _construct(data_ + i, static_cast<T&&>(o.data_[o.start_ + i]));
      }
      size_ = o.size_;
      o.clear();
    }
    return *this;
  }
  deque& operator=(initializer_list<T> il) {
    _destroy_all();
    if (il.size() > cap_) {
      _free_mem(data_, cap_);
      data_ = il.size() ? _alloc_mem(il.size()) : nullptr;
      cap_ = il.size();
    }
    start_ = 0;
    size_type i = 0;
    for (const T& v : il)
      _construct(data_ + i++, v);
    size_ = il.size();
    return *this;
  }

  allocator_type get_allocator() const noexcept { return alloc_; }

  void assign(size_type n, const T& v) {
    clear();
    if (n > cap_) {
      _free_mem(data_, cap_);
      data_ = _alloc_mem(n);
      cap_ = n;
    }
    start_ = 0;
    for (size_type i = 0; i < n; ++i)
      _construct(data_ + i, v);
    size_ = n;
  }
  template <typename It>
    requires(!is_integral_v<It>)
  void assign(It first, It last) {
    clear();
    for (; first != last; ++first)
      push_back(*first);
  }
  void assign(initializer_list<T> il) { assign(il.begin(), il.end()); }

  // Element access
  reference operator[](size_type i) noexcept { return data_[start_ + i]; }
  const_reference operator[](size_type i) const noexcept {
    return data_[start_ + i];
  }
  reference at(size_type i) {
    if (i >= size_)
      _PSYCHICSTD_THROW(out_of_range("deque::at"));
    return data_[start_ + i];
  }
  const_reference at(size_type i) const {
    if (i >= size_)
      _PSYCHICSTD_THROW(out_of_range("deque::at"));
    return data_[start_ + i];
  }
  reference front() noexcept { return data_[start_]; }
  const_reference front() const noexcept { return data_[start_]; }
  reference back() noexcept { return data_[start_ + size_ - 1]; }
  const_reference back() const noexcept { return data_[start_ + size_ - 1]; }

  // Iterators
  iterator begin() noexcept { return iterator{data_ + start_}; }
  iterator end() noexcept { return iterator{data_ + start_ + size_}; }
  const_iterator begin() const noexcept {
    return const_iterator{data_ + start_};
  }
  const_iterator end() const noexcept {
    return const_iterator{data_ + start_ + size_};
  }
  const_iterator cbegin() const noexcept { return begin(); }
  const_iterator cend() const noexcept { return end(); }
  reverse_iterator rbegin() noexcept { return reverse_iterator(end()); }
  reverse_iterator rend() noexcept { return reverse_iterator(begin()); }
  const_reverse_iterator rbegin() const noexcept {
    return const_reverse_iterator(end());
  }
  const_reverse_iterator rend() const noexcept {
    return const_reverse_iterator(begin());
  }

  // Capacity
  bool empty() const noexcept { return size_ == 0; }
  size_type size() const noexcept { return size_; }
  size_type max_size() const noexcept {
    const size_type ma = allocator_traits<Allocator>::max_size(alloc_);
    const size_type md = size_type(__PTRDIFF_MAX__) / sizeof(T);
    return ma < md ? ma : md;
  }
  void resize(size_type n) {
    if (n > size_) {
      _ensure_slack(0, n - size_);
      for (size_type i = size_; i < n; ++i)
        _construct(data_ + start_ + i);
      size_ = n;
    } else {
      for (size_type i = n; i < size_; ++i)
        _destroy(data_ + start_ + i);
      size_ = n;
    }
  }
  void resize(size_type n, const T& v) {
    if (n > size_) {
      _ensure_slack(0, n - size_);
      for (size_type i = size_; i < n; ++i)
        _construct(data_ + start_ + i, v);
      size_ = n;
    } else {
      for (size_type i = n; i < size_; ++i)
        _destroy(data_ + start_ + i);
      size_ = n;
    }
  }
  void shrink_to_fit() {
    if (size_ == 0) {
      _free_mem(data_, cap_);
      data_ = nullptr;
      start_ = 0;
      cap_ = 0;
      return;
    }
    if (cap_ > size_)
      _recenter(size_, 0);
  }

  // Modifiers
  void clear() noexcept {
    _destroy_all();
    size_ = 0;
  }

  void push_back(const T& v) {
    T tmp(v);
    _ensure_slack(0, 1);
    _construct(data_ + start_ + size_, _xfer(tmp));
    ++size_;
  }
  void push_back(T&& v) {
    // move
    T tmp(static_cast<T&&>(v));
    _ensure_slack(0, 1);
    // move
    _construct(data_ + start_ + size_, static_cast<T&&>(tmp));
    ++size_;
  }
  void push_front(const T& v) {
    T tmp(v);
    _ensure_slack(1, 0);
    _construct(data_ + start_ - 1, _xfer(tmp));
    --start_;
    ++size_;
  }
  void push_front(T&& v) {
    // move
    T tmp(static_cast<T&&>(v));
    _ensure_slack(1, 0);
    // move
    _construct(data_ + start_ - 1, static_cast<T&&>(tmp));
    --start_;
    ++size_;
  }
  void pop_back() noexcept {
    --size_;
    _destroy(data_ + start_ + size_);
  }
  void pop_front() noexcept {
    _destroy(data_ + start_);
    ++start_;
    --size_;
  }

  template <typename... Args> reference emplace_back(Args&&... args) {
    if (cap_ - start_ - size_ >= 1) {
      // forward
      _construct(data_ + start_ + size_, static_cast<Args&&>(args)...);
      return data_[start_ + size_++];
    }
    // Grow: construct the new element into the new buffer BEFORE touching
    // the old one, so args referencing an existing element (e.g.
    // d.emplace_back(d[0])) stay valid until construction completes.
    size_type need = size_ + 2;
    size_type nc = cap_ ? cap_ * 2 : 4;
    while (nc < need)
      nc *= 2;
    size_type new_start = (nc - size_) / 2;
    T* np = _alloc_mem(nc);
    // forward
    _construct(np + new_start + size_, static_cast<Args&&>(args)...);
    for (size_type i = 0; i < size_; ++i) {
      _construct(np + new_start + i, _xfer(data_[start_ + i]));
      _destroy(data_ + start_ + i);
    }
    _free_mem(data_, cap_);
    data_ = np;
    cap_ = nc;
    start_ = new_start;
    return data_[start_ + size_++];
  }
  template <typename... Args> reference emplace_front(Args&&... args) {
    if (start_ >= 1) {
      // forward
      _construct(data_ + start_ - 1, static_cast<Args&&>(args)...);
      --start_;
      ++size_;
      return data_[start_];
    }
    size_type need = size_ + 2;
    size_type nc = cap_ ? cap_ * 2 : 4;
    while (nc < need)
      nc *= 2;
    size_type new_start = (nc - size_) / 2;
    T* np = _alloc_mem(nc);
    // forward
    _construct(np + new_start - 1, static_cast<Args&&>(args)...);
    for (size_type i = 0; i < size_; ++i) {
      _construct(np + new_start + i, _xfer(data_[start_ + i]));
      _destroy(data_ + start_ + i);
    }
    _free_mem(data_, cap_);
    data_ = np;
    cap_ = nc;
    start_ = new_start - 1;
    ++size_;
    return data_[start_];
  }

  template <typename... Args>
  iterator emplace(const_iterator pos, Args&&... args) {
    size_type idx = pos.ptr_ - (data_ + start_);
    // args may alias an element of *this; build the value before the
    // gap-opening shift can move or destroy its storage.
    // forward
    T tmp(static_cast<Args&&>(args)...);
    _make_gap(idx, 1);
    // move
    _construct(data_ + start_ + idx, static_cast<T&&>(tmp));
    ++size_;
    return iterator{data_ + start_ + idx};
  }

  iterator insert(const_iterator pos, const T& v) {
    size_type idx = pos.ptr_ - (data_ + start_);
    T tmp(v);
    _make_gap(idx, 1);
    _construct(data_ + start_ + idx, _xfer(tmp));
    ++size_;
    return iterator{data_ + start_ + idx};
  }
  iterator insert(const_iterator pos, T&& v) {
    size_type idx = pos.ptr_ - (data_ + start_);
    // move
    T tmp(static_cast<T&&>(v));
    _make_gap(idx, 1);
    // move
    _construct(data_ + start_ + idx, static_cast<T&&>(tmp));
    ++size_;
    return iterator{data_ + start_ + idx};
  }
  iterator insert(const_iterator pos, size_type n, const T& v) {
    size_type idx = pos.ptr_ - (data_ + start_);
    if (n == 0)
      return iterator{data_ + start_ + idx};
    // v may alias an element of *this; copy it before the gap-opening shift
    // can move or destroy its storage.
    T tmp(v);
    _make_gap(idx, n);
    for (size_type i = 0; i < n; ++i)
      _construct(data_ + start_ + idx + i, tmp);
    size_ += n;
    return iterator{data_ + start_ + idx};
  }
  iterator insert(const_iterator pos, initializer_list<T> il) {
    return insert(pos, il.begin(), il.end());
  }
  template <typename It>
    requires(!is_integral_v<It>)
  iterator insert(const_iterator pos, It first, It last) {
    size_type idx = pos.ptr_ - (data_ + start_);
    if constexpr (!is_base_of_v<
                      forward_iterator_tag,
                      typename iterator_traits<It>::iterator_category>) {
      // Single-pass iterators can't be traversed twice; buffer first.
      deque<T> tmp;
      for (; first != last; ++first)
        tmp.push_back(*first);
      return insert(const_iterator{data_ + start_ + idx}, tmp.begin(),
                    tmp.end());
    }
    size_type n = 0;
    for (auto it = first; it != last; ++it)
      ++n;
    if (n == 0)
      return iterator{data_ + start_ + idx};
    _make_gap(idx, n);
    size_type i = 0;
    for (auto it = first; it != last; ++it)
      _construct(data_ + start_ + idx + (i++), *it);
    size_ += n;
    return iterator{data_ + start_ + idx};
  }

  iterator erase(const_iterator pos) {
    size_type idx = pos.ptr_ - (data_ + start_);
    _make_erase_gap(idx, 1);
    --size_;
    return iterator{data_ + start_ + idx};
  }
  iterator erase(const_iterator first, const_iterator last) {
    size_type idx = first.ptr_ - (data_ + start_);
    size_type n = last - first;
    if (n == 0)
      return iterator{data_ + start_ + idx};
    _make_erase_gap(idx, n);
    size_ -= n;
    return iterator{data_ + start_ + idx};
  }

  void swap(deque& o) noexcept {
    T* td = data_;
    size_type ts = start_, tz = size_, tc = cap_;
    data_ = o.data_;
    start_ = o.start_;
    size_ = o.size_;
    cap_ = o.cap_;
    o.data_ = td;
    o.start_ = ts;
    o.size_ = tz;
    o.cap_ = tc;
    if constexpr (allocator_traits<
                      Allocator>::propagate_on_container_swap::value) {
      // move
      Allocator ta = static_cast<Allocator&&>(alloc_);
      // move
      alloc_ = static_cast<Allocator&&>(o.alloc_);
      // move
      o.alloc_ = static_cast<Allocator&&>(ta);
    }
  }
};

template <typename T, typename A>
void swap(deque<T, A>& a, deque<T, A>& b) noexcept {
  a.swap(b);
}

template <typename T, typename A>
bool operator==(const deque<T, A>& a, const deque<T, A>& b) {
  if (a.size() != b.size())
    return false;
  for (size_t i = 0; i < a.size(); ++i)
    if (!(a[i] == b[i]))
      return false;
  return true;
}
template <typename T, typename A>
bool operator!=(const deque<T, A>& a, const deque<T, A>& b) {
  return !(a == b);
}
template <typename T, typename A>
bool operator<(const deque<T, A>& a, const deque<T, A>& b) {
  for (size_t i = 0; i < a.size() && i < b.size(); ++i) {
    if (a[i] < b[i])
      return true;
    if (b[i] < a[i])
      return false;
  }
  return a.size() < b.size();
}
template <typename T, typename A>
bool operator<=(const deque<T, A>& a, const deque<T, A>& b) {
  return !(b < a);
}
template <typename T, typename A>
bool operator>(const deque<T, A>& a, const deque<T, A>& b) {
  return b < a;
}
template <typename T, typename A>
bool operator>=(const deque<T, A>& a, const deque<T, A>& b) {
  return !(a < b);
}

template <typename T, typename A>
  requires(__contiguous_detail::__ntw<T> || __contiguous_detail::__stw<T>)
auto operator<=>(const deque<T, A>& a, const deque<T, A>& b)
    -> __contiguous_detail::__cmp_t<T> {
  using R = __contiguous_detail::__cmp_t<T>;
  size_t n = a.size() < b.size() ? a.size() : b.size();
  for (size_t i = 0; i < n; ++i) {
    R c = __contiguous_detail::__cmp(a[i], b[i]);
    if (c != 0)
      return c;
  }
  return static_cast<R>(a.size() <=> b.size());
}

// std::erase / std::erase_if (C++20)
template <typename T, typename A, typename U>
typename deque<T, A>::size_type erase(deque<T, A>& c, const U& value) {
  typename deque<T, A>::size_type n = 0;
  auto it = c.begin();
  while (it != c.end()) {
    if (*it == value) {
      it = c.erase(it);
      ++n;
    } else
      ++it;
  }
  return n;
}
template <typename T, typename A, typename Pred>
typename deque<T, A>::size_type erase_if(deque<T, A>& c, Pred pred) {
  typename deque<T, A>::size_type n = 0;
  auto it = c.begin();
  while (it != c.end()) {
    if (pred(*it)) {
      it = c.erase(it);
      ++n;
    } else
      ++it;
  }
  return n;
}

