#pragma once
#include <cstddef>
#include <initializer_list>
#include <memory>
#include <vector>

namespace std {

// deque implemented as a vector (no O(1) front insertion, but API-compatible)
template <typename T, typename Allocator = allocator<T>> class deque {
  vector<T, Allocator> data_;

public:
  using value_type = T;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using reference = T&;
  using const_reference = const T&;
  using pointer = T*;
  using const_pointer = const T*;
  using iterator = T*;
  using const_iterator = const T*;
  using reverse_iterator = std::reverse_iterator<iterator>;
  using const_reverse_iterator = std::reverse_iterator<const_iterator>;

  deque() = default;
  explicit deque(size_type n) : data_(n) {}
  deque(size_type n, const T& v) : data_(n, v) {}
  deque(initializer_list<T> il) : data_(il.begin(), il.end()) {}
  template <typename It> deque(It first, It last) : data_(first, last) {}
  deque(const deque&) = default;
  deque(deque&&) noexcept = default;
  deque& operator=(const deque&) = default;
  deque& operator=(deque&&) noexcept = default;

  // Element access
  reference operator[](size_type i) noexcept { return data_[i]; }
  const_reference operator[](size_type i) const noexcept { return data_[i]; }
  reference at(size_type i) { return data_.at(i); }
  const_reference at(size_type i) const { return data_.at(i); }
  reference front() { return data_.front(); }
  const_reference front() const { return data_.front(); }
  reference back() { return data_.back(); }
  const_reference back() const { return data_.back(); }

  // Iterators
  iterator begin() noexcept { return data_.data(); }
  iterator end() noexcept { return data_.data() + data_.size(); }
  const_iterator begin() const noexcept { return data_.data(); }
  const_iterator end() const noexcept { return data_.data() + data_.size(); }
  const_iterator cbegin() const noexcept { return begin(); }
  const_iterator cend() const noexcept { return end(); }
  reverse_iterator rbegin() noexcept { return reverse_iterator(end()); }
  reverse_iterator rend() noexcept { return reverse_iterator(begin()); }
  const_reverse_iterator rbegin() const noexcept {
    return const_reverse_iterator(end());
  }
  const_reverse_iterator rend() const noexcept {
    return const_reverse_iterator(begin());
  }

  // Capacity
  bool empty() const noexcept { return data_.empty(); }
  size_type size() const noexcept { return data_.size(); }
  size_type max_size() const noexcept { return data_.max_size(); }
  void resize(size_type n) { data_.resize(n); }
  void resize(size_type n, const T& v) { data_.resize(n, v); }
  void shrink_to_fit() { data_.shrink_to_fit(); }

  // Modifiers
  void clear() noexcept { data_.clear(); }
  void push_back(const T& v) { data_.push_back(v); }
  void push_back(T&& v) { data_.push_back(static_cast<T&&>(v)); }
  void push_front(const T& v) { data_.insert(data_.begin(), v); }
  void push_front(T&& v) { data_.insert(data_.begin(), static_cast<T&&>(v)); }
  void pop_back() { data_.pop_back(); }
  void pop_front() { data_.erase(data_.begin()); }
  template <typename... Args> reference emplace_back(Args&&... args) {
    return data_.emplace_back(static_cast<Args&&>(args)...);
  }
  template <typename... Args> reference emplace_front(Args&&... args) {
    data_.emplace(data_.begin(), static_cast<Args&&>(args)...);
    return data_.front();
  }
  iterator insert(const_iterator pos, const T& v) {
    ptrdiff_t idx = pos - data_.data();
    data_.insert(data_.begin() + idx, v);
    return data_.data() + idx;
  }
  iterator insert(const_iterator pos, T&& v) {
    ptrdiff_t idx = pos - data_.data();
    data_.insert(data_.begin() + idx, static_cast<T&&>(v));
    return data_.data() + idx;
  }
  iterator insert(const_iterator pos, size_type n, const T& v) {
    ptrdiff_t idx = pos - data_.data();
    data_.insert(data_.begin() + idx, n, v);
    return data_.data() + idx;
  }
  template <typename It>
  iterator insert(const_iterator pos, It first, It last) {
    ptrdiff_t idx = pos - data_.data();
    data_.insert(data_.begin() + idx, first, last);
    return data_.data() + idx;
  }
  iterator erase(const_iterator pos) {
    ptrdiff_t idx = pos - data_.data();
    data_.erase(data_.begin() + idx);
    return data_.data() + idx;
  }
  iterator erase(const_iterator first, const_iterator last) {
    ptrdiff_t f = first - data_.data();
    ptrdiff_t l = last - data_.data();
    data_.erase(data_.begin() + f, data_.begin() + l);
    return data_.data() + f;
  }
  void swap(deque& o) noexcept { data_.swap(o.data_); }
};

} // namespace std
