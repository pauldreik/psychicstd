#pragma once
#include <__psychicstd_char_traits>
#include <__psychicstd_config>
#include <cerrno>
#include <cstddef>
#include <iosfwd>
#include <locale>
#include <system_error>

namespace std {

class ios_base {
public:
  class Init {
  public:
    Init() = default;
    ~Init() = default;
  };

  class failure : public system_error {
  public:
    explicit failure(const string& message);
    explicit failure(const char* message);
    failure(const string& message, const error_code& code);
    failure(const char* message, const error_code& code);
  };

  using fmtflags = unsigned;
  using iostate = unsigned;
  using openmode = unsigned;
  using seekdir = int;

  static constexpr fmtflags dec = 1 << 0;
  static constexpr fmtflags oct = 1 << 1;
  static constexpr fmtflags hex = 1 << 2;
  static constexpr fmtflags left = 1 << 3;
  static constexpr fmtflags right = 1 << 4;
  static constexpr fmtflags internal = 1 << 5;
  static constexpr fmtflags fixed = 1 << 6;
  static constexpr fmtflags scientific = 1 << 7;
  static constexpr fmtflags boolalpha = 1 << 8;
  static constexpr fmtflags showbase = 1 << 9;
  static constexpr fmtflags showpoint = 1 << 10;
  static constexpr fmtflags showpos = 1 << 11;
  static constexpr fmtflags skipws = 1 << 12;
  static constexpr fmtflags uppercase = 1 << 13;
  static constexpr fmtflags adjustfield = left | right | internal;
  static constexpr fmtflags basefield = dec | oct | hex;
  static constexpr fmtflags floatfield = fixed | scientific;

  static constexpr iostate goodbit = 0;
  static constexpr iostate badbit = 1;
  static constexpr iostate failbit = 2;
  static constexpr iostate eofbit = 4;

  static constexpr openmode in = 1;
  static constexpr openmode out = 2;
  static constexpr openmode app = 4;
  static constexpr openmode ate = 8;
  static constexpr openmode trunc = 16;
  static constexpr openmode binary = 32;

  static constexpr seekdir beg = 0;
  static constexpr seekdir cur = 1;
  static constexpr seekdir end = 2;

  fmtflags flags() const noexcept { return flags_; }
  fmtflags flags(fmtflags f) {
    fmtflags old = flags_;
    flags_ = f;
    return old;
  }
  fmtflags setf(fmtflags f) {
    fmtflags old = flags_;
    flags_ |= f;
    return old;
  }
  fmtflags setf(fmtflags f, fmtflags mask) {
    fmtflags old = flags_;
    flags_ = (flags_ & ~mask) | f;
    return old;
  }
  void unsetf(fmtflags f) { flags_ &= ~f; }

  streamsize width() const noexcept { return width_; }
  streamsize width(streamsize w) {
    streamsize old = width_;
    width_ = w;
    return old;
  }
  streamsize precision() const noexcept { return prec_; }
  streamsize precision(streamsize p) {
    streamsize old = prec_;
    prec_ = p;
    return old;
  }
  char fill() const noexcept { return fill_; }
  char fill(char c) {
    char old = fill_;
    fill_ = c;
    return old;
  }

  iostate rdstate() const noexcept { return state_; }
  bool good() const noexcept { return state_ == goodbit; }
  bool eof() const noexcept { return state_ & eofbit; }
  bool fail() const noexcept { return state_ & (failbit | badbit); }
  bool bad() const noexcept { return state_ & badbit; }
  explicit operator bool() const noexcept { return !fail(); }
  bool operator!() const noexcept { return fail(); }
  void clear(iostate s = goodbit) {
    state_ = s;
    if (state_ & except_)
      _throw_failure();
  }
  void setstate(iostate s) { clear(state_ | s); }
  iostate exceptions() const noexcept { return except_; }
  void exceptions(iostate mask) {
    except_ = mask;
    clear(state_);
  }

  locale getloc() const { return loc_; }
  locale imbue(const locale& loc) {
    locale old = loc_;
    loc_ = loc;
    return old;
  }

protected:
  [[noreturn, gnu::cold, gnu::noinline]] static void _throw_failure() {
#if defined(__cpp_exceptions)
    _throw_failure_with_exceptions();
#else
    __builtin_abort();
#endif
  }

  [[noreturn, gnu::cold]] static void _throw_failure_with_exceptions();

  ios_base()
      : flags_(dec | skipws), width_(0), prec_(6), state_(goodbit), fill_(' ') {
  }
  virtual ~ios_base() = default;
  ios_base(const ios_base&) = delete;
  ios_base& operator=(const ios_base&) = delete;

  fmtflags flags_;
  streamsize width_;
  streamsize prec_;
  iostate state_;
  iostate except_ = goodbit;
  char fill_;
  locale loc_;
};

template <typename Char, typename Traits> class basic_ios : public ios_base {
public:
  explicit basic_ios(basic_streambuf<Char, Traits>* sb) : buf_(sb) {}
  using char_type = Char;
  using traits_type = Traits;
  using int_type = typename Traits::int_type;
  using off_type = typename Traits::off_type;
  using pos_type = typename Traits::pos_type;

  // Re-define ios_base methods explicitly so that 'using basic_ios::foo' in
  // derived multiple-inheritance classes (e.g. basic_stringstream) resolves
  // unambiguously to this class rather than requiring a D*→ios_base* cast.
  fmtflags flags() const noexcept { return ios_base::flags(); }
  fmtflags flags(fmtflags f) { return ios_base::flags(f); }
  fmtflags setf(fmtflags f) { return ios_base::setf(f); }
  fmtflags setf(fmtflags f, fmtflags mask) { return ios_base::setf(f, mask); }
  void unsetf(fmtflags f) { ios_base::unsetf(f); }
  streamsize width() const noexcept { return ios_base::width(); }
  streamsize width(streamsize w) { return ios_base::width(w); }
  streamsize precision() const noexcept { return ios_base::precision(); }
  streamsize precision(streamsize p) { return ios_base::precision(p); }
  char fill() const noexcept { return ios_base::fill(); }
  char fill(char c) { return ios_base::fill(c); }
  iostate rdstate() const noexcept { return ios_base::rdstate(); }
  bool good() const noexcept { return ios_base::good(); }
  bool eof() const noexcept { return ios_base::eof(); }
  bool fail() const noexcept { return ios_base::fail(); }
  bool bad() const noexcept { return ios_base::bad(); }
  explicit operator bool() const noexcept { return ios_base::operator bool(); }
  bool operator!() const noexcept { return ios_base::operator!(); }
  void clear(iostate s = goodbit) { ios_base::clear(s); }
  void setstate(iostate s) { ios_base::setstate(s); }
  iostate exceptions() const noexcept { return ios_base::exceptions(); }
  void exceptions(iostate mask) { ios_base::exceptions(mask); }
  locale getloc() const { return ios_base::getloc(); }
  locale imbue(const locale& loc) { return ios_base::imbue(loc); }

  basic_streambuf<Char, Traits>* rdbuf() const noexcept { return buf_; }
  basic_streambuf<Char, Traits>* rdbuf(basic_streambuf<Char, Traits>* sb) {
    auto* old = buf_;
    // Replacing a buffer starts a new input sequence.
    init(sb);
    return old;
  }

  // Copy formatting state from another stream
  basic_ios& copyfmt(const basic_ios& rhs) {
    if (this != &rhs) {
      flags_ = rhs.flags_;
      width_ = rhs.width_;
      prec_ = rhs.prec_;
      fill_ = rhs.fill_;
    }
    return *this;
  }

protected:
  basic_ios() : buf_(nullptr) {}
  void init(basic_streambuf<Char, Traits>* sb) {
    buf_ = sb;
    state_ = sb ? goodbit : badbit;
  }

  basic_streambuf<Char, Traits>* buf_;
};

} // namespace std
