  {
    return __atomic_xor_fetch(ptr_, value, __ATOMIC_SEQ_CST);
  }
  void wait(T old, memory_order order = memory_order_seq_cst) const noexcept {
    __atomic_detail::wait(ptr_, old, order);
  }
  void notify_one() const noexcept { __atomic_detail::notify(ptr_, 1); }
  void notify_all() const noexcept {
    __atomic_detail::notify(ptr_, 0x7fffffff);
  }
};

