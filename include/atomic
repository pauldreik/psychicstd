template <typename T> struct atomic {
  static_assert(is_trivially_copyable_v<T>);
  using value_type = T;
  using difference_type = conditional_t<is_pointer_v<T>, ptrdiff_t, T>;
  static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(T), nullptr);
  static constexpr size_t required_alignment =
      sizeof(T) == 1 || sizeof(T) == 2 || sizeof(T) == 4 || sizeof(T) == 8 ||
              sizeof(T) == 16
          ? sizeof(T)
          : alignof(T);

  alignas(required_alignment) T val_{};

  constexpr atomic() = default;
  constexpr atomic(T v) noexcept : val_(v) {}
  atomic(const atomic&) = delete;
  atomic& operator=(const atomic&) = delete;
  atomic& operator=(const atomic&) volatile = delete;

  T load(memory_order order = memory_order_seq_cst) const noexcept {
    T result;
    __atomic_load(&val_, &result, int(order));
    return result;
  }
  T load(memory_order order = memory_order_seq_cst) const volatile noexcept {
    T result;
    __atomic_load(&val_, &result, int(order));
    return result;
  }
  void store(T v, memory_order order = memory_order_seq_cst) noexcept {
    __atomic_store(&val_, &v, int(order));
  }
  void store(T v, memory_order order = memory_order_seq_cst) volatile noexcept {
    __atomic_store(&val_, &v, int(order));
  }
  bool is_lock_free() const noexcept { return is_always_lock_free; }
  bool is_lock_free() const volatile noexcept { return is_always_lock_free; }

  T fetch_add(difference_type arg,
              memory_order order = memory_order_seq_cst) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    if constexpr (is_floating_point_v<T>) {
      T expected = load(memory_order_relaxed);
      while (!compare_exchange_weak(expected, expected + arg, order,
                                    memory_order_relaxed)) {
      }
      return expected;
    } else if constexpr (is_pointer_v<T>) {
      return __atomic_fetch_add(&val_, arg * sizeof(remove_pointer_t<T>),
                                int(order));
    } else {
      return __atomic_fetch_add(&val_, arg, int(order));
    }
  }
  T fetch_add(difference_type arg,
              memory_order order = memory_order_seq_cst) volatile noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    if constexpr (is_floating_point_v<T>) {
      T expected = load(memory_order_relaxed);
      while (!compare_exchange_weak(expected, expected + arg, order,
                                    memory_order_relaxed)) {
      }
      return expected;
    } else if constexpr (is_pointer_v<T>) {
      return __atomic_fetch_add(&val_, arg * sizeof(remove_pointer_t<T>),
                                int(order));
    } else {
      return __atomic_fetch_add(&val_, arg, int(order));
    }
  }
  T fetch_sub(difference_type arg,
              memory_order order = memory_order_seq_cst) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_add(-arg, order);
  }
  T fetch_sub(difference_type arg,
              memory_order order = memory_order_seq_cst) volatile noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_add(-arg, order);
  }
  T fetch_and(T arg, memory_order order = memory_order_seq_cst) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_and(&val_, arg, int(order));
  }
  T fetch_and(T arg,
              memory_order order = memory_order_seq_cst) volatile noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_and(&val_, arg, int(order));
  }
  T fetch_or(T arg, memory_order order = memory_order_seq_cst) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_or(&val_, arg, int(order));
  }
  T fetch_or(T arg, memory_order order = memory_order_seq_cst) volatile noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_or(&val_, arg, int(order));
  }
  T fetch_xor(T arg, memory_order order = memory_order_seq_cst) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_xor(&val_, arg, int(order));
  }
  T fetch_xor(T arg,
              memory_order order = memory_order_seq_cst) volatile noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_xor(&val_, arg, int(order));
  }
  T exchange(T desired, memory_order order = memory_order_seq_cst) noexcept {
    T result;
    __atomic_exchange(&val_, &desired, &result, int(order));
    return result;
  }
  T exchange(T desired,
             memory_order order = memory_order_seq_cst) volatile noexcept {
    T result;
    __atomic_exchange(&val_, &desired, &result, int(order));
    return result;
  }
  bool
  compare_exchange_weak(T& expected, T desired,
                        memory_order success = memory_order_seq_cst,
                        memory_order failure = memory_order_seq_cst) noexcept {
    return __atomic_compare_exchange(&val_, &expected, &desired, true,
                                     int(success), int(failure));
  }
  bool compare_exchange_weak(
      T& expected, T desired, memory_order success = memory_order_seq_cst,
      memory_order failure = memory_order_seq_cst) volatile noexcept {
    return __atomic_compare_exchange(&val_, &expected, &desired, true,
                                     int(success), int(failure));
  }
  bool compare_exchange_strong(
      T& expected, T desired, memory_order success = memory_order_seq_cst,
      memory_order failure = memory_order_seq_cst) noexcept {
    return __atomic_compare_exchange(&val_, &expected, &desired, false,
                                     int(success), int(failure));
  }
  bool compare_exchange_strong(
      T& expected, T desired, memory_order success = memory_order_seq_cst,
      memory_order failure = memory_order_seq_cst) volatile noexcept {
    return __atomic_compare_exchange(&val_, &expected, &desired, false,
                                     int(success), int(failure));
  }

  operator T() const noexcept { return load(); }
  operator T() const volatile noexcept { return load(); }
  T operator=(T v) noexcept {
    store(v);
    return v;
  }
  T operator=(T v) volatile noexcept {
    store(v);
    return v;
  }

  T operator++() noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_add(difference_type(1)) + difference_type(1);
  }
  T operator++(int) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_add(difference_type(1));
  }
  T operator--() noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_sub(difference_type(1)) - difference_type(1);
  }
  T operator--(int) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_sub(difference_type(1));
  }
  T operator+=(difference_type v) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_add(v) + v;
  }
  T operator-=(difference_type v) noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_sub(v) - v;
  }
  T operator&=(T v) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_and_fetch(&val_, v, __ATOMIC_SEQ_CST);
  }
  T operator|=(T v) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_or_fetch(&val_, v, __ATOMIC_SEQ_CST);
  }
  T operator^=(T v) noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_xor_fetch(&val_, v, __ATOMIC_SEQ_CST);
  }
  void wait(T old, memory_order order = memory_order_seq_cst) const noexcept {
    __atomic_detail::wait(&val_, old, order);
  }
  void wait(T old, memory_order order = memory_order_seq_cst) const
      volatile noexcept {
    __atomic_detail::wait(&val_, old, order);
  }
  void notify_one() noexcept { __atomic_detail::notify(&val_, 1); }
  void notify_one() volatile noexcept { __atomic_detail::notify(&val_, 1); }
  void notify_all() noexcept { __atomic_detail::notify(&val_, 0x7fffffff); }
  void notify_all() volatile noexcept {
    __atomic_detail::notify(&val_, 0x7fffffff);
  }
};

template <typename T> class atomic_ref {
  static_assert(is_trivially_copyable_v<T>);
  T* ptr_;

public:
  using value_type = T;
  using difference_type = conditional_t<is_pointer_v<T>, ptrdiff_t, T>;
  static constexpr size_t required_alignment =
      sizeof(T) == 1 || sizeof(T) == 2 || sizeof(T) == 4 || sizeof(T) == 8 ||
              sizeof(T) == 16
          ? sizeof(T)
          : alignof(T);
  static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(T), nullptr);

  explicit atomic_ref(T& value) noexcept : ptr_(&value) {}
  atomic_ref(const atomic_ref&) noexcept = default;
  atomic_ref& operator=(const atomic_ref&) = delete;

  bool is_lock_free() const noexcept { return is_always_lock_free; }
  T load(memory_order order = memory_order_seq_cst) const noexcept {
    T result;
    __atomic_load(ptr_, &result, int(order));
    return result;
  }
  void store(T value,
             memory_order order = memory_order_seq_cst) const noexcept {
    __atomic_store(ptr_, &value, int(order));
  }
  T exchange(T value,
             memory_order order = memory_order_seq_cst) const noexcept {
    T result;
    __atomic_exchange(ptr_, &value, &result, int(order));
    return result;
  }
  bool compare_exchange_weak(
      T& expected, T desired, memory_order success = memory_order_seq_cst,
      memory_order failure = memory_order_seq_cst) const noexcept {
    return __atomic_compare_exchange(ptr_, &expected, &desired, true,
                                     int(success), int(failure));
  }
  bool compare_exchange_strong(
      T& expected, T desired, memory_order success = memory_order_seq_cst,
      memory_order failure = memory_order_seq_cst) const noexcept {
    return __atomic_compare_exchange(ptr_, &expected, &desired, false,
                                     int(success), int(failure));
  }
  T fetch_add(difference_type value,
              memory_order order = memory_order_seq_cst) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    if constexpr (is_floating_point_v<T>) {
      T expected = load(memory_order_relaxed);
      while (!compare_exchange_weak(expected, expected + value, order,
                                    memory_order_relaxed)) {
      }
      return expected;
    } else if constexpr (is_pointer_v<T>) {
      return __atomic_fetch_add(ptr_, value * sizeof(remove_pointer_t<T>),
                                int(order));
    } else {
      return __atomic_fetch_add(ptr_, value, int(order));
    }
  }
  T fetch_sub(difference_type value,
              memory_order order = memory_order_seq_cst) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_add(-value, order);
  }
  T fetch_and(T value, memory_order order = memory_order_seq_cst) const noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_and(ptr_, value, int(order));
  }
  T fetch_or(T value, memory_order order = memory_order_seq_cst) const noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_or(ptr_, value, int(order));
  }
  T fetch_xor(T value, memory_order order = memory_order_seq_cst) const noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
  {
    return __atomic_fetch_xor(ptr_, value, int(order));
  }
  operator T() const noexcept { return load(); }
  T operator=(T value) const noexcept {
    store(value);
    return value;
  }
  T operator++() const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_add(difference_type(1)) + difference_type(1);
  }
  T operator++(int) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_add(difference_type(1));
  }
  T operator--() const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_sub(difference_type(1)) - difference_type(1);
  }
  T operator--(int) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T>)
  {
    return fetch_sub(difference_type(1));
  }
  T operator+=(difference_type value) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_add(value) + value;
  }
  T operator-=(difference_type value) const noexcept
    requires((is_integral_v<T> && !is_same_v<T, bool>) || is_pointer_v<T> ||
             is_floating_point_v<T>)
  {
    return fetch_sub(value) - value;
  }
  T operator&=(T value) const noexcept
    requires(is_integral_v<T> && !is_same_v<T, bool>)
