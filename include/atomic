#define _PSYCHICSTD_ATOMIC_FETCH(name)                                         \
  template <typename T>                                                        \
  T atomic_fetch_##name(atomic<T>* obj,                                        \
                        typename atomic<T>::difference_type value) noexcept {  \
    return obj->fetch_##name(value);                                           \
  }                                                                            \
  template <typename T>                                                        \
  T atomic_fetch_##name(volatile atomic<T>* obj,                               \
                        typename atomic<T>::difference_type value) noexcept {  \
    return obj->fetch_##name(value);                                           \
  }                                                                            \
  template <typename T>                                                        \
  T atomic_fetch_##name##_explicit(atomic<T>* obj,                             \
                                   typename atomic<T>::difference_type value,  \
                                   memory_order order) noexcept {              \
    return obj->fetch_##name(value, order);                                    \
  }                                                                            \
  template <typename T>                                                        \
  T atomic_fetch_##name##_explicit(volatile atomic<T>* obj,                    \
                                   typename atomic<T>::difference_type value,  \
                                   memory_order order) noexcept {              \
    return obj->fetch_##name(value, order);                                    \
  }

_PSYCHICSTD_ATOMIC_FETCH(add)
_PSYCHICSTD_ATOMIC_FETCH(sub)
_PSYCHICSTD_ATOMIC_FETCH(and)
_PSYCHICSTD_ATOMIC_FETCH(or)
_PSYCHICSTD_ATOMIC_FETCH(xor)
#undef _PSYCHICSTD_ATOMIC_FETCH

