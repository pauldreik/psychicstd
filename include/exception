#pragma once
#include <__psychicstd_exception_base>
#include <cstddef>
#include <typeinfo>

namespace std {

// The virtual destructors and what() are deliberately NOT defined inline:
// their out-of-line definitions live in the C++ ABI runtime (libsupc++ on
// GCC/Linux, libc++abi on macOS), so the vtable and typeinfo of each class
// come from the runtime as well. This is required for catch matching: the
// runtime throws these types itself (operator new -> bad_alloc, dynamic_cast
// -> bad_cast, ...) using ITS typeinfo, and on platforms where RTTI equality
// is pointer-based (Apple arm64) a header-local duplicate typeinfo would
// never match a runtime-thrown exception.
class bad_exception : public exception {
public:
  bad_exception() noexcept = default;
  ~bad_exception() noexcept override;
  const char* what() const noexcept override;
};

class bad_alloc : public exception {
public:
  bad_alloc() noexcept = default;
  ~bad_alloc() noexcept override;
  const char* what() const noexcept override;
};

class bad_array_new_length : public bad_alloc {
public:
  bad_array_new_length() noexcept = default;
  ~bad_array_new_length() noexcept override;
  const char* what() const noexcept override;
};

class bad_cast : public exception {
public:
  bad_cast() noexcept = default;
  ~bad_cast() noexcept override;
  const char* what() const noexcept override;
};

class bad_typeid : public exception {
public:
  bad_typeid() noexcept = default;
  ~bad_typeid() noexcept override;
  const char* what() const noexcept override;
};

[[noreturn]] void terminate() noexcept;

using terminate_handler = void (*)();
terminate_handler get_terminate() noexcept;
terminate_handler set_terminate(terminate_handler) noexcept;

#ifdef __APPLE__
// libc++abi exports only the __cxa_ entry point; the std:: wrappers live in
// libc++.dylib, which we do not link.
extern "C" unsigned int __cxa_uncaught_exceptions() noexcept;
inline bool uncaught_exception() noexcept {
  return __cxa_uncaught_exceptions() > 0;
}
inline int uncaught_exceptions() noexcept {
  return static_cast<int>(__cxa_uncaught_exceptions());
}
#else
// libsupc++ defines both.
bool uncaught_exception() noexcept;
int uncaught_exceptions() noexcept;
#endif

// Itanium ABI exception-handling globals — layout is ABI-stable across GCC.
namespace __cxxabiv1 {
struct __cxa_exception;
struct __cxa_eh_globals {
  __cxa_exception* caughtExceptions;
  unsigned int uncaughtExceptions;
};
extern "C" __cxa_eh_globals* __cxa_get_globals() noexcept;
extern "C" void* __cxa_get_exception_ptr(void*) noexcept;
extern "C" [[noreturn]] void __cxa_rethrow();
#ifdef __APPLE__
extern "C" void* __cxa_current_primary_exception() noexcept;
extern "C" void __cxa_increment_exception_refcount(void*) noexcept;
extern "C" void __cxa_decrement_exception_refcount(void*) noexcept;
extern "C" void __cxa_rethrow_primary_exception(void*);
#endif
} // namespace __cxxabiv1

// Keep the ABI name and layout used by libsupc++'s exception_ptr support.
// Its out-of-line operations maintain the exception's reference count and
// rethrow the saved primary exception correctly.
namespace __exception_ptr {
class exception_ptr;
}
__exception_ptr::exception_ptr current_exception() noexcept;
[[noreturn]] void rethrow_exception(__exception_ptr::exception_ptr);

namespace __exception_ptr {
class exception_ptr {
  void* ptr_ = nullptr;

#ifdef __APPLE__
  explicit exception_ptr(void* p) noexcept : ptr_(p) {}
#else
  explicit exception_ptr(void* p) noexcept;
  void _M_addref() noexcept;
  void _M_release() noexcept;
#endif
  friend exception_ptr std::current_exception() noexcept;
  friend void std::rethrow_exception(exception_ptr);

public:
#ifdef __APPLE__
  exception_ptr() noexcept = default;
  exception_ptr(nullptr_t) noexcept {}
  exception_ptr(const exception_ptr& other) noexcept : ptr_(other.ptr_) {
    if (ptr_)
      __cxxabiv1::__cxa_increment_exception_refcount(ptr_);
  }
  exception_ptr& operator=(const exception_ptr& other) noexcept {
    if (other.ptr_)
      __cxxabiv1::__cxa_increment_exception_refcount(other.ptr_);
    if (ptr_)
      __cxxabiv1::__cxa_decrement_exception_refcount(ptr_);
    ptr_ = other.ptr_;
    return *this;
  }
  ~exception_ptr() noexcept {
    if (ptr_)
      __cxxabiv1::__cxa_decrement_exception_refcount(ptr_);
  }
#else
  exception_ptr() noexcept;
  exception_ptr(nullptr_t) noexcept : ptr_(nullptr) {}
  exception_ptr(const exception_ptr&) noexcept;
  exception_ptr& operator=(const exception_ptr&) noexcept;
  ~exception_ptr() noexcept;
#endif
  explicit operator bool() const noexcept { return ptr_ != nullptr; }
  friend bool operator==(const exception_ptr& a,
                         const exception_ptr& b) noexcept {
    return a.ptr_ == b.ptr_;
  }
  friend bool operator!=(const exception_ptr& a,
                         const exception_ptr& b) noexcept {
    return !(a == b);
  }
};
} // namespace __exception_ptr

using __exception_ptr::exception_ptr;

#ifdef __APPLE__
inline exception_ptr current_exception() noexcept {
  return exception_ptr(__cxxabiv1::__cxa_current_primary_exception());
}

[[noreturn]] inline void rethrow_exception(exception_ptr p) {
  __cxxabiv1::__cxa_rethrow_primary_exception(p.ptr_);
  terminate();
}
#else
// The declarations above have libsupc++'s ABI names. Its implementations use
// the saved primary exception, unlike __cxa_rethrow(), which only works while
// handling the current exception.
#endif

template <typename E>
exception_ptr make_exception_ptr([[maybe_unused]] E e) noexcept {
  return exception_ptr{}; // stub
}

} // namespace std
