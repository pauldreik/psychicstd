#pragma once
#include <type_traits>
#include <utility>

namespace std {

// tuple_element / tuple_size — forward declarations
template <size_t I, typename T> struct tuple_element;
template <typename T> struct tuple_size;
template <size_t I, typename T>
using tuple_element_t = typename tuple_element<I, T>::type;

// --- tuple implementation using recursive inheritance ---

namespace detail {
template <size_t I, typename T> struct tuple_leaf {
  T value;
  tuple_leaf() = default;
  explicit tuple_leaf(const T& v) : value(v) {}
  explicit tuple_leaf(T&& v) : value(static_cast<T&&>(v)) {}
  template <typename U>
  explicit tuple_leaf(U&& v) : value(static_cast<U&&>(v)) {}
};
// Reference-type specialisation: value is a reference, so assign through it.
template <size_t I, typename T> struct tuple_leaf<I, T&> {
  T& value;
  explicit tuple_leaf(T& v) : value(v) {}
  tuple_leaf& operator=(const tuple_leaf& o) {
    value = o.value;
    return *this;
  }
  tuple_leaf& operator=(tuple_leaf&& o) {
    value = o.value;
    return *this;
  }
};

template <typename Indices, typename... Ts> struct tuple_impl;

template <size_t... Is, typename... Ts>
struct tuple_impl<index_sequence<Is...>, Ts...> : tuple_leaf<Is, Ts>... {
  tuple_impl() = default;
  template <typename... Us>
  explicit tuple_impl(Us&&... args)
      : tuple_leaf<Is, Ts>(static_cast<Us&&>(args))... {}
};
} // namespace detail

template <typename... Ts>
class tuple
    : public detail::tuple_impl<make_index_sequence<sizeof...(Ts)>, Ts...> {
  using base = detail::tuple_impl<make_index_sequence<sizeof...(Ts)>, Ts...>;

public:
  tuple() = default;
  tuple(const tuple&) = default;
  tuple(tuple&&) = default;
  tuple& operator=(const tuple&) = default;
  tuple& operator=(tuple&&) = default;

  // Assign from pair (for tuple<T&, U&> = pair<T, U> pattern used by tie)
  template <typename U1, typename U2>
    requires(sizeof...(Ts) == 2)
  tuple& operator=(const pair<U1, U2>& p) {
    get<0>(*this) = p.first;
    get<1>(*this) = p.second;
    return *this;
  }

  // Non-template constructor: allows {} to initialise individual element types.
  explicit(!(is_convertible_v<Ts, Ts> && ...)) tuple(Ts&&... args)
    requires(sizeof...(Ts) != 0)
      : base(static_cast<Ts&&>(args)...) {}

  // Excludes the sizeof...(Ts) == 1 case where the single argument is itself
  // a tuple, so it doesn't hijack the copy/move/converting constructors.
  template <typename... Us>
    requires(sizeof...(Us) == sizeof...(Ts) && sizeof...(Ts) != 0 &&
             !(sizeof...(Us) == 1 && (is_same_v<remove_cvref_t<Us>, tuple> ||
                                      ...)))
  explicit(!(is_convertible_v<Us, Ts> && ...)) tuple(Us&&... args)
      : base(static_cast<Us&&>(args)...) {}

  template <typename... Us, size_t... Is>
  tuple(const tuple<Us...>& other, index_sequence<Is...>)
      : base(static_cast<const Us&>(
            static_cast<const detail::tuple_leaf<Is, Us>&>(other).value)...) {}
  template <typename... Us>
    requires(sizeof...(Us) == sizeof...(Ts) &&
             (is_constructible_v<Ts, const Us&> && ...))
  tuple(const tuple<Us...>& other)
      : tuple(other, make_index_sequence<sizeof...(Ts)>{}) {}

  // Heterogeneous assignment — needed for std::tie(a,b) = tuple<Us...>{...}
  // where Ts are reference types and Us are value types.
  template <typename... Us>
    requires(sizeof...(Us) == sizeof...(Ts))
  tuple& operator=(const tuple<Us...>& other) {
    [&]<size_t... Is>(index_sequence<Is...>) {
      ((get<Is>(*this) = get<Is>(other)), ...);
    }(make_index_sequence<sizeof...(Ts)>{});
    return *this;
  }
};

template <> class tuple<> {};

// tuple_size
template <typename... Ts>
struct tuple_size<tuple<Ts...>> : integral_constant<size_t, sizeof...(Ts)> {};
template <typename T> struct tuple_size<const T> : tuple_size<T> {};
template <typename T>
inline constexpr size_t tuple_size_v = tuple_size<T>::value;

// tuple_element
namespace detail {
#if __has_builtin(__type_pack_element)
template <size_t I, typename... Ts> struct type_at {
  using type = __type_pack_element<I, Ts...>;
};
#else
template <size_t I, typename Head, typename... Tail> struct type_at {
  using type = typename type_at<I - 1, Tail...>::type;
};
template <typename Head, typename... Tail> struct type_at<0, Head, Tail...> {
  using type = Head;
};
#endif
} // namespace detail

template <size_t I, typename... Ts> struct tuple_element<I, tuple<Ts...>> {
  using type = typename detail::type_at<I, Ts...>::type;
};
template <size_t I, typename T> struct tuple_element<I, const T> {
  using type = const typename tuple_element<I, T>::type;
};

// get<I>(tuple)
template <size_t I, typename... Ts>
constexpr tuple_element_t<I, tuple<Ts...>>& get(tuple<Ts...>& t) noexcept {
  using Leaf = detail::tuple_leaf<I, tuple_element_t<I, tuple<Ts...>>>;
  return static_cast<Leaf&>(t).value;
}
template <size_t I, typename... Ts>
constexpr const tuple_element_t<I, tuple<Ts...>>&
get(const tuple<Ts...>& t) noexcept {
  using Leaf = detail::tuple_leaf<I, tuple_element_t<I, tuple<Ts...>>>;
  return static_cast<const Leaf&>(t).value;
}
template <size_t I, typename... Ts>
constexpr tuple_element_t<I, tuple<Ts...>>&& get(tuple<Ts...>&& t) noexcept {
  using Leaf = detail::tuple_leaf<I, tuple_element_t<I, tuple<Ts...>>>;
  return static_cast<tuple_element_t<I, tuple<Ts...>>&&>(
      static_cast<Leaf&>(t).value);
}

// get<T>(tuple)
template <typename T, typename... Ts>
constexpr T& get(tuple<Ts...>& t) noexcept {
  constexpr std::size_t I = []() -> std::size_t {
    std::size_t i = 0;
    std::size_t ret; // uninit on purpose
    auto count = 0;
    for (auto& d : {std::is_same_v<T, Ts>...}) {
      if (d) {
        ret = i;
        ++count;
      }
      ++i;
    };
    if (count == 0) {
      // not found
      return -1;
    }
    if (count == 1) {
      return ret;
    }
    return -2;
  }();
  static_assert(I != -1, "type not found in tuple");
  static_assert(I != -2, "type must occur only once in tuple");
  return get<I>(t);
}
template <typename T, typename... Ts>
constexpr const T& get(const tuple<Ts...>& t) noexcept {
  constexpr std::size_t I = []() -> std::size_t {
    std::size_t i = 0;
    std::size_t ret; // uninit on purpose
    auto count = 0;
    for (auto& d : {std::is_same_v<T, Ts>...}) {
      if (d) {
        ret = i;
        ++count;
      }
      ++i;
    };
    if (count == 0) {
      // not found
      return -1;
    }
    if (count == 1) {
      return ret;
    }
    return -2;
  }();
  static_assert(I != -1, "type not found in tuple");
  static_assert(I != -2, "type must occur only once in tuple");
  return get<I>(t);
}

// Comparison operators
namespace detail {
template <size_t I, typename Tup>
constexpr bool tuple_lt(const Tup& a, const Tup& b) {
  if constexpr (I == tuple_size_v<Tup>)
    return false;
  else if (get<I>(a) < get<I>(b))
    return true;
  else if (get<I>(b) < get<I>(a))
    return false;
  else
    return tuple_lt<I + 1>(a, b);
}
} // namespace detail

template <typename... Ts>
constexpr bool operator==(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return [&]<size_t... Is>(index_sequence<Is...>) {
    return ((get<Is>(a) == get<Is>(b)) && ...);
  }(make_index_sequence<sizeof...(Ts)>{});
}
template <typename... Ts>
constexpr bool operator!=(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return !(a == b);
}
template <typename... Ts>
constexpr bool operator<(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return detail::tuple_lt<0>(a, b);
}
template <typename... Ts>
constexpr bool operator<=(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return !(b < a);
}
template <typename... Ts>
constexpr bool operator>(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return b < a;
}
template <typename... Ts>
constexpr bool operator>=(const tuple<Ts...>& a, const tuple<Ts...>& b) {
  return !(a < b);
}

// make_tuple
template <typename... Ts>
constexpr tuple<decay_t<Ts>...> make_tuple(Ts&&... args) {
  return tuple<decay_t<Ts>...>(static_cast<Ts&&>(args)...);
}

// forward_as_tuple
template <typename... Ts>
constexpr tuple<Ts&&...> forward_as_tuple(Ts&&... args) noexcept {
  return tuple<Ts&&...>(static_cast<Ts&&>(args)...);
}

// tie
template <typename... Ts> constexpr tuple<Ts&...> tie(Ts&... args) noexcept {
  return tuple<Ts&...>(args...);
}

// ignore
struct _ignore_t {
  template <typename T> const _ignore_t& operator=(const T&) const {
    return *this;
  }
};
inline constexpr _ignore_t ignore{};

// tuple_cat (two tuples — simple version)
template <typename... Ts, typename... Us>
constexpr tuple<Ts..., Us...> tuple_cat(tuple<Ts...> a, tuple<Us...> b) {
  // use index sequences to unpack
  return [&]<size_t... Is, size_t... Js>(index_sequence<Is...>,
                                         index_sequence<Js...>) {
    return tuple<Ts..., Us...>(get<Is>(static_cast<tuple<Ts...>&&>(a))...,
                               get<Js>(static_cast<tuple<Us...>&&>(b))...);
  }(make_index_sequence<sizeof...(Ts)>{}, make_index_sequence<sizeof...(Us)>{});
}

// apply (C++17)
template <typename F, typename Tuple>
constexpr decltype(auto) apply(F&& f, Tuple&& t) {
  return [&]<size_t... Is>(index_sequence<Is...>) -> decltype(auto) {
    return static_cast<F&&>(f)(get<Is>(static_cast<Tuple&&>(t))...);
  }(make_index_sequence<tuple_size_v<remove_reference_t<Tuple>>>{});
}

// pair tuple_element / tuple_size (for structured bindings)
template <typename T1, typename T2>
struct tuple_size<pair<T1, T2>> : integral_constant<size_t, 2> {};
template <typename T1, typename T2> struct tuple_element<0, pair<T1, T2>> {
  using type = T1;
};
template <typename T1, typename T2> struct tuple_element<1, pair<T1, T2>> {
  using type = T2;
};
template <size_t I, typename T1, typename T2>
constexpr decltype(auto) get(pair<T1, T2>& p) noexcept {
  if constexpr (I == 0)
    return (p.first);
  else
    return (p.second);
}
template <size_t I, typename T1, typename T2>
constexpr decltype(auto) get(const pair<T1, T2>& p) noexcept {
  if constexpr (I == 0)
    return (p.first);
  else
    return (p.second);
}
template <size_t I, typename T1, typename T2>
constexpr decltype(auto) get(pair<T1, T2>&& p) noexcept {
  if constexpr (I == 0)
    return static_cast<T1&&>(p.first);
  else
    return static_cast<T2&&>(p.second);
}

} // namespace std
