#pragma once
#include <__psychicstd_config>
#include <__psychicstd_except>
#include <regex.h>
#include <string>
#include <vector>

namespace std {

class regex {
public:
  using flag_type = int;
  static constexpr flag_type ECMAScript = 0;
  static constexpr flag_type icase = REG_ICASE;
  static constexpr flag_type extended = REG_EXTENDED;

  regex() : valid_(false) {}

  explicit regex(const string& pattern, flag_type flags = ECMAScript) {
    int rf = REG_EXTENDED;
    if (flags & icase)
      rf |= REG_ICASE;
    if (::regcomp(&re_, pattern.c_str(), rf) != 0)
      _PSYCHICSTD_THROW(runtime_error("regex: bad pattern"));
    valid_ = true;
  }
  explicit regex(const char* pattern, flag_type flags = ECMAScript) {
    int rf = REG_EXTENDED;
    if (flags & icase)
      rf |= REG_ICASE;
    if (::regcomp(&re_, pattern, rf) != 0)
      _PSYCHICSTD_THROW(runtime_error("regex: bad pattern"));
    valid_ = true;
  }

  ~regex() {
    if (valid_)
      ::regfree(&re_);
  }

  regex(const regex&) = delete;
  regex& operator=(const regex&) = delete;
  regex(regex&& o) noexcept : re_(o.re_), valid_(o.valid_) { o.valid_ = false; }

  bool valid() const noexcept { return valid_; }
  const ::regex_t& native() const noexcept { return re_; }

private:
  ::regex_t re_{};
  bool valid_;
};

class smatch {
public:
  smatch() = default;

  string str(size_t i = 0) const {
    return i < matches_.size() ? matches_[i] : string{};
  }
  size_t size() const noexcept { return matches_.size(); }
  bool empty() const noexcept { return matches_.empty(); }
  bool ready() const noexcept { return ready_; }

  void set(const string& subject, const ::regmatch_t* pm, size_t n) {
    matches_.clear();
    ready_ = true;
    for (size_t i = 0; i < n; ++i) {
      if (pm[i].rm_so >= 0)
        matches_.push_back(subject.substr((size_t)pm[i].rm_so,
                                          (size_t)(pm[i].rm_eo - pm[i].rm_so)));
      else
        matches_.push_back(string{});
    }
    // Trim trailing empty matches from unmatched groups
    while (!matches_.empty() && matches_.back().empty() &&
           matches_.size() > 1) {
      // Keep empty groups that were explicitly captured, drop POSIX sentinels
      // with rm_so==-1 (we already set those to ""); trim only if size > 1
      break;
    }
  }

private:
  vector<string> matches_;
  bool ready_ = false;
};

using cmatch = smatch;
using wsmatch = smatch;

inline bool regex_search(const string& s, smatch& m, const regex& re) {
  if (!re.valid())
    return false;
  static constexpr size_t NMATCH = 16;
  ::regmatch_t pm[NMATCH];
  if (::regexec(&re.native(), s.c_str(), NMATCH, pm, 0) == 0) {
    m.set(s, pm, NMATCH);
    return true;
  }
  return false;
}

inline bool regex_search(const char* s, smatch& m, const regex& re) {
  return regex_search(string(s), m, re);
}

inline bool regex_search(const string& s, const regex& re) {
  smatch m;
  return regex_search(s, m, re);
}

inline bool regex_search(const char* s, const regex& re) {
  smatch m;
  return regex_search(string(s), m, re);
}

inline bool regex_match(const string& s, smatch& m, const regex& re) {
  if (!regex_search(s, m, re))
    return false;
  // Must cover the whole string
  return !m.empty() && m.str(0) == s;
}

inline bool regex_match(const string& s, const regex& re) {
  smatch m;
  return regex_match(s, m, re);
}

inline bool regex_match(const char* s, const regex& re) {
  return regex_match(string(s), re);
}

} // namespace std
