#pragma once
#include <__psychicstd_iterator_core>
#include <compare>
#include <type_traits>

// Minimal <concepts> stub

namespace std {

template <typename T, typename U>
concept same_as = is_same_v<T, U> && is_same_v<U, T>;

template <typename Derived, typename Base>
concept derived_from =
    is_base_of_v<Base, Derived> &&
    is_convertible_v<const volatile Derived*, const volatile Base*>;

template <typename From, typename To>
concept convertible_to = is_convertible_v<From, To> &&
                         requires { static_cast<To>(declval<From>()); };

// common_type is not yet in our type_traits; stub common_with as
// always-satisfiable
template <typename T, typename U>
concept common_with = true;

template <typename T>
concept integral = is_integral_v<T>;

template <typename T>
concept signed_integral = integral<T> && is_signed_v<T>;

template <typename T>
concept unsigned_integral = integral<T> && !signed_integral<T>;

template <typename T>
concept floating_point = is_floating_point_v<T>;

template <typename T, typename U>
concept assignable_from = is_lvalue_reference_v<T> && requires(T lhs, U&& rhs) {
  { lhs = static_cast<U&&>(rhs) } -> same_as<T>;
};

template <typename T>
concept destructible = is_nothrow_destructible_v<T>;

template <typename T, typename... Args>
concept constructible_from = destructible<T> && is_constructible_v<T, Args...>;

template <typename T>
concept default_initializable = constructible_from<T> && requires {
  T{};
  new T;
};

template <typename T>
concept move_constructible = constructible_from<T, T> && convertible_to<T, T>;

template <typename T>
concept copy_constructible =
    move_constructible<T> && constructible_from<T, T&> &&
    convertible_to<T&, T> && constructible_from<T, const T&> &&
    convertible_to<const T&, T> && constructible_from<T, const T> &&
    convertible_to<const T, T>;

template <typename T>
concept equality_comparable =
    requires(const remove_reference_t<T>& a, const remove_reference_t<T>& b) {
      { a == b } -> convertible_to<bool>;
      { a != b } -> convertible_to<bool>;
    };

template <typename T, typename U>
concept equality_comparable_with =
    equality_comparable<T> && equality_comparable<U> &&
    requires(const remove_reference_t<T>& t, const remove_reference_t<U>& u) {
      { t == u } -> convertible_to<bool>;
      { t != u } -> convertible_to<bool>;
      { u == t } -> convertible_to<bool>;
      { u != t } -> convertible_to<bool>;
    };

template <typename T>
concept totally_ordered =
    equality_comparable<T> &&
    requires(const remove_reference_t<T>& a, const remove_reference_t<T>& b) {
      { a < b } -> convertible_to<bool>;
      { a > b } -> convertible_to<bool>;
      { a <= b } -> convertible_to<bool>;
      { a >= b } -> convertible_to<bool>;
    };

template <typename T, typename U>
concept totally_ordered_with =
    totally_ordered<T> && totally_ordered<U> && equality_comparable_with<T, U>;

template <typename T>
concept movable =
    is_object_v<T> && move_constructible<T> && assignable_from<T&, T>;

template <typename T>
concept copyable =
    copy_constructible<T> && movable<T> && assignable_from<T&, T&> &&
    assignable_from<T&, const T&> && assignable_from<T&, const T>;

template <typename T>
concept semiregular = copyable<T> && default_initializable<T>;

template <typename T>
concept regular = semiregular<T> && equality_comparable<T>;

// Callable concepts
template <typename F, typename... Args>
concept invocable = requires(F&& f, Args&&... args) {
  static_cast<F&&>(f)(static_cast<Args&&>(args)...);
};

template <typename F, typename... Args>
concept regular_invocable = invocable<F, Args...>;

template <typename F, typename... Args>
concept predicate = regular_invocable<F, Args...> &&
                    convertible_to<invoke_result_t<F, Args...>, bool>;

// ITER_CONCEPT: prefer iterator_concept over iterator_category (C++20
// iterators)
namespace __iter_detail {
template <typename I, typename = void> struct __concept_helper {
  using type = typename iterator_traits<I>::iterator_category;
};
template <typename I>
struct __concept_helper<I, void_t<typename I::iterator_concept>> {
  using type = typename I::iterator_concept;
};
template <typename I> using __concept_t = typename __concept_helper<I>::type;
} // namespace __iter_detail

// Weakly incrementable
template <typename I>
concept weakly_incrementable = movable<I> && requires(I i) {
  typename iter_difference_t<I>;
  { ++i } -> same_as<I&>;
  i++;
};

template <typename I>
concept incrementable = regular<I> && weakly_incrementable<I> && requires(I i) {
  { i++ } -> same_as<I>;
};

template <typename I>
concept input_or_output_iterator = weakly_incrementable<I> && requires(I i) {
  { *i };
};

template <typename I, typename T>
concept output_iterator = input_or_output_iterator<I> && requires(I it, T&& t) {
  *it++ = static_cast<T&&>(t);
};

template <typename S, typename I>
concept sentinel_for = semiregular<S> && input_or_output_iterator<I> &&
                       requires(const I i, const S s) {
                         { i == s } -> convertible_to<bool>;
                       };

template <typename S, typename I>
concept sized_sentinel_for =
    sentinel_for<S, I> && requires(const I& i, const S& s) {
      { s - i } -> same_as<iter_difference_t<I>>;
      { i - s } -> same_as<iter_difference_t<I>>;
    };

// common_reference_with — uses common_reference_t from <type_traits>
template <typename T, typename U>
concept common_reference_with =
    same_as<common_reference_t<T, U>, common_reference_t<U, T>> &&
    convertible_to<T, common_reference_t<T, U>> &&
    convertible_to<U, common_reference_t<T, U>>;

// three_way_comparable_with — re-exported from <compare>
using std::three_way_comparable_with;

// Iterator concepts — use iterator_concept when present (C++20 iterators)
template <typename I>
concept input_iterator = input_or_output_iterator<I> && requires {
  typename __iter_detail::__concept_t<I>;
} && derived_from<__iter_detail::__concept_t<I>, input_iterator_tag>;

template <typename I>
concept forward_iterator =
    input_iterator<I> && incrementable<I> && sentinel_for<I, I> &&
    derived_from<__iter_detail::__concept_t<I>, forward_iterator_tag>;

template <typename I>
concept bidirectional_iterator =
    forward_iterator<I> &&
    derived_from<__iter_detail::__concept_t<I>, bidirectional_iterator_tag> &&
    requires(I i) {
      { --i } -> same_as<I&>;
      { i-- } -> same_as<I>;
    };

template <typename I>
concept random_access_iterator =
    bidirectional_iterator<I> && totally_ordered<I> &&
    derived_from<__iter_detail::__concept_t<I>, random_access_iterator_tag> &&
    requires(I i, typename iterator_traits<I>::difference_type n) {
      { i += n } -> same_as<I&>;
      { i -= n } -> same_as<I&>;
      { i + n } -> same_as<I>;
      { n + i } -> same_as<I>;
      { i - n } -> same_as<I>;
      { i - i } -> same_as<decltype(n)>;
      { i[n] };
    };

template <typename I>
concept contiguous_iterator =
    random_access_iterator<I> &&
    derived_from<__iter_detail::__concept_t<I>, contiguous_iterator_tag> &&
    requires(I i) {
      { i.operator->() };
    };

// Range concept stubs
template <typename R>
concept range = requires(R& r) {
  begin(r);
  end(r);
};

template <typename R>
concept borrowed_range = range<R>;

template <typename R>
concept sized_range = range<R> && requires(R& r) { size(r); };

template <typename R>
concept input_range = range<R>;
template <typename R>
concept forward_range = range<R>;
template <typename R>
concept bidirectional_range = range<R>;
template <typename R>
concept random_access_range = range<R>;
template <typename R>
concept contiguous_range = range<R>;
template <typename R>
concept common_range = range<R>;

template <typename R, typename T>
concept output_range = range<R>;

} // namespace std
