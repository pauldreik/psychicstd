// not_fn (C++17)
template <typename F> class not_fn_t {
  F f_;

public:
  explicit not_fn_t(F&& f) : f_(static_cast<F&&>(f)) {}
  template <typename... Args> auto operator()(Args&&... args) & {
    return !f_(static_cast<Args&&>(args)...);
  }
  template <typename... Args> auto operator()(Args&&... args) const& {
    return !f_(static_cast<Args&&>(args)...);
  }
  template <typename... Args> auto operator()(Args&&... args) && {
    return !static_cast<F&&>(f_)(static_cast<Args&&>(args)...);
  }
};
template <typename F> not_fn_t<decay_t<F>> not_fn(F&& f) {
  return not_fn_t<decay_t<F>>(static_cast<F&&>(f));
}

// reference_wrapper (minimal)
template <typename T> class reference_wrapper {
  T* ptr_;

public:
  using type = T;
  reference_wrapper(T& r) noexcept : ptr_(&r) {}
  reference_wrapper(T&&) = delete;
  operator T&() const noexcept { return *ptr_; }
  T& get() const noexcept { return *ptr_; }
  template <typename... Args>
  invoke_result_t<T&, Args...> operator()(Args&&... args) const {
    return (*ptr_)(static_cast<Args&&>(args)...);
  }
};
template <typename T> reference_wrapper<T> ref(T& r) noexcept { return {r}; }
template <typename T> reference_wrapper<const T> cref(const T& r) noexcept {
  return {r};
}

// hash (forward declarations + specializations for common types)
template <typename T> struct hash;

template <> struct hash<bool> {
  size_t operator()(bool v) const noexcept { return (size_t)v; }
};
template <> struct hash<char> {
  size_t operator()(char v) const noexcept { return (size_t)v; }
};
template <> struct hash<signed char> {
  size_t operator()(signed char v) const noexcept { return (size_t)v; }
};
template <> struct hash<unsigned char> {
  size_t operator()(unsigned char v) const noexcept { return (size_t)v; }
};
template <> struct hash<short> {
  size_t operator()(short v) const noexcept { return (size_t)v; }
};
template <> struct hash<unsigned short> {
  size_t operator()(unsigned short v) const noexcept { return (size_t)v; }
};
template <> struct hash<int> {
  size_t operator()(int v) const noexcept { return (size_t)v; }
};
template <> struct hash<unsigned int> {
  size_t operator()(unsigned int v) const noexcept { return (size_t)v; }
};
template <> struct hash<long> {
  size_t operator()(long v) const noexcept { return (size_t)v; }
};
template <> struct hash<unsigned long> {
  size_t operator()(unsigned long v) const noexcept { return (size_t)v; }
};
template <> struct hash<long long> {
  size_t operator()(long long v) const noexcept { return (size_t)v; }
};
template <> struct hash<unsigned long long> {
  size_t operator()(unsigned long long v) const noexcept { return (size_t)v; }
};
template <> struct hash<float> {
  size_t operator()(float v) const noexcept {
    size_t h = 0;
    __builtin_memcpy(&h, &v, sizeof(v));
    return h;
  }
};
template <> struct hash<double> {
  size_t operator()(double v) const noexcept {
    size_t h = 0;
    __builtin_memcpy(&h, &v, sizeof(v));
    return h;
  }
};
template <typename T> struct hash<T*> {
  size_t operator()(T* p) const noexcept { return (size_t)p; }
};

// function<R(Args...)> — type-erased callable
template <typename> class function;

template <typename R, typename... Args> class function<R(Args...)> {
  struct base {
    virtual R call(Args...) = 0;
    virtual base* clone() = 0;
    virtual ~base() = default;
  };
  template <typename F> struct impl : base {
    F f_;
    impl(F f) : f_(static_cast<F&&>(f)) {}
    R call(Args... args) override { return f_(static_cast<Args&&>(args)...); }
    base* clone() override { return new impl(f_); }
  };
  base* ptr_ = nullptr;

public:
  function() noexcept = default;
  function(nullptr_t) noexcept {}
  function(const function& o) : ptr_(o.ptr_ ? o.ptr_->clone() : nullptr) {}
  function(function&& o) noexcept : ptr_(o.ptr_) { o.ptr_ = nullptr; }
  template <typename F>
    requires(!is_same_v<decay_t<F>, function>)
  function(F&& f) : ptr_(new impl<decay_t<F>>(static_cast<F&&>(f))) {}
  ~function() { delete ptr_; }

  function& operator=(const function& o) {
    if (this != &o) {
      delete ptr_;
      ptr_ = o.ptr_ ? o.ptr_->clone() : nullptr;
    }
    return *this;
  }
  function& operator=(function&& o) noexcept {
    delete ptr_;
    ptr_ = o.ptr_;
    o.ptr_ = nullptr;
    return *this;
  }
  function& operator=(nullptr_t) noexcept {
    delete ptr_;
    ptr_ = nullptr;
    return *this;
  }

  explicit operator bool() const noexcept { return ptr_ != nullptr; }

  R operator()(Args... args) const {
    return ptr_->call(static_cast<Args&&>(args)...);
  }
};

// --- std::bind / placeholders (minimal) ---

namespace placeholders {
  struct __ph1 {};
  inline constexpr __ph1 _1{};
} // namespace placeholders

namespace detail {
  template <typename F, typename... Bound> struct __bind_wrapper;

  // Wrap a value — if it's a placeholder, substitute; otherwise pass through.
  template <typename T, typename... Rest>
  constexpr decltype(auto) __bind_arg(T&& v, Rest&&...) { return static_cast<T&&>(v); }
  // Nested bind: invoke the nested bind expression with the call args
  template <typename F, typename... Bound, typename... Args>
  constexpr decltype(auto) __bind_arg(__bind_wrapper<F, Bound...>& bw, Args&&... args) {
    return bw(static_cast<Args&&>(args)...);
  }
  template <typename F, typename... Bound, typename... Args>
  constexpr decltype(auto) __bind_arg(const __bind_wrapper<F, Bound...>& bw, Args&&... args) {
    return bw(static_cast<Args&&>(args)...);
  }
  template <typename T, typename... Rest>
  constexpr T& __bind_arg(reference_wrapper<T> ref, Rest&&...) { return ref.get(); }
  template <typename Arg, typename... Rest>
  constexpr Arg&& __bind_arg(placeholders::__ph1, Arg&& a, Rest&&...) { return static_cast<Arg&&>(a); }

  // invoke: call f(args...) or (obj.*f)(args...) for member pointers
  template <typename F, typename... Args>
  constexpr decltype(auto) __invoke(F&& f, Args&&... args) {
    return static_cast<F&&>(f)(static_cast<Args&&>(args)...);
  }
  template <typename R, typename T, typename Obj, typename... Args>
  constexpr decltype(auto) __invoke(R T::*pm, Obj&& obj, Args&&... args) {
    if constexpr (is_pointer_v<decay_t<Obj>>)
      return ((*static_cast<Obj&&>(obj)).*pm)(static_cast<Args&&>(args)...);
    else
      return (static_cast<Obj&&>(obj).*pm)(static_cast<Args&&>(args)...);
  }

  template <typename F, typename... Bound>
  struct __bind_wrapper {
    F f_;
    tuple<Bound...> bound_;
    template <typename F2, typename... B2>
    constexpr __bind_wrapper(F2&& f, B2&&... b)
        : f_(static_cast<F2&&>(f)), bound_(static_cast<B2&&>(b)...) {}
    template <typename... Args>
    constexpr decltype(auto) operator()(Args&&... args) {
      return __call(index_sequence_for<Bound...>{}, static_cast<Args&&>(args)...);
    }
  private:
    template <size_t... Is, typename... Args>
    constexpr decltype(auto) __call(index_sequence<Is...>, Args&&... args) {
      auto resolved = tuple<decltype(detail::__bind_arg(get<Is>(bound_), static_cast<Args&&>(args)...))...>(
          detail::__bind_arg(get<Is>(bound_), static_cast<Args&&>(args)...)...);
      return apply([this](auto&&... resolved_args) -> decltype(auto) {
        return detail::__invoke(f_, static_cast<decltype(resolved_args)>(resolved_args)...);
      }, static_cast<decltype(resolved)&&>(resolved));
    }
  };
} // namespace detail

template <typename F, typename... Args>
constexpr auto bind(F&& f, Args&&... args) {
  return detail::__bind_wrapper<decay_t<F>, decay_t<Args>...>(
      static_cast<F&&>(f), static_cast<Args&&>(args)...);
}

// std::mem_fn — creates a call wrapper for a member function pointer
template <typename R, typename T>
constexpr auto mem_fn(R T::*pm) {
  return [pm](auto&& obj, auto&&... args) -> decltype(auto) {
    if constexpr (is_pointer_v<decay_t<decltype(obj)>>)
      return ((*static_cast<decltype(obj)>(obj)).*pm)(static_cast<decltype(args)>(args)...);
    else
      return (static_cast<decltype(obj)>(obj).*pm)(static_cast<decltype(args)>(args)...);
  };
}
// const version
template <typename R, typename T>
constexpr auto mem_fn(R (T::*pm)() const) {
  return [pm](auto&& obj) -> decltype(auto) {
    if constexpr (is_pointer_v<decay_t<decltype(obj)>>)
      return ((*static_cast<decltype(obj)>(obj)).*pm)();
    else
      return (static_cast<decltype(obj)>(obj).*pm)();
  };
}

} // namespace std
