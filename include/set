#pragma once
#include <__psychicstd_algo>
#include <__psychicstd_functors>
#include <initializer_list>
#include <utility>
#include <vector>

namespace std {

// set backed by sorted vector
template <typename Key, typename Compare = less<Key>,
          typename Alloc = allocator<Key>>
class set {
public:
  using key_type = Key;
  using value_type = Key;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using key_compare = Compare;
  using value_compare = Compare;
  using allocator_type = Alloc;
  using reference = const Key&;
  using const_reference = const Key&;
  using iterator = typename vector<Key>::const_iterator;
  using const_iterator = typename vector<Key>::const_iterator;
  using reverse_iterator = typename vector<Key>::const_reverse_iterator;
  using const_reverse_iterator = typename vector<Key>::const_reverse_iterator;

  set() = default;
  explicit set(const Compare& c) : comp_(c) {}
  explicit set(const Alloc& a) : alloc_(a) {}
  set(const Compare& c, const Alloc& a) : comp_(c), alloc_(a) {}
  template <typename It> set(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  set(initializer_list<Key> il) {
    for (auto& v : il)
      insert(v);
  }
  set(initializer_list<Key> il, const Compare& c) : comp_(c) {
    for (auto& v : il)
      insert(v);
  }
  set(initializer_list<Key> il, const Compare& c, const Alloc& a)
      : comp_(c), alloc_(a) {
    for (auto& v : il)
      insert(v);
  }
  set(initializer_list<Key> il, const Alloc& a) : alloc_(a) {
    for (auto& v : il)
      insert(v);
  }
  set(const set&) = default;
  set(set&&) = default;
  set& operator=(const set&) = default;
  set& operator=(set&&) = default;
  set& operator=(initializer_list<Key> il) {
    data_.clear();
    for (auto& v : il)
      insert(v);
    return *this;
  }

  iterator begin() const noexcept { return data_.begin(); }
  iterator end() const noexcept { return data_.end(); }
  const_iterator cbegin() const noexcept { return data_.cbegin(); }
  const_iterator cend() const noexcept { return data_.cend(); }
  reverse_iterator rbegin() const noexcept { return data_.rbegin(); }
  reverse_iterator rend() const noexcept { return data_.rend(); }

  bool empty() const noexcept { return data_.empty(); }
  size_type size() const noexcept { return data_.size(); }
  size_type max_size() const noexcept { return data_.max_size(); }

  pair<iterator, bool> insert(const Key& k) {
    auto it = lower_bound_(k);
    if (it != data_.end() && !comp_(k, *it))
      return {it, false};
    it = data_.insert(data_.begin() + (it - data_.begin()), k);
    return {it, true};
  }
  pair<iterator, bool> insert(Key&& k) {
    auto it = lower_bound_(k);
    if (it != data_.end() && !comp_(k, *it))
      return {it, false};
    it = data_.insert(data_.begin() + (it - data_.begin()),
                      static_cast<Key&&>(k));
    return {it, true};
  }
  // Hint versions (hint ignored for sorted-vector implementation)
  iterator insert(const_iterator, const Key& k) { return insert(k).first; }
  iterator insert(const_iterator, Key&& k) {
    return insert(static_cast<Key&&>(k)).first;
  }
  template <typename It> void insert(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  void insert(initializer_list<Key> il) {
    for (auto& v : il)
      insert(v);
  }

  template <typename... Args> pair<iterator, bool> emplace(Args&&... args) {
    return insert(Key(static_cast<Args&&>(args)...));
  }

  iterator erase(const_iterator pos) {
    return data_.erase(data_.begin() + (pos - data_.begin()));
  }
  iterator erase(const_iterator first, const_iterator last) {
    return data_.erase(data_.begin() + (first - data_.begin()),
                       data_.begin() + (last - data_.begin()));
  }
  size_type erase(const Key& k) {
    // Pointer keys need equality lookup: operator< on unrelated pointers is
    // not a portable ordering, while std::less<T*> must still support them.
    for (auto it = data_.begin(); it != data_.end(); ++it) {
      if (!comp_(*it, k) && !comp_(k, *it)) {
        data_.erase(it);
        return 1;
      }
    }
    auto it = lower_bound_(k);
    if (it == data_.end() || comp_(k, *it))
      return 0;
    data_.erase(data_.begin() + (it - data_.begin()));
    return 1;
  }
  void clear() noexcept { data_.clear(); }
  void swap(set& other) noexcept { data_.swap(other.data_); }

  iterator find(const Key& k) const {
    auto it = lower_bound_(k);
    if (it != data_.end() && !comp_(k, *it))
      return it;
    return data_.end();
  }
  size_type count(const Key& k) const { return find(k) != data_.end() ? 1 : 0; }
  bool contains(const Key& k) const { return find(k) != data_.end(); }

  iterator lower_bound(const Key& k) const { return lower_bound_(k); }
  iterator upper_bound(const Key& k) const {
    auto it = lower_bound_(k);
    if (it != data_.end() && !comp_(k, *it))
      ++it;
    return it;
  }
  pair<iterator, iterator> equal_range(const Key& k) const {
    return {lower_bound(k), upper_bound(k)};
  }

  bool operator==(const set& o) const { return data_ == o.data_; }
  bool operator!=(const set& o) const { return !(*this == o); }
  bool operator<(const set& o) const { return data_ < o.data_; }

private:
  vector<Key> data_;
  Compare comp_ = {};
  [[no_unique_address]] Alloc alloc_ = {};

  const_iterator lower_bound_(const Key& k) const {
    return std::__lower_bound(data_.begin(), data_.end(), k, comp_);
  }
};

// multiset
template <typename Key, typename Compare = less<Key>,
          typename Alloc = allocator<Key>>
class multiset {
public:
  using key_type = Key;
  using value_type = Key;
  using size_type = size_t;
  using key_compare = Compare;
  using value_compare = Compare;
  using allocator_type = Alloc;
  using iterator = typename vector<Key>::const_iterator;
  using const_iterator = typename vector<Key>::const_iterator;

  multiset() = default;
  explicit multiset(const Compare& comp) : comp_(comp) {}
  explicit multiset(const Alloc& alloc) : alloc_(alloc) {}
  multiset(const Compare& comp, const Alloc& alloc)
      : comp_(comp), alloc_(alloc) {}
  multiset(initializer_list<Key> il) {
    for (const auto& v : il)
      insert(v);
  }
  template <typename It> multiset(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }

  iterator begin() const noexcept { return data_.begin(); }
  iterator end() const noexcept { return data_.end(); }
  bool empty() const noexcept { return data_.empty(); }
  size_type size() const noexcept { return data_.size(); }
  void clear() noexcept { data_.clear(); }

  iterator insert(const Key& k) {
    auto it = std::__lower_bound(data_.begin(), data_.end(), k, comp_);
    return data_.insert(data_.begin() + (it - data_.begin()), k);
  }
  template <typename It> void insert(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename... Args> iterator emplace(Args&&... args) {
    return insert(Key(static_cast<Args&&>(args)...));
  }
  iterator erase(const_iterator pos) {
    return data_.erase(data_.begin() + (pos - data_.begin()));
  }
  size_type erase(const Key& k) {
    auto lo = std::__lower_bound(data_.begin(), data_.end(), k, comp_);
    auto hi = std::__upper_bound(data_.begin(), data_.end(), k, comp_);
    auto n = hi - lo;
    data_.erase(lo, hi);
    return n;
  }
  size_type count(const Key& k) const {
    auto lo = std::__lower_bound(data_.begin(), data_.end(), k, comp_);
    auto hi = std::__upper_bound(data_.begin(), data_.end(), k, comp_);
    return hi - lo;
  }
  iterator find(const Key& k) const {
    auto it = std::__lower_bound(data_.begin(), data_.end(), k, comp_);
    if (it != data_.end() && !comp_(k, *it))
      return it;
    return data_.end();
  }

private:
  vector<Key> data_;
  Compare comp_ = {};
  [[no_unique_address]] Alloc alloc_ = {};
};

} // namespace std
