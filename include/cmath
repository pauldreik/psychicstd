// isnan/isinf/isfinite/isnormal/signbit are macros in C — wrap them
inline bool isnan(float x) { return __builtin_isnan(x); }
inline bool isnan(double x) { return __builtin_isnan(x); }
inline bool isnan(long double x) { return __builtin_isnan(x); }
inline bool isinf(float x) { return __builtin_isinf(x); }
inline bool isinf(double x) { return __builtin_isinf(x); }
inline bool isinf(long double x) { return __builtin_isinf(x); }
inline bool isfinite(float x) { return __builtin_isfinite(x); }
inline bool isfinite(double x) { return __builtin_isfinite(x); }
inline bool isfinite(long double x) { return __builtin_isfinite(x); }
inline int fpclassify(float x) {
  return __builtin_fpclassify(FP_NAN, FP_INFINITE, FP_NORMAL, FP_SUBNORMAL,
                              FP_ZERO, x);
}
inline int fpclassify(double x) {
  return __builtin_fpclassify(FP_NAN, FP_INFINITE, FP_NORMAL, FP_SUBNORMAL,
                              FP_ZERO, x);
}
inline int fpclassify(long double x) {
  return __builtin_fpclassify(FP_NAN, FP_INFINITE, FP_NORMAL, FP_SUBNORMAL,
                              FP_ZERO, x);
}
#define _PSYCHICSTD_INTEGRAL_FINITE(T)                                         \
  constexpr bool isnan(T) { return false; }                                    \
  constexpr bool isinf(T) { return false; }                                    \
  constexpr bool isfinite(T) { return true; }                                  \
  constexpr int fpclassify(T x) { return x == 0 ? FP_ZERO : FP_NORMAL; }
_PSYCHICSTD_INTEGRAL_FINITE(bool)
_PSYCHICSTD_INTEGRAL_FINITE(char)
_PSYCHICSTD_INTEGRAL_FINITE(signed char)
_PSYCHICSTD_INTEGRAL_FINITE(unsigned char)
_PSYCHICSTD_INTEGRAL_FINITE(short)
_PSYCHICSTD_INTEGRAL_FINITE(unsigned short)
_PSYCHICSTD_INTEGRAL_FINITE(int)
_PSYCHICSTD_INTEGRAL_FINITE(unsigned int)
_PSYCHICSTD_INTEGRAL_FINITE(long)
_PSYCHICSTD_INTEGRAL_FINITE(unsigned long)
_PSYCHICSTD_INTEGRAL_FINITE(long long)
_PSYCHICSTD_INTEGRAL_FINITE(unsigned long long)
