#pragma once
#include <__psychicstd_config>
#include <__psychicstd_exception_base>

namespace std {

namespace __stdexcept {
class __msg {
  char* p_ = nullptr;
  static char* __dup(const char* s);

public:
  __msg() = default;
  explicit __msg(const char* s);
  __msg(const __msg& o);
  __msg(__msg&& o) noexcept;
  __msg& operator=(const __msg& o);
  __msg& operator=(__msg&& o) noexcept;
  ~__msg();
  const char* c_str() const noexcept;
};
} // namespace __stdexcept

class logic_error : public exception {
public:
  explicit logic_error(const char* msg);
  template <typename S>
    requires requires(const S& s) { s.c_str(); }
  explicit logic_error(const S& msg) : logic_error(msg.c_str()) {}
  logic_error(const logic_error&);
  logic_error& operator=(const logic_error&);
  ~logic_error() noexcept override;
  const char* what() const noexcept override;

private:
  __stdexcept::__msg msg_;
};

class domain_error : public logic_error {
public:
  using logic_error::logic_error;
  ~domain_error() noexcept override;
};
class invalid_argument : public logic_error {
public:
  using logic_error::logic_error;
  ~invalid_argument() noexcept override;
};
class length_error : public logic_error {
public:
  using logic_error::logic_error;
  ~length_error() noexcept override;
};
class out_of_range : public logic_error {
public:
  using logic_error::logic_error;
  ~out_of_range() noexcept override;
};

class runtime_error : public exception {
public:
  explicit runtime_error(const char* msg);
  template <typename S>
    requires requires(const S& s) { s.c_str(); }
  explicit runtime_error(const S& msg) : runtime_error(msg.c_str()) {}
  runtime_error(const runtime_error&);
  runtime_error& operator=(const runtime_error&);
  ~runtime_error() noexcept override;
  const char* what() const noexcept override;

private:
  __stdexcept::__msg msg_;
};

class range_error : public runtime_error {
public:
  using runtime_error::runtime_error;
  ~range_error() noexcept override;
};
class overflow_error : public runtime_error {
public:
  using runtime_error::runtime_error;
  ~overflow_error() noexcept override;
};
class underflow_error : public runtime_error {
public:
  using runtime_error::runtime_error;
  ~underflow_error() noexcept override;
};

[[noreturn, gnu::cold, gnu::noinline]] void
__throw_out_of_range(const char* message);
[[noreturn, gnu::cold, gnu::noinline]] void
__throw_invalid_argument(const char* message);
[[noreturn, gnu::cold, gnu::noinline]] void
__throw_runtime_error(const char* message);

} // namespace std
