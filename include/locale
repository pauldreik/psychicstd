// A small, process-local locale implementation. It supports the facet model
// used by formatting libraries: a locale owns installed facets, derived facets
// are found through their base class, and copies share their facet storage.
class locale {
public:
  class facet {
  public:
    virtual ~facet() = default;
    facet(const facet&) = delete;
    facet& operator=(const facet&) = delete;

  protected:
    facet() = default;
  };
  class id {};

  locale() noexcept = default;
  locale(const char*) noexcept {}
  locale(const locale& o) noexcept : rep_(o.rep_) {
    if (rep_)
      ++rep_->refs;
  }
  locale& operator=(const locale& o) noexcept {
    if (rep_ != o.rep_) {
      if (o.rep_)
        ++o.rep_->refs;
      _release();
      rep_ = o.rep_;
    }
    return *this;
  }
  ~locale() { _release(); }

  // Install facet f into a copy of other. The new locale owns f while the
  // facets inherited from other remain shared with it.
  template <typename Facet>
  locale(const locale& other, Facet* f)
      : rep_(new _rep(f, other.rep_ ? other.rep_->head : nullptr)) {}

  static const locale& classic() {
    static locale c;
    return c;
  }
  static locale global(const locale& loc) {
    locale& g = _global();
    locale prev = g;
    g = loc;
    return prev;
  }

  bool operator==(const locale& o) const noexcept { return rep_ == o.rep_; }
  bool operator!=(const locale& o) const noexcept { return rep_ != o.rep_; }

  template <typename F> const F* _facet() const {
#if _PSYCHICSTD_HAS_RTTI
    for (_node* node = rep_ ? rep_->head : nullptr; node; node = node->next)
      if (const auto* facet = dynamic_cast<const F*>(node->value))
        return facet;
#else
    (void)sizeof(F);
#endif
    return nullptr;
  }

private:
  struct _node {
    long refs = 1;
    facet* value;
    _node* next;

    _node(facet* f, _node* n) : value(f), next(n) {
      if (next)
        ++next->refs;
    }
  };
  struct _rep {
    long refs = 1;
    _node* head = nullptr;
    explicit _rep(facet* f, _node* inherited) : head(new _node(f, inherited)) {}
    ~_rep() { _release_node(head); }

  private:
    static void _release_node(_node* node) noexcept {
      if (node && --node->refs == 0) {
        _node* next = node->next;
        delete node->value;
        delete node;
        _release_node(next);
      }
    }
  };
  _rep* rep_ = nullptr;
  void _release() noexcept {
    if (rep_ && --rep_->refs == 0)
      delete rep_;
  }
  static locale& _global() {
    static locale g;
    return g;
  }
};

template <typename Char> class numpunct : public locale::facet {
public:
  using char_type = Char;
  // [locale.numpunct] specifies a narrow string even for wchar_t facets.
  using string_type = basic_string<char>;

  Char decimal_point() const { return do_decimal_point(); }
  Char thousands_sep() const { return do_thousands_sep(); }
  string_type grouping() const { return do_grouping(); }

  ~numpunct() override = default;

protected:
  virtual Char do_decimal_point() const { return Char('.'); }
  virtual Char do_thousands_sep() const { return Char(','); }
  virtual string_type do_grouping() const { return string_type(); }
};

class codecvt_base {
public:
  enum result { ok, partial, error, noconv };
};

template <typename Intern, typename E, typename S>
class codecvt : public locale::facet, public codecvt_base {
public:
  using intern_type = Intern;
  using extern_type = E;
  using state_type = S;

  result out(state_type& state, const Intern* from, const Intern* from_end,
             const Intern*& from_next, E* to, E* to_end, E*& to_next) const {
    return do_out(state, from, from_end, from_next, to, to_end, to_next);
  }
  result in(state_type& state, const E* from, const E* from_end,
            const E*& from_next, Intern* to, Intern* to_end,
            Intern*& to_next) const {
    return do_in(state, from, from_end, from_next, to, to_end, to_next);
  }
  result unshift(state_type& state, E* to, E* to_end, E*& to_next) const {
    return do_unshift(state, to, to_end, to_next);
  }
  int encoding() const noexcept { return do_encoding(); }
  bool always_noconv() const noexcept { return do_always_noconv(); }
  int length(state_type& state, const E* from, const E* end, size_t max) const {
    return do_length(state, from, end, max);
  }
  int max_length() const noexcept { return do_max_length(); }
  ~codecvt() override = default;

protected:
  virtual result do_out(state_type&, const Intern* from, const Intern* from_end,
                        const Intern*& from_next, E* to, E* to_end,
                        E*& to_next) const {
    return convert(from, from_end, from_next, to, to_end, to_next);
  }
  virtual result do_in(state_type&, const E* from, const E* from_end,
                       const E*& from_next, Intern* to, Intern* to_end,
                       Intern*& to_next) const {
    return convert(from, from_end, from_next, to, to_end, to_next);
  }
  virtual result do_unshift(state_type&, E* to, E*, E*& to_next) const {
    to_next = to;
    return noconv;
  }
  virtual int do_encoding() const noexcept {
    return __psychicstd_detail::is_same_v<Intern, E> ? 1 : 0;
  }
  virtual bool do_always_noconv() const noexcept {
    return __psychicstd_detail::is_same_v<Intern, E>;
  }
  virtual int do_length(state_type&, const E* from, const E* end,
                        size_t max) const {
    size_t available = static_cast<size_t>(end - from);
    return static_cast<int>(available < max ? available : max);
  }
  virtual int do_max_length() const noexcept { return 1; }

private:
  template <typename From, typename To>
  static result convert(const From* from, const From* from_end,
                        const From*& from_next, To* to, To* to_end,
                        To*& to_next) {
    while (from != from_end && to != to_end)
      *to++ = static_cast<To>(*from++);
    from_next = from;
    to_next = to;
    return from == from_end ? ok : partial;
  }
};

template <typename CharT, typename OutIt = ostreambuf_iterator<CharT>>
class time_put : public locale::facet {
public:
  using char_type = CharT;
  using iter_type = OutIt;

  iter_type put(iter_type out, ios_base&, char_type, const tm* time,
                const char_type* first, const char_type* last) const {
    char_type format[64]{};
    size_t n = static_cast<size_t>(last - first);
    if (n >= sizeof(format) / sizeof(*format))
      n = sizeof(format) / sizeof(*format) - 1;
    for (size_t i = 0; i < n; ++i)
      format[i] = first[i];
    char_type text[256]{};
    if constexpr (__psychicstd_detail::is_same_v<char_type, char>)
      ::strftime(text, sizeof(text), format, time);
    else
      ::wcsftime(text, sizeof(text) / sizeof(*text), format, time);
    for (const char_type* p = text; *p; ++p)
      *out++ = *p;
    return out;
  }
  iter_type put(iter_type out, ios_base& ios, char_type fill, const tm* time,
                char format, char modifier = 0) const {
    char_type spec[3] = {char_type('%'), static_cast<char_type>(format), 0};
    if (modifier) {
      spec[1] = static_cast<char_type>(modifier);
      spec[2] = static_cast<char_type>(format);
    }
    return put(out, ios, fill, time, spec, spec + (modifier ? 3 : 2));
  }
};

template <typename Facet>
struct __default_locale_facet : __psychicstd_detail::false_type {};
template <typename Char>
struct __default_locale_facet<numpunct<Char>> : __psychicstd_detail::true_type {
};
template <typename Intern, typename E, typename S>
struct __default_locale_facet<codecvt<Intern, E, S>>
    : __psychicstd_detail::true_type {};
template <typename Char, typename OutIt>
struct __default_locale_facet<time_put<Char, OutIt>>
    : __psychicstd_detail::true_type {};

template <typename Facet> bool has_facet(const locale& loc) {
  return loc.template _facet<Facet>() != nullptr ||
         __default_locale_facet<Facet>::value;
}

template <typename Facet> const Facet& use_facet(const locale& loc) {
  if (const Facet* facet = loc.template _facet<Facet>())
    return *facet;
  // Standard facets are present in every locale. For the small set of facets
  // implemented here, a default-constructed instance is the classic facet.
  static const Facet classic_facet{};
  return classic_facet;
}

