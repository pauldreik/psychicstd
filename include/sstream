namespace std {

// basic_stringbuf — wraps a string as a streambuf with read position
// (default args are in <iosfwd>)
template <typename Char, typename Traits, typename Alloc>
class basic_stringbuf : public basic_streambuf<Char, Traits> {
public:
  using char_type = Char;
  using traits_type = Traits;
  using int_type = typename Traits::int_type;
  using string_type = basic_string<Char, Traits, Alloc>;

  basic_stringbuf() = default;
  explicit basic_stringbuf(const string_type& s,
                           ios_base::openmode which = ios_base::in |
                                                      ios_base::out)
      : buf_(s), rpos_(0), ppos_((which & ios_base::ate) ? s.size() : 0) {}
  explicit basic_stringbuf(string_type&& s,
                           ios_base::openmode which = ios_base::in |
                                                      ios_base::out)
      : buf_(static_cast<string_type&&>(s)), rpos_(0),
        ppos_((which & ios_base::ate) ? buf_.size() : 0) {}

  string_type str() const { return buf_; }
  size_t _put_position() const noexcept { return ppos_; }
  void str(const string_type& s) {
    buf_ = s;
    rpos_ = 0;
    ppos_ = 0;
  }
  void str(string_type&& s) {
    buf_ = static_cast<string_type&&>(s);
    rpos_ = 0;
    ppos_ = 0;
  }

protected:
  // Write support
  streamsize xsputn(const Char* s, streamsize n) override {
    if (n <= 0)
      return 0;
    size_t count = (size_t)n;
    size_t available = ppos_ < buf_.size() ? buf_.size() - ppos_ : 0;
    size_t overwritten = count < available ? count : available;
    Traits::copy(buf_.data() + ppos_, s, overwritten);
    if (overwritten < count)
      buf_.append(s + overwritten, count - overwritten);
    ppos_ += count;
    return n;
  }
  int_type overflow(int_type c) override {
    if (Traits::eq_int_type(c, Traits::eof()))
      return Traits::eof();
    if (ppos_ < buf_.size())
      buf_[ppos_] = Traits::to_char_type(c);
    else
      buf_.push_back(Traits::to_char_type(c));
    ++ppos_;
    return c;
  }

  // Read support
  int_type underflow() override {
    if (rpos_ >= buf_.size())
      return Traits::eof();
    return Traits::to_int_type(buf_[rpos_]);
  }
  int_type uflow() override {
    if (rpos_ >= buf_.size())
      return Traits::eof();
    return Traits::to_int_type(buf_[rpos_++]);
  }
  int_type pbackfail(int_type c = Traits::eof()) override {
    if (rpos_ == 0)
      return Traits::eof();
    if (!Traits::eq_int_type(c, Traits::eof()) &&
        !Traits::eq(Traits::to_char_type(c), buf_[rpos_ - 1]))
      return Traits::eof();
    --rpos_;
    return Traits::eq_int_type(c, Traits::eof())
               ? Traits::to_int_type(buf_[rpos_])
               : c;
  }
  streamsize xsgetn(Char* s, streamsize n) override {
    size_t avail = buf_.size() > rpos_ ? buf_.size() - rpos_ : 0;
    size_t got = (size_t)n < avail ? (size_t)n : avail;
    Traits::copy(s, buf_.data() + rpos_, got);
    rpos_ += got;
    return (streamsize)got;
  }

  // Seek support
  streampos seekpos(streampos pos, ios_base::openmode which) override {
    size_t p = (size_t)(long long)pos;
    if (p > buf_.size())
      return streampos(-1);
    if (which & ios_base::in)
      rpos_ = p;
    if (which & ios_base::out)
      ppos_ = p;
    return streampos((which & ios_base::out) ? ppos_ : rpos_);
  }
  streampos seekoff(streamoff off, ios_base::seekdir dir,
                    ios_base::openmode which) override {
    size_t base;
    if (dir == ios_base::beg)
      base = 0;
    else if (dir == ios_base::end)
      base = buf_.size();
    else
      base = (which & ios_base::out) ? ppos_ : rpos_;
    size_t pos = (size_t)((long long)base + off);
    if (pos > buf_.size())
      return streampos(-1);
    if (which & ios_base::in)
      rpos_ = pos;
    if (which & ios_base::out)
      ppos_ = pos;
    return streampos((which & ios_base::out) ? ppos_ : rpos_);
  }

private:
  string_type buf_;
  size_t rpos_ = 0;
  size_t ppos_ = 0;
};

// basic_ostringstream (default args are in <iosfwd>)
template <typename Char, typename Traits, typename Alloc>
class basic_ostringstream : public basic_ostream<Char, Traits> {
public:
  using char_type = Char;
  using traits_type = Traits;
  using string_type = basic_string<Char, Traits, Alloc>;

  basic_ostringstream() : basic_ostream<Char, Traits>(&buf_) {}
  explicit basic_ostringstream(const string_type& s,
                               ios_base::openmode which = ios_base::out)
      : basic_ostream<Char, Traits>(&buf_), buf_(s, which) {}
  basic_ostringstream(basic_ostringstream&& other)
      : basic_ostream<Char, Traits>(&buf_), buf_(other.buf_.str()) {}
  basic_ostringstream& operator=(basic_ostringstream&& other) {
    if (this != &other) {
      buf_.str(other.buf_.str());
      this->copyfmt(other);
    }
    return *this;
  }

  string_type str() const { return buf_.str(); }
  void str(const string_type& s) { buf_.str(s); }
  void str(string_type&& s) { buf_.str(static_cast<string_type&&>(s)); }

  basic_stringbuf<Char, Traits, Alloc>* rdbuf() const {
    return const_cast<basic_stringbuf<Char, Traits, Alloc>*>(&buf_);
  }

private:
  basic_stringbuf<Char, Traits, Alloc> buf_;
};

// basic_istringstream (default args are in <iosfwd>)
template <typename Char, typename Traits, typename Alloc>
class basic_istringstream : public basic_istream<Char, Traits> {
public:
  using char_type = Char;
  using traits_type = Traits;
  using string_type = basic_string<Char, Traits, Alloc>;

  basic_istringstream() : basic_istream<Char, Traits>(&buf_) {}
  explicit basic_istringstream(const string_type& s,
                               ios_base::openmode which = ios_base::in)
      : basic_istream<Char, Traits>(&buf_), buf_(s, which) {}

  string_type str() const { return buf_.str(); }
  void str(const string_type& s) { buf_.str(s); }

  void imbue(const locale&) {} // stub

  basic_stringbuf<Char, Traits, Alloc>* rdbuf() const {
    return const_cast<basic_stringbuf<Char, Traits, Alloc>*>(&buf_);
  }

private:
  basic_stringbuf<Char, Traits, Alloc> buf_;
};

// basic_stringstream — inherits from both basic_istream and basic_ostream so it
// can be passed as either istream& or ostream*. State ambiguity is resolved by
// routing all ios methods through the istream base.
template <typename Char, typename Traits, typename Alloc>
class basic_stringstream : public basic_istream<Char, Traits>,
                           public basic_ostream<Char, Traits> {
public:
  using char_type = Char;
  using traits_type = Traits;
  using string_type = basic_string<Char, Traits, Alloc>;
  using int_type = typename Traits::int_type;

  // Disambiguate ios methods — route through istream's basic_ios subobject
  using basic_istream<Char, Traits>::setstate;
  using basic_istream<Char, Traits>::clear;
  using basic_istream<Char, Traits>::good;
  using basic_istream<Char, Traits>::fail;
  using basic_istream<Char, Traits>::bad;
  using basic_istream<Char, Traits>::eof;
  using basic_istream<Char, Traits>::rdstate;
  using basic_istream<Char, Traits>::flags;
  using basic_istream<Char, Traits>::setf;
  using basic_istream<Char, Traits>::unsetf;
  using basic_istream<Char, Traits>::precision;
  using basic_istream<Char, Traits>::width;
  using basic_istream<Char, Traits>::fill;
  using basic_istream<Char, Traits>::exceptions;

  basic_stringstream()
      : basic_istream<Char, Traits>(&buf_), basic_ostream<Char, Traits>(&buf_) {
  }
  explicit basic_stringstream(const string_type& s,
                              ios_base::openmode which = ios_base::in |
                                                         ios_base::out)
      : basic_istream<Char, Traits>(&buf_), basic_ostream<Char, Traits>(&buf_),
        buf_(s, which) {}

  string_type str() const { return buf_.str(); }
  void str(const string_type& s) { buf_.str(s); }
  void str(string_type&& s) { buf_.str(static_cast<string_type&&>(s)); }

  // Return our specific stringbuf (hides base class rdbuf())
  basic_stringbuf<Char, Traits, Alloc>* rdbuf() const {
    return const_cast<basic_stringbuf<Char, Traits, Alloc>*>(&buf_);
  }

  streampos tellp() { return streampos(buf_._put_position()); }
  streampos tellg() { return buf_.pubseekoff(0, ios_base::cur, ios_base::in); }

private:
  basic_stringbuf<Char, Traits, Alloc> buf_;
};

using stringbuf = basic_stringbuf<char, char_traits<char>, allocator<char>>;
using ostringstream =
    basic_ostringstream<char, char_traits<char>, allocator<char>>;
using istringstream =
    basic_istringstream<char, char_traits<char>, allocator<char>>;
using stringstream =
    basic_stringstream<char, char_traits<char>, allocator<char>>;
using wstringbuf =
    basic_stringbuf<wchar_t, char_traits<wchar_t>, allocator<wchar_t>>;
using wostringstream =
    basic_ostringstream<wchar_t, char_traits<wchar_t>, allocator<wchar_t>>;
using wstringstream =
    basic_stringstream<wchar_t, char_traits<wchar_t>, allocator<wchar_t>>;

} // namespace std
