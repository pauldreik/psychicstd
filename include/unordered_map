#pragma once
#include <__psychicstd_config>
#include <__psychicstd_except>
#include <__psychicstd_functors>
#include <cstddef>
#include <initializer_list>
#include <iterator>
#include <memory>
#include <utility>

namespace std {

template <typename Key, typename T, typename Hash = hash<Key>,
          typename KeyEqual = equal_to<Key>,
          typename Allocator = allocator<pair<const Key, T>>>
class unordered_map {
  struct Node {
    pair<const Key, T> kv;
    Node* next = nullptr;
    template <typename... A>
    explicit Node(A&&... a) : kv(static_cast<A&&>(a)...) {}
  };

  static Node** _alloc(size_t n) {
    Node** b = new Node*[n];
    for (size_t i = 0; i < n; ++i)
      b[i] = nullptr;
    return b;
  }

  size_t nbuckets_ = 16;
  Node** buckets_ = _alloc(16);
  size_t size_ = 0;
  Hash hasher_{};
  KeyEqual eq_{};
  Allocator allocator_{};

  size_t bucket(const Key& k) const { return hasher_(k) % nbuckets_; }

  void destroy() {
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        delete n;
        n = next;
      }
      buckets_[i] = nullptr;
    }
    size_ = 0;
  }

  void _rehash(size_t nb) {
    Node** nbuckets = _alloc(nb);
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        size_t b = hasher_(n->kv.first) % nb;
        n->next = nbuckets[b];
        nbuckets[b] = n;
        n = next;
      }
    }
    delete[] buckets_;
    buckets_ = nbuckets;
    nbuckets_ = nb;
  }
  void _maybe_rehash() {
    if (size_ + 1 > nbuckets_)
      _rehash(nbuckets_ * 2);
  }

  void swap_(unordered_map& o) noexcept {
    Node** tb = buckets_;
    buckets_ = o.buckets_;
    o.buckets_ = tb;
    size_t tn = nbuckets_;
    nbuckets_ = o.nbuckets_;
    o.nbuckets_ = tn;
    size_t ts = size_;
    size_ = o.size_;
    o.size_ = ts;
  }

public:
  using key_type = Key;
  using mapped_type = T;
  using value_type = pair<const Key, T>;
  using allocator_type = Allocator;
  using hasher = Hash;
  using key_equal = KeyEqual;
  using pointer = typename allocator_traits<Allocator>::pointer;
  using const_pointer = typename allocator_traits<Allocator>::const_pointer;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using reference = value_type&;
  using const_reference = const value_type&;

  struct const_iterator;
  struct iterator {
    using iterator_category = forward_iterator_tag;
    using value_type = pair<const Key, T>;
    using difference_type = ptrdiff_t;
    using pointer = value_type*;
    using reference = value_type&;
    unordered_map* m = nullptr;
    size_t b = 0;
    Node* n = nullptr;
    iterator() = default;
    iterator(unordered_map* m, size_t b, Node* n) : m(m), b(b), n(n) {}
    value_type& operator*() const { return n->kv; }
    value_type* operator->() const { return &n->kv; }
    bool operator==(const iterator& o) const { return n == o.n; }
    bool operator!=(const iterator& o) const { return n != o.n; }
    iterator& operator++() {
      n = n->next;
      while (!n && ++b < m->nbuckets_)
        n = m->buckets_[b];
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
  };
  struct const_iterator {
    using iterator_category = forward_iterator_tag;
    using value_type = pair<const Key, T>;
    using difference_type = ptrdiff_t;
    using pointer = const value_type*;
    using reference = const value_type&;
    const unordered_map* m = nullptr;
    size_t b = 0;
    const Node* n = nullptr;
    const_iterator() = default;
    const_iterator(const unordered_map* m, size_t b, const Node* n)
        : m(m), b(b), n(n) {}
    const_iterator(iterator it) : m(it.m), b(it.b), n(it.n) {}
    const value_type& operator*() const { return n->kv; }
    const value_type* operator->() const { return &n->kv; }
    bool operator==(const const_iterator& o) const { return n == o.n; }
    bool operator!=(const const_iterator& o) const { return n != o.n; }
    friend bool operator==(const iterator& a, const const_iterator& b) {
      return a.n == b.n;
    }
    friend bool operator!=(const iterator& a, const const_iterator& b) {
      return a.n != b.n;
    }
    const_iterator& operator++() {
      n = n->next;
      while (!n && ++b < m->nbuckets_)
        n = m->buckets_[b];
      return *this;
    }
    const_iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
  };
  using local_iterator = iterator;
  using const_local_iterator = const_iterator;

  unordered_map() = default;
  explicit unordered_map(const Allocator& a) : allocator_(a) {}
  explicit unordered_map(size_t buckets, const Hash& h = Hash(),
                         const KeyEqual& eq = KeyEqual(),
                         const Allocator& a = Allocator())
      : nbuckets_(buckets ? buckets : 1), buckets_(_alloc(nbuckets_)),
        hasher_(h), eq_(eq), allocator_(a) {}
  unordered_map(size_t buckets, const Allocator& a)
      : unordered_map(buckets, Hash(), KeyEqual(), a) {}
  unordered_map(size_t buckets, const Hash& h, const Allocator& a)
      : unordered_map(buckets, h, KeyEqual(), a) {}
  unordered_map(initializer_list<value_type> il) {
    for (const auto& kv : il)
      insert(kv);
  }
  unordered_map(initializer_list<value_type> il, size_t buckets, const Hash& h,
                const KeyEqual& eq, const Allocator& a)
      : unordered_map(buckets, h, eq, a) {
    for (const auto& kv : il)
      insert(kv);
  }
  unordered_map(initializer_list<value_type> il, size_t buckets, const Hash& h,
                const Allocator& a)
      : unordered_map(il, buckets, h, KeyEqual(), a) {}
  unordered_map(initializer_list<value_type> il, size_t buckets,
                const Allocator& a)
      : unordered_map(il, buckets, Hash(), KeyEqual(), a) {}
  template <typename It> unordered_map(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename It>
  unordered_map(It first, It last, size_t buckets, const Hash& h,
                const KeyEqual& eq, const Allocator& a)
      : unordered_map(buckets, h, eq, a) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename It>
  unordered_map(It first, It last, size_t buckets, const Hash& h,
                const Allocator& a)
      : unordered_map(buckets, h, KeyEqual(), a) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename It>
  unordered_map(It first, It last, size_t buckets, const Allocator& a)
      : unordered_map(buckets, Hash(), KeyEqual(), a) {
    for (; first != last; ++first)
      insert(*first);
  }
  unordered_map(const unordered_map& o) { *this = o; }
  unordered_map(const unordered_map& o, const Allocator& a)
      : unordered_map(o.nbuckets_, o.hasher_, o.eq_, a) {
    for (const auto& kv : o)
      insert(kv);
  }
  unordered_map(unordered_map&& o) noexcept { swap_(o); }
  ~unordered_map() {
    destroy();
    delete[] buckets_;
  }

  unordered_map& operator=(const unordered_map& o) {
    if (this != &o) {
      destroy();
      for (size_t i = 0; i < o.nbuckets_; ++i)
        for (Node* n = o.buckets_[i]; n; n = n->next)
          insert(n->kv);
    }
    return *this;
  }
  unordered_map& operator=(unordered_map&& o) noexcept {
    swap_(o);
    return *this;
  }

  size_type size() const noexcept { return size_; }
  bool empty() const noexcept { return size_ == 0; }
  size_type bucket_count() const noexcept { return nbuckets_; }
  size_type max_size() const noexcept { return size_type(-1); }
  hasher hash_function() const { return hasher_; }
  key_equal key_eq() const { return eq_; }
  allocator_type get_allocator() const { return allocator_; }
  float load_factor() const noexcept {
    return static_cast<float>(size_) / static_cast<float>(nbuckets_);
  }
  void rehash(size_type count) {
    if (count > nbuckets_)
      _rehash(count);
  }
  void reserve(size_type count) { rehash(count); }

  iterator begin() {
    for (size_t b = 0; b < nbuckets_; ++b)
      if (buckets_[b])
        return {this, b, buckets_[b]};
    return end();
  }
  iterator end() { return {this, nbuckets_, nullptr}; }
  const_iterator begin() const {
    for (size_t b = 0; b < nbuckets_; ++b)
      if (buckets_[b])
        return {this, b, buckets_[b]};
    return end();
  }
  const_iterator end() const { return {this, nbuckets_, nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  iterator find(const Key& k) {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, k))
        return {this, b, n};
    return end();
  }
  const_iterator find(const Key& k) const {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, k))
        return {this, b, n};
    return end();
  }
  pair<iterator, iterator> equal_range(const Key& k) {
    auto it = find(k);
    return it == end() ? pair<iterator, iterator>{it, it}
                       : pair<iterator, iterator>{it, next(it)};
  }
  pair<const_iterator, const_iterator> equal_range(const Key& k) const {
    auto it = find(k);
    return it == end() ? pair<const_iterator, const_iterator>{it, it}
                       : pair<const_iterator, const_iterator>{it, next(it)};
  }

  T& operator[](const Key& k) {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, k))
        return n->kv.second;
    _maybe_rehash();
    b = bucket(k);
    Node* n = new Node(k, T{});
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return n->kv.second;
  }
  T& operator[](Key&& k) {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, k))
        return n->kv.second;
    _maybe_rehash();
    b = bucket(k);
    Node* n = new Node(static_cast<Key&&>(k), T{});
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return n->kv.second;
  }
  T& at(const Key& k) {
    auto it = find(k);
    if (it == end())
      _PSYCHICSTD_THROW(out_of_range("unordered_map::at"));
    return it->second;
  }
  const T& at(const Key& k) const {
    auto it = find(k);
    if (it == end())
      _PSYCHICSTD_THROW(out_of_range("unordered_map::at"));
    return it->second;
  }
  size_type count(const Key& k) const { return find(k) != end() ? 1 : 0; }

  pair<iterator, bool> insert(const value_type& kv) {
    size_t b = bucket(kv.first);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, kv.first))
        return {{this, b, n}, false};
    _maybe_rehash();
    b = bucket(kv.first);
    Node* n = new Node(kv);
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {{this, b, n}, true};
  }
  pair<iterator, bool> insert(value_type&& kv) {
    size_t b = bucket(kv.first);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (eq_(n->kv.first, kv.first))
        return {{this, b, n}, false};
    _maybe_rehash();
    b = bucket(kv.first);
    Node* n = new Node(static_cast<value_type&&>(kv));
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {{this, b, n}, true};
  }
  // Hint versions (hint ignored)
  iterator insert(const_iterator, const value_type& kv) {
    return insert(kv).first;
  }
  iterator insert(const_iterator, value_type&& kv) {
    return insert(static_cast<value_type&&>(kv)).first;
  }
  template <typename It> void insert(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename... Args> pair<iterator, bool> emplace(Args&&... args) {
    return insert(value_type(static_cast<Args&&>(args)...));
  }
  template <typename... Args>
  iterator emplace_hint(const_iterator, Args&&... args) {
    return emplace(static_cast<Args&&>(args)...).first;
  }
  template <typename... Args>
  pair<iterator, bool> try_emplace(const Key& key, Args&&... args) {
    auto it = find(key);
    if (it != end())
      return {it, false};
    return insert(value_type(key, T(static_cast<Args&&>(args)...)));
  }
  template <typename... Args>
  pair<iterator, bool> try_emplace(Key&& key, Args&&... args) {
    auto it = find(key);
    if (it != end())
      return {it, false};
    return insert(
        value_type(static_cast<Key&&>(key), T(static_cast<Args&&>(args)...)));
  }
  template <typename... Args>
  iterator try_emplace(const_iterator hint, const Key& key, Args&&... args) {
    return try_emplace(key, static_cast<Args&&>(args)...).first;
  }
  template <typename... Args>
  iterator try_emplace(const_iterator hint, Key&& key, Args&&... args) {
    return try_emplace(static_cast<Key&&>(key), static_cast<Args&&>(args)...)
        .first;
  }
  template <typename M>
  pair<iterator, bool> insert_or_assign(const Key& key, M&& obj) {
    auto it = find(key);
    if (it != end()) {
      it->second = static_cast<M&&>(obj);
      return {it, false};
    }
    return {insert(value_type(key, static_cast<M&&>(obj))).first, true};
  }
  template <typename M>
  pair<iterator, bool> insert_or_assign(Key&& key, M&& obj) {
    auto it = find(key);
    if (it != end()) {
      it->second = static_cast<M&&>(obj);
      return {it, false};
    }
    return {insert(value_type(static_cast<Key&&>(key), static_cast<M&&>(obj)))
                .first,
            true};
  }
  template <typename M>
  iterator insert_or_assign(const_iterator hint, const Key& key, M&& obj) {
    return insert_or_assign(key, static_cast<M&&>(obj)).first;
  }
  template <typename M>
  iterator insert_or_assign(const_iterator hint, Key&& key, M&& obj) {
    return insert_or_assign(static_cast<Key&&>(key), static_cast<M&&>(obj))
        .first;
  }
  iterator erase(const_iterator pos) {
    size_t b = pos.b;
    Node* target = const_cast<Node*>(pos.n);
    Node* nx = target->next;
    Node** pp = &buckets_[b];
    while (*pp && *pp != target)
      pp = &(*pp)->next;
    if (*pp) {
      *pp = target->next;
      delete target;
      --size_;
    }
    iterator r{this, b, nx};
    while (!r.n && ++r.b < nbuckets_)
      r.n = buckets_[r.b];
    return r;
  }
  iterator erase(const_iterator first, const_iterator last) {
    while (first != last)
      first = erase(first);
    return {this, first.b, const_cast<Node*>(first.n)};
  }
  size_type erase(const Key& k) {
    size_t b = bucket(k);
    Node** pp = &buckets_[b];
    while (*pp) {
      if (eq_((*pp)->kv.first, k)) {
        Node* d = *pp;
        *pp = d->next;
        delete d;
        --size_;
        return 1;
      }
      pp = &(*pp)->next;
    }
    return 0;
  }
  void swap(unordered_map& other) noexcept { swap_(other); }
  void clear() { destroy(); }
};

// unordered_multimap — multiple values per key, node-based chaining
template <typename Key, typename T, typename Hash = hash<Key>,
          typename KeyEqual = equal_to<Key>,
          typename Allocator = allocator<pair<const Key, T>>>
class unordered_multimap {
  struct Node {
    pair<const Key, T> kv;
    Node* next = nullptr;
    template <typename... A>
    explicit Node(A&&... a) : kv(static_cast<A&&>(a)...) {}
  };

  static Node** _alloc(size_t n) {
    Node** b = new Node*[n];
    for (size_t i = 0; i < n; ++i)
      b[i] = nullptr;
    return b;
  }

  size_t nbuckets_ = 16;
  Node** buckets_ = _alloc(16);
  size_t size_ = 0;
  Hash hasher_{};
  KeyEqual eq_{};

  size_t bucket(const Key& k) const { return hasher_(k) % nbuckets_; }

  void destroy() {
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        delete n;
        n = next;
      }
      buckets_[i] = nullptr;
    }
    size_ = 0;
  }

  void _rehash(size_t nb) {
    Node** nbuckets = _alloc(nb);
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        size_t b = hasher_(n->kv.first) % nb;
        n->next = nbuckets[b];
        nbuckets[b] = n;
        n = next;
      }
    }
    delete[] buckets_;
    buckets_ = nbuckets;
    nbuckets_ = nb;
  }
  void _maybe_rehash() {
    if (size_ + 1 > nbuckets_)
      _rehash(nbuckets_ * 2);
  }

  void swap_(unordered_multimap& o) noexcept {
    Node** tb = buckets_;
    buckets_ = o.buckets_;
    o.buckets_ = tb;
    size_t tn = nbuckets_;
    nbuckets_ = o.nbuckets_;
    o.nbuckets_ = tn;
    size_t ts = size_;
    size_ = o.size_;
    o.size_ = ts;
  }

public:
  using key_type = Key;
  using mapped_type = T;
  using value_type = pair<const Key, T>;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using hasher = Hash;
  using key_equal = KeyEqual;

  struct const_iterator;
  struct iterator {
    unordered_multimap* m = nullptr;
    size_t b = 0;
    Node* n = nullptr;
    iterator() = default;
    iterator(unordered_multimap* map, size_t bucket, Node* node)
        : m(map), b(bucket), n(node) {}
    value_type& operator*() const { return n->kv; }
    value_type* operator->() const { return &n->kv; }
    iterator& operator++() {
      n = n->next;
      while (!n && ++b < m->nbuckets_)
        n = m->buckets_[b];
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    bool operator==(const iterator& o) const { return n == o.n; }
    bool operator!=(const iterator& o) const { return n != o.n; }
    operator const_iterator() const { return {m, b, n}; }
  };
  struct const_iterator {
    const unordered_multimap* m = nullptr;
    size_t b = 0;
    const Node* n = nullptr;
    const_iterator() = default;
    const_iterator(const unordered_multimap* map, size_t bucket,
                   const Node* node)
        : m(map), b(bucket), n(node) {}
    const value_type& operator*() const { return n->kv; }
    const value_type* operator->() const { return &n->kv; }
    const_iterator& operator++() {
      n = n->next;
      while (!n && ++b < m->nbuckets_)
        n = m->buckets_[b];
      return *this;
    }
    const_iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    bool operator==(const const_iterator& o) const { return n == o.n; }
    bool operator!=(const const_iterator& o) const { return n != o.n; }
  };

  iterator begin() {
    for (size_t b = 0; b < nbuckets_; ++b)
      if (buckets_[b])
        return {this, b, buckets_[b]};
    return end();
  }
  iterator end() { return {this, nbuckets_, nullptr}; }
  const_iterator begin() const {
    for (size_t b = 0; b < nbuckets_; ++b)
      if (buckets_[b])
        return {this, b, buckets_[b]};
    return end();
  }
  const_iterator end() const { return {this, nbuckets_, nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  unordered_multimap() = default;
  unordered_multimap(initializer_list<value_type> il) {
    for (const auto& kv : il)
      insert(kv);
  }
  template <typename It> unordered_multimap(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  unordered_multimap(const unordered_multimap& o) { *this = o; }
  unordered_multimap(unordered_multimap&& o) noexcept { swap_(o); }
  ~unordered_multimap() {
    destroy();
    delete[] buckets_;
  }

  unordered_multimap& operator=(const unordered_multimap& o) {
    if (this != &o) {
      destroy();
      for (size_t i = 0; i < o.nbuckets_; ++i)
        for (Node* n = o.buckets_[i]; n; n = n->next)
          insert(n->kv);
    }
    return *this;
  }
  unordered_multimap& operator=(unordered_multimap&& o) noexcept {
    swap_(o);
    return *this;
  }

  size_type size() const noexcept { return size_; }
  bool empty() const noexcept { return size_ == 0; }

  iterator insert(const value_type& kv) {
    _maybe_rehash();
    size_t b = bucket(kv.first);
    Node* n = new Node(kv);
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {this, b, n};
  }
  iterator insert(value_type&& kv) {
    _maybe_rehash();
    size_t b = bucket(kv.first);
    Node* n = new Node(static_cast<value_type&&>(kv));
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {this, b, n};
  }
  iterator insert(const_iterator, const value_type& kv) { return insert(kv); }
  iterator insert(const_iterator, value_type&& kv) {
    return insert(static_cast<value_type&&>(kv));
  }
  template <typename It> void insert(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  template <typename... Args> iterator emplace(Args&&... args) {
    return insert(value_type(static_cast<Args&&>(args)...));
  }

  size_type count(const Key& k) const {
    size_t b = bucket(k), n = 0;
    for (Node* p = buckets_[b]; p; p = p->next)
      if (eq_(p->kv.first, k))
        ++n;
    return n;
  }

  void clear() { destroy(); }
};

template <typename Key, typename T, typename Hash, typename KeyEqual,
          typename Allocator>
bool operator==(const unordered_map<Key, T, Hash, KeyEqual, Allocator>& a,
                const unordered_map<Key, T, Hash, KeyEqual, Allocator>& b) {
  if (a.size() != b.size())
    return false;
  for (const auto& kv : a) {
    auto it = b.find(kv.first);
    if (it == b.end() || !(it->second == kv.second))
      return false;
  }
  return true;
}

} // namespace std
