namespace __detail {
// Non-reference object destructibility via destructor expression
template <typename T, typename = void> struct __is_destr_obj : false_type {};
template <typename T>
struct __is_destr_obj<T, decltype((void)(declval<T&>().~T()))> : true_type {};

template <typename T, typename = void>
struct __is_nothrow_destr_obj : false_type {};
template <typename T>
struct __is_nothrow_destr_obj<T, decltype((void)(declval<T&>().~T()))>
    : bool_constant<noexcept(declval<T&>().~T())> {};

// is_destructible: references always qualify; non-refs use object check
template <typename T> struct __is_destr : __is_destr_obj<T> {};
template <typename T> struct __is_destr<T&> : true_type {};
template <typename T> struct __is_destr<T&&> : true_type {};

// is_nothrow_destructible: refs always nothrow; non-refs use noexcept check
template <typename T> struct __is_nothrow_destr : __is_nothrow_destr_obj<T> {};
template <typename T> struct __is_nothrow_destr<T&> : true_type {};
template <typename T> struct __is_nothrow_destr<T&&> : true_type {};
} // namespace __detail
template <typename T> struct is_destructible : __detail::__is_destr<T> {};
template <typename T>
inline constexpr bool is_destructible_v = is_destructible<T>::value;

template <typename T>
struct is_nothrow_destructible : __detail::__is_nothrow_destr<T> {};
template <typename T>
inline constexpr bool is_nothrow_destructible_v =
    is_nothrow_destructible<T>::value;

