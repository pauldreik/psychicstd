// invoke_result / result_of (deprecated in C++17, removed in C++20 but Catch2
// uses it)
namespace detail {
template <typename F, typename... Args>
auto invoke_expr(F&& f, Args&&... args)
    -> decltype(declval<F>()(declval<Args>()...));
template <typename R, typename C, typename Obj, typename... Args>
auto invoke_expr(R C::* member, Obj* obj, Args&&... args)
    -> decltype((obj->*member)(declval<Args>()...));
template <typename R, typename C, typename Obj, typename... Args>
auto invoke_expr(R C::* member, Obj&& obj, Args&&... args)
    -> decltype((declval<Obj>().*member)(declval<Args>()...));

template <typename Void, typename F, typename... Args>
struct invoke_result_impl {};
template <typename F, typename... Args>
struct invoke_result_impl<void_t<decltype(declval<F>()(declval<Args>()...))>, F,
                          Args...> {
  using type = decltype(declval<F>()(declval<Args>()...));
};
template <typename R, typename C, typename Obj, typename... Args>
struct invoke_result_impl<
    void_t<decltype((declval<Obj>().*declval<R C::*>())(declval<Args>()...))>,
    R C::*, Obj, Args...> {
  using type =
      decltype((declval<Obj>().*declval<R C::*>())(declval<Args>()...));
};
template <typename R, typename C, typename Obj, typename... Args>
struct invoke_result_impl<
    void_t<decltype((declval<Obj*>()->*declval<R C::*>())(declval<Args>()...))>,
    R C::*, Obj*, Args...> {
  using type =
      decltype((declval<Obj*>()->*declval<R C::*>())(declval<Args>()...));
};
} // namespace detail
template <typename F, typename... Args>
struct invoke_result : detail::invoke_result_impl<void, F, Args...> {};
template <typename F, typename... Args>
using invoke_result_t = typename invoke_result<F, Args...>::type;

// result_of<F(Args...)> — legacy alias; SFINAE-friendly: has ::type only when
// callable
template <typename> struct result_of;
template <typename F, typename... Args>
struct result_of<F(Args...)> : invoke_result<F, Args...> {};
template <typename T> using result_of_t = typename result_of<T>::type;

