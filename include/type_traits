template <typename T> struct remove_pointer<T* volatile> {
  using type = T;
};
template <typename T> struct remove_pointer<T* const volatile> {
  using type = T;
};
template <typename T> using remove_pointer_t = typename remove_pointer<T>::type;

template <typename T> struct add_pointer {
  using type = remove_reference_t<T>*;
};
template <typename T> using add_pointer_t = typename add_pointer<T>::type;

// remove_all_extents
template <typename T> struct remove_all_extents {
  using type = T;
};
template <typename T> struct remove_all_extents<T[]> {
  using type = typename remove_all_extents<T>::type;
};
template <typename T, size_t N> struct remove_all_extents<T[N]> {
  using type = typename remove_all_extents<T>::type;
};
template <typename T>
using remove_all_extents_t = typename remove_all_extents<T>::type;

// is_lvalue_reference / is_rvalue_reference
template <typename T> struct is_lvalue_reference : false_type {};
template <typename T> struct is_lvalue_reference<T&> : true_type {};
template <typename T>
inline constexpr bool is_lvalue_reference_v = is_lvalue_reference<T>::value;

template <typename T> struct is_rvalue_reference : false_type {};
template <typename T> struct is_rvalue_reference<T&&> : true_type {};
template <typename T>
inline constexpr bool is_rvalue_reference_v = is_rvalue_reference<T>::value;

// is_member_pointer / is_member_function_pointer / is_member_object_pointer
namespace detail {
template <typename T> struct is_member_pointer_impl : false_type {};
template <typename T, typename U>
struct is_member_pointer_impl<T U::*> : true_type {};
template <typename T> struct is_member_function_pointer_impl : false_type {};
template <typename T, typename U>
struct is_member_function_pointer_impl<T U::*> : is_function<T> {};
} // namespace detail
template <typename T>
struct is_member_pointer : detail::is_member_pointer_impl<remove_cv_t<T>> {};
template <typename T>
struct is_member_function_pointer
    : detail::is_member_function_pointer_impl<remove_cv_t<T>> {};
template <typename T>
struct is_member_object_pointer
    : bool_constant<is_member_pointer<T>::value &&
                    !is_member_function_pointer<T>::value> {};
template <typename T>
inline constexpr bool is_member_pointer_v = is_member_pointer<T>::value;
template <typename T>
inline constexpr bool is_member_function_pointer_v =
    is_member_function_pointer<T>::value;
template <typename T>
inline constexpr bool is_member_object_pointer_v =
    is_member_object_pointer<T>::value;

// is_fundamental / is_compound
template <typename T>
struct is_fundamental
    : bool_constant<is_arithmetic<T>::value || is_void<T>::value ||
                    is_null_pointer<T>::value> {};
template <typename T>
inline constexpr bool is_fundamental_v = is_fundamental<T>::value;

template <typename T>
struct is_compound : bool_constant<!is_fundamental<T>::value> {};
template <typename T>
inline constexpr bool is_compound_v = is_compound<T>::value;

// is_swappable — defined in <utility> (requires swap to be in scope)

// is_invocable
namespace detail {
template <typename F, typename... Args>
auto is_invocable_test(int)
    -> decltype((void)declval<typename invoke_result<F, Args...>::type*>(),
                true_type{});
template <typename, typename...> false_type is_invocable_test(...);
} // namespace detail
template <typename F, typename... Args>
struct is_invocable : decltype(detail::is_invocable_test<F, Args...>(0)) {};
template <typename F, typename... Args>
inline constexpr bool is_invocable_v = is_invocable<F, Args...>::value;

template <typename F, typename... Args>
struct is_nothrow_invocable
    : bool_constant<is_invocable<F, Args...>::value &&
                    noexcept(detail::invoke_expr(declval<F>(),
                                                 declval<Args>()...))> {};
template <typename F, typename... Args>
inline constexpr bool is_nothrow_invocable_v =
    is_nothrow_invocable<F, Args...>::value;

// is_invocable_r — invocable and the result is convertible to R (R=void: any)
namespace detail {
template <typename R, typename F, typename... Args>
auto is_invocable_r_test(int)
    -> decltype((void)declval<typename invoke_result<F, Args...>::type*>(),
                bool_constant<
                    is_void<R>::value ||
                    is_convertible_v<typename invoke_result<F, Args...>::type,
                                     R>>{});
template <typename R, typename, typename...>
false_type is_invocable_r_test(...);
} // namespace detail
template <typename R, typename F, typename... Args>
struct is_invocable_r
    : decltype(detail::is_invocable_r_test<R, F, Args...>(0)) {};
template <typename R, typename F, typename... Args>
inline constexpr bool is_invocable_r_v = is_invocable_r<R, F, Args...>::value;

// common_type
template <typename... Ts> struct common_type {};

template <typename T> struct common_type<T> {
  using type = decay_t<T>;
};

template <typename T, typename U> struct common_type<T, U> {
private:
  template <typename A, typename B>
  static auto test(int) -> decltype(true ? declval<A>() : declval<B>());
  static void test(...);

public:
  using type = decay_t<decltype(test<T, U>(0))>;
};

template <typename T, typename U, typename... Rest>
struct common_type<T, U, Rest...>
    : common_type<typename common_type<T, U>::type, Rest...> {};

template <typename... Ts>
using common_type_t = typename common_type<Ts...>::type;

// basic_common_reference — hook for user/library specializations
template <typename T, typename U, template <typename> class TQual,
          template <typename> class UQual>
struct basic_common_reference {};

namespace __cr_detail {
// Qualifier extraction: XREF(T) maps X -> X with T's qualifiers applied
template <typename T> struct __qual {
  template <typename X> using apply = X;
};
template <typename T> struct __qual<const T> {
  template <typename X> using apply = const X;
};
template <typename T> struct __qual<T&> {
  template <typename X> using apply = X&;
};
template <typename T> struct __qual<const T&> {
  template <typename X> using apply = const X&;
};
template <typename T> struct __qual<T&&> {
  template <typename X> using apply = X&&;
};
template <typename T> struct __qual<const T&&> {
  template <typename X> using apply = const X&&;
};

// Step 1: check basic_common_reference specialization
template <typename T, typename U, typename = void> struct __basic_cr {};

template <typename T, typename U>
struct __basic_cr<
    T, U,
    void_t<typename basic_common_reference<remove_cvref_t<T>, remove_cvref_t<U>,
                                           __qual<T>::template apply,
                                           __qual<U>::template apply>::type>> {
  using type =
      typename basic_common_reference<remove_cvref_t<T>, remove_cvref_t<U>,
                                      __qual<T>::template apply,
                                      __qual<U>::template apply>::type;
};

// Step 2: ternary-based common reference
template <typename T, typename U, typename = void> struct __ternary_cr {};

template <typename T, typename U>
struct __ternary_cr<T, U,
                    void_t<decltype(true ? declval<T>() : declval<U>())>> {
  using type = decltype(true ? declval<T>() : declval<U>());
};

// Priority: basic_common_reference > ternary > common_type
template <typename T, typename U, typename = void>
struct __common_ref2 : __ternary_cr<T, U> {};

template <typename T, typename U>
struct __common_ref2<T, U, void_t<typename __basic_cr<T, U>::type>>
    : __basic_cr<T, U> {};
} // namespace __cr_detail

template <typename... Ts> struct common_reference {};

template <typename T> struct common_reference<T> {
  using type = T;
};

template <typename T, typename U>
struct common_reference<T, U> : __cr_detail::__common_ref2<T, U> {};

template <typename T, typename U, typename... Rest>
struct common_reference<T, U, Rest...>
    : common_reference<typename common_reference<T, U>::type, Rest...> {};

template <typename... Ts>
using common_reference_t = typename common_reference<Ts...>::type;

constexpr bool is_constant_evaluated() noexcept {
  return __builtin_is_constant_evaluated();
}

