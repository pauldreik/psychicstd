// is_convertible — SFINAE test
namespace detail {
template <typename To> void is_convertible_sink(To);
template <typename From, typename To,
          typename = decltype(is_convertible_sink<To>(declval<From>()))>
true_type is_convertible_test(int);
template <typename From, typename To> false_type is_convertible_test(...);
} // namespace detail
template <typename From, typename To>
struct is_convertible : decltype(detail::is_convertible_test<From, To>(0)) {};
template <typename From, typename To>
inline constexpr bool is_convertible_v = is_convertible<From, To>::value;

// is_signed / is_unsigned — expression-based so char, wchar_t, char8/16/32_t
// are handled correctly regardless of platform signedness.
namespace detail {
template <typename T, bool = is_arithmetic<T>::value>
struct is_signed_impl : false_type {};
template <typename T>
struct is_signed_impl<T, true> : bool_constant<(T(-1) < T(0))> {};
template <typename T, bool = is_integral<T>::value>
struct is_unsigned_impl : false_type {};
template <typename T>
struct is_unsigned_impl<T, true> : bool_constant<(T(0) < T(-1))> {};
} // namespace detail
template <typename T>
struct is_signed : detail::is_signed_impl<remove_cv_t<T>> {};
template <typename T> inline constexpr bool is_signed_v = is_signed<T>::value;
template <typename T>
struct is_unsigned : detail::is_unsigned_impl<remove_cv_t<T>> {};
template <typename T>
inline constexpr bool is_unsigned_v = is_unsigned<T>::value;

