class seed_seq {
public:
  using result_type = uint32_t;
  seed_seq() = default;
  seed_seq(initializer_list<result_type>) {}

  template <typename It> void generate(It first, It last) {
    uint32_t s = 0x12345678u;
    for (auto it = first; it != last; ++it) {
      s = s * 1664525u + 1013904223u;
      *it = s;
    }
  }
