// random_device: reads from /dev/urandom
class random_device {
public:
  using result_type = unsigned int;
  random_device() = default;
  random_device(const random_device&) = delete;
  random_device& operator=(const random_device&) = delete;

  result_type operator()() {
    result_type val;
    int fd = ::open("/dev/urandom", O_RDONLY | O_CLOEXEC);
    if (fd >= 0) {
      (void)::read(fd, &val, sizeof(val));
      ::close(fd);
    } else {
      // fallback: use address entropy + a counter
      static unsigned long long s = (unsigned long long)(void*)&s;
      s = s * 6364136223846793005ULL + 1442695040888963407ULL;
      val = (result_type)(s >> 33);
    }
    return val;
  }

  static constexpr result_type min() { return 0; }
  static constexpr result_type max() { return ~result_type(0); }
  double entropy() const noexcept { return 32.0; }
};

// linear_congruential_engine (minimal, for minstd_rand)
template <typename UInt, UInt a, UInt c, UInt m>
class linear_congruential_engine {
public:
  using result_type = UInt;
  static constexpr result_type multiplier = a;
  static constexpr result_type increment = c;
  static constexpr result_type modulus = m;
  static constexpr result_type default_seed = 1;

  explicit linear_congruential_engine(result_type seed = default_seed)
      : state_(seed % m) {}
  void seed(result_type s = default_seed) { state_ = s % m; }

  result_type operator()() {
    state_ = (a * state_ + c) % m;
    return state_;
  }
  static constexpr result_type min() { return c == 0 ? 1 : 0; }
  static constexpr result_type max() { return m - 1; }

private:
  result_type state_;
};

using minstd_rand0 =
    linear_congruential_engine<uint_fast32_t, 16807, 0, 2147483647>;
using minstd_rand =
    linear_congruential_engine<uint_fast32_t, 48271, 0, 2147483647>;

// Mersenne Twister 32-bit (mt19937)
class mt19937 {
  static constexpr int N = 624, M = 397;
  static constexpr uint32_t MATRIX_A = 0x9908b0dfU;
  static constexpr uint32_t UPPER_MASK = 0x80000000U;
  static constexpr uint32_t LOWER_MASK = 0x7fffffffU;
  uint32_t mt_[N];
  int index_ = N + 1;

  void generate() {
    static constexpr uint32_t mag[2] = {0, MATRIX_A};
    for (int i = 0; i < N - M; ++i) {
      uint32_t y = (mt_[i] & UPPER_MASK) | (mt_[i + 1] & LOWER_MASK);
      mt_[i] = mt_[i + M] ^ (y >> 1) ^ mag[y & 1];
    }
    for (int i = N - M; i < N - 1; ++i) {
      uint32_t y = (mt_[i] & UPPER_MASK) | (mt_[i + 1] & LOWER_MASK);
      mt_[i] = mt_[i + (M - N)] ^ (y >> 1) ^ mag[y & 1];
    }
    uint32_t y = (mt_[N - 1] & UPPER_MASK) | (mt_[0] & LOWER_MASK);
    mt_[N - 1] = mt_[M - 1] ^ (y >> 1) ^ mag[y & 1];
    index_ = 0;
  }

public:
  using result_type = uint32_t;
  static constexpr result_type default_seed = 5489U;

  explicit mt19937(result_type seed = default_seed) { this->seed(seed); }
  void seed(result_type s) {
    mt_[0] = s;
    for (int i = 1; i < N; ++i)
      mt_[i] = 1812433253U * (mt_[i - 1] ^ (mt_[i - 1] >> 30)) + i;
    index_ = N;
  }

  result_type operator()() {
    if (index_ >= N)
      generate();
    uint32_t y = mt_[index_++];
    y ^= y >> 11;
    y ^= (y << 7) & 0x9d2c5680U;
    y ^= (y << 15) & 0xefc60000U;
    y ^= y >> 18;
    return y;
  }
  static constexpr result_type min() { return 0; }
  static constexpr result_type max() { return 0xffffffffU; }
};

// mt19937_64
class mt19937_64 {
  static constexpr int N = 312, M = 156;
  static constexpr uint64_t MATRIX_A = 0xb5026f5aa96619e9ULL;
  static constexpr uint64_t UPPER_MASK = 0xffffffff80000000ULL;
  static constexpr uint64_t LOWER_MASK = 0x7fffffffULL;
  uint64_t mt_[N];
  int index_ = N + 1;

  void generate() {
    static constexpr uint64_t mag[2] = {0, MATRIX_A};
    for (int i = 0; i < N - M; ++i) {
      uint64_t y = (mt_[i] & UPPER_MASK) | (mt_[i + 1] & LOWER_MASK);
      mt_[i] = mt_[i + M] ^ (y >> 1) ^ mag[y & 1];
    }
    for (int i = N - M; i < N - 1; ++i) {
      uint64_t y = (mt_[i] & UPPER_MASK) | (mt_[i + 1] & LOWER_MASK);
      mt_[i] = mt_[i + (M - N)] ^ (y >> 1) ^ mag[y & 1];
    }
    uint64_t y = (mt_[N - 1] & UPPER_MASK) | (mt_[0] & LOWER_MASK);
    mt_[N - 1] = mt_[M - 1] ^ (y >> 1) ^ mag[y & 1];
    index_ = 0;
  }

public:
  using result_type = uint64_t;
  static constexpr result_type default_seed = 5489ULL;

  explicit mt19937_64(result_type seed = default_seed) { this->seed(seed); }
  void seed(result_type s) {
    mt_[0] = s;
    for (int i = 1; i < N; ++i)
      mt_[i] = 6364136223846793005ULL * (mt_[i - 1] ^ (mt_[i - 1] >> 62)) + i;
    index_ = N;
  }

  result_type operator()() {
    if (index_ >= N)
      generate();
    uint64_t x = mt_[index_++];
    x ^= (x >> 29) & 0x5555555555555555ULL;
    x ^= (x << 17) & 0x71d67fffeda60000ULL;
    x ^= (x << 37) & 0xfff7eee000000000ULL;
    x ^= x >> 43;
    return x;
  }
  static constexpr result_type min() { return 0; }
  static constexpr result_type max() { return ~uint64_t(0); }
};

// uniform_int_distribution
template <typename Int = int> class uniform_int_distribution {
public:
  using result_type = Int;
  struct param_type {
    Int a, b;
    param_type(Int a = 0, Int b = 1) : a(a), b(b) {}
    Int min() const { return a; }
    Int max() const { return b; }
  };

  explicit uniform_int_distribution(Int a = 0, Int b = 1) : p_(a, b) {}
  explicit uniform_int_distribution(const param_type& p) : p_(p) {}

  template <typename Engine> result_type operator()(Engine& g) {
    return operator()(g, p_);
  }

  template <typename Engine>
  result_type operator()(Engine& g, const param_type& p) {
    using UInt = make_unsigned_t<Int>;
    UInt range = static_cast<UInt>(p.b) - static_cast<UInt>(p.a);
    if (range == ~UInt(0))
      return static_cast<Int>(g());
    ++range;
    UInt mod = (~UInt(0) - range + 1) % range;
    UInt val;
    do {
      val = static_cast<UInt>(g());
    } while (val < mod);
    return static_cast<Int>(val % range + static_cast<UInt>(p.a));
  }

  result_type min() const { return p_.a; }
  result_type max() const { return p_.b; }
  param_type param() const { return p_; }
  void param(const param_type& p) { p_ = p; }

private:
  param_type p_;
};

// uniform_real_distribution
template <typename Real = double> class uniform_real_distribution {
public:
  using result_type = Real;
  struct param_type {
    Real a, b;
    param_type(Real a = 0, Real b = 1) : a(a), b(b) {}
    Real min() const { return a; }
    Real max() const { return b; }
  };

  explicit uniform_real_distribution(Real a = 0, Real b = 1) : p_(a, b) {}
  explicit uniform_real_distribution(const param_type& p) : p_(p) {}

  template <typename Engine> result_type operator()(Engine& g) {
    return operator()(g, p_);
  }

  template <typename Engine>
  result_type operator()(Engine& g, const param_type& p) {
    // Generate a uniform [0,1) floating point value
    auto gmin = g.min();
    auto gmax = g.max();
    auto range = static_cast<double>(gmax) - static_cast<double>(gmin) + 1.0;
    double u = (static_cast<double>(g() - gmin)) / range;
    return static_cast<Real>(p.a + u * (p.b - p.a));
  }

  result_type min() const { return p_.a; }
  result_type max() const { return p_.b; }
  param_type param() const { return p_; }
  void param(const param_type& p) { p_ = p; }

private:
  param_type p_;
};

// normal_distribution
template <typename Real = double> class normal_distribution {
public:
  using result_type = Real;
  struct param_type {
    Real mean, stddev;
    param_type(Real mean = 0, Real stddev = 1) : mean(mean), stddev(stddev) {}
  };

  explicit normal_distribution(Real mean = 0, Real stddev = 1)
      : p_{mean, stddev} {}

  template <typename Engine> result_type operator()(Engine& g) {
    // Box-Muller transform
    uniform_real_distribution<Real> u(0, 1);
    Real u1, u2;
    do {
      u1 = u(g);
    } while (u1 == 0);
    u2 = u(g);
    Real mag = p_.stddev * static_cast<Real>(::sqrt(-2.0 * ::log((double)u1)));
    return mag * static_cast<Real>(
                     ::cos(2.0 * 3.14159265358979323846 * (double)u2)) +
           p_.mean;
  }

  result_type mean() const { return p_.mean; }
  result_type stddev() const { return p_.stddev; }

private:
  param_type p_;
};

