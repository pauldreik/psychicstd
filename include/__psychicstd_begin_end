#pragma once
#include <cstddef>

namespace std {

template <typename T, size_t N> constexpr T* begin(T (&a)[N]) noexcept {
  return a;
}
template <typename T, size_t N> constexpr T* end(T (&a)[N]) noexcept {
  return a + N;
}
template <typename C> constexpr auto begin(C& c) -> decltype(c.begin()) {
  return c.begin();
}
template <typename C> constexpr auto begin(const C& c) -> decltype(c.begin()) {
  return c.begin();
}
template <typename C> constexpr auto end(C& c) -> decltype(c.end()) {
  return c.end();
}
template <typename C> constexpr auto end(const C& c) -> decltype(c.end()) {
  return c.end();
}

} // namespace std
