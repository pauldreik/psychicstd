#pragma once

// Heap algorithms, split out of <algorithm> so <queue> (priority_queue) can
// use them without pulling in all of <algorithm>.

#include <__psychicstd_iterator_core>
#include <cstddef>

namespace std {

template <typename It, typename Compare>
constexpr void __push_heap(It first, ptrdiff_t hole, ptrdiff_t top, Compare cmp,
                           typename iterator_traits<It>::value_type val) {
  ptrdiff_t parent = (hole - 1) / 2;
  while (hole > top && cmp(*(first + parent), val)) {
    *(first + hole) = static_cast<decltype(val)&&>(*(first + parent));
    hole = parent;
    parent = (hole - 1) / 2;
  }
  *(first + hole) = static_cast<decltype(val)&&>(val);
}

template <typename It, typename Compare>
constexpr void push_heap(It first, It last, Compare cmp) {
  if (last - first > 1) {
    auto val =
        static_cast<typename iterator_traits<It>::value_type&&>(*(last - 1));
    __push_heap(first, last - first - 1, ptrdiff_t(0), cmp,
                static_cast<decltype(val)&&>(val));
  }
}
template <typename It> constexpr void push_heap(It first, It last) {
  push_heap(first, last, [](const auto& a, const auto& b) { return a < b; });
}

template <typename It, typename Compare>
constexpr void __adjust_heap(It first, ptrdiff_t hole, ptrdiff_t len,
                             Compare cmp,
                             typename iterator_traits<It>::value_type val) {
  ptrdiff_t top = hole;
  ptrdiff_t rchild = 2 * hole + 2;
  while (rchild < len) {
    if (cmp(*(first + rchild), *(first + (rchild - 1))))
      --rchild;
    *(first + hole) = static_cast<decltype(val)&&>(*(first + rchild));
    hole = rchild;
    rchild = 2 * hole + 2;
  }
  if (rchild == len) {
    *(first + hole) = static_cast<decltype(val)&&>(*(first + (rchild - 1)));
    hole = rchild - 1;
  }
  __push_heap(first, hole, top, cmp, static_cast<decltype(val)&&>(val));
}

template <typename It, typename Compare>
constexpr void pop_heap(It first, It last, Compare cmp) {
  if (last - first > 1) {
    --last;
    auto val = static_cast<typename iterator_traits<It>::value_type&&>(*last);
    *last = static_cast<decltype(val)&&>(*first);
    __adjust_heap(first, ptrdiff_t(0), last - first, cmp,
                  static_cast<decltype(val)&&>(val));
  }
}
template <typename It> constexpr void pop_heap(It first, It last) {
  pop_heap(first, last, [](const auto& a, const auto& b) { return a < b; });
}

template <typename It, typename Compare>
constexpr void make_heap(It first, It last, Compare cmp) {
  ptrdiff_t n = last - first;
  for (ptrdiff_t i = n / 2 - 1; i >= 0; --i) {
    auto val =
        static_cast<typename iterator_traits<It>::value_type&&>(*(first + i));
    __adjust_heap(first, i, n, cmp, static_cast<decltype(val)&&>(val));
  }
}
template <typename It> constexpr void make_heap(It first, It last) {
  make_heap(first, last, [](const auto& a, const auto& b) { return a < b; });
}

template <typename It, typename Compare>
constexpr void sort_heap(It first, It last, Compare cmp) {
  while (last - first > 1)
    pop_heap(first, last--, cmp);
}
template <typename It> constexpr void sort_heap(It first, It last) {
  sort_heap(first, last, [](const auto& a, const auto& b) { return a < b; });
}

template <typename It, typename Compare>
constexpr bool is_heap(It first, It last, Compare cmp) {
  ptrdiff_t n = last - first;
  for (ptrdiff_t i = 1; i < n; ++i)
    if (cmp(*(first + (i - 1) / 2), *(first + i)))
      return false;
  return true;
}
template <typename It> constexpr bool is_heap(It first, It last) {
  return is_heap(first, last,
                 [](const auto& a, const auto& b) { return a < b; });
}

template <typename It, typename Compare>
constexpr It is_heap_until(It first, It last, Compare cmp) {
  ptrdiff_t n = last - first;
  for (ptrdiff_t i = 1; i < n; ++i)
    if (cmp(*(first + (i - 1) / 2), *(first + i)))
      return first + i;
  return last;
}
template <typename It> constexpr It is_heap_until(It first, It last) {
  return is_heap_until(first, last,
                       [](const auto& a, const auto& b) { return a < b; });
}

} // namespace std
