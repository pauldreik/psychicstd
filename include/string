  size_t operator()(basic_string_view<Char> s) const noexcept {
    size_t h = 14695981039346656037ULL;
    for (size_t i = 0; i < s.size(); ++i) {
      h ^= (size_t)(unsigned char)s[i];
      h *= 1099511628211ULL;
    }
    return h;
  }
};

template <typename Char, typename Traits, typename Alloc>
basic_ostream<Char, Traits>&
operator<<(basic_ostream<Char, Traits>& os,
           const basic_string<Char, Traits, Alloc>& s) {
  return os.__put(s.data(), (streamsize)s.size());
}

template <typename Char, typename Traits, typename Alloc>
basic_istream<Char, Traits>& operator>>(basic_istream<Char, Traits>& is,
                                        basic_string<Char, Traits, Alloc>& s) {
  typename basic_istream<Char, Traits>::sentry sen(is);
  if (!sen) {
    is.setstate(basic_ios<Char, Traits>::failbit);
    return is;
  }
  s.clear();
  auto* sb = is.rdbuf();
  typename Traits::int_type c;
  while (!Traits::eq_int_type(c = sb->sgetc(), Traits::eof())) {
    Char ch = Traits::to_char_type(c);
    if (ch == ' ' || ch == '\n' || ch == '\t' || ch == '\r')
      break;
    s += ch;
    sb->sbumpc();
  }
  if (s.empty())
    is.setstate(basic_ios<Char, Traits>::failbit);
  return is;
}

template <typename Char, typename Traits, typename Alloc>
basic_istream<Char, Traits>&& operator>>(
    basic_istream<Char, Traits>&& is,
    basic_string<Char, Traits, Alloc>& s) {
  is >> s;
  return static_cast<basic_istream<Char, Traits>&&>(is);
}

template <typename Char, typename Traits, typename Alloc>
basic_istream<Char, Traits>& getline(basic_istream<Char, Traits>& is,
                                     basic_string<Char, Traits, Alloc>& s,
                                     Char delim = Char('\n')) {
  s.clear();
  typename basic_istream<Char, Traits>::sentry sen(is, true);
  if (!sen) {
    is.setstate(basic_ios<Char, Traits>::failbit);
    return is;
  }
  auto* sb = is.rdbuf();
  typename Traits::int_type c;
  size_t extracted = 0;
  while (!Traits::eq_int_type(c = sb ? sb->sbumpc() : Traits::eof(),
                              Traits::eof())) {
    ++extracted;
    Char ch = Traits::to_char_type(c);
    if (Traits::eq(ch, delim))
      break;
    s += ch;
  }
  if (Traits::eq_int_type(c, Traits::eof()))
    is.setstate(basic_ios<Char, Traits>::eofbit);
  // Extracting nothing (immediate EOF) is a failure, not an empty line.
  if (extracted == 0)
    is.setstate(basic_ios<Char, Traits>::failbit);
  return is;
}

