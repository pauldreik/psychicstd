// hash<basic_string> specializations
template <typename Char, typename Traits, typename Alloc>
struct hash<basic_string<Char, Traits, Alloc>> {
  size_t operator()(const basic_string<Char, Traits, Alloc>& s) const noexcept {
    // FNV-1a hash
    size_t h = 14695981039346656037ULL;
    for (size_t i = 0; i < s.size(); ++i) {
      h ^= (size_t)(unsigned char)s[i];
      h *= 1099511628211ULL;
    }
    return h;
  }
};

