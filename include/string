}
template <typename C, typename T, typename A>
bool operator<(const basic_string<C, T, A>& a,
               basic_string_view<C> b) noexcept {
  return T::compare(a.data(), b.data(),
                    a.size() < b.size() ? a.size() : b.size()) < 0 ||
         (a.size() < b.size() && T::compare(a.data(), b.data(), a.size()) == 0);
