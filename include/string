// sto* — string to arithmetic conversions
inline int stoi(const string& s, size_t* pos = nullptr, int base = 10) {
  errno = 0;
  char* end;
  auto v = ::strtol(s.c_str(), &end, base);
  if (pos)
    *pos = end - s.c_str();
  if (end == s.c_str())
    _PSYCHICSTD_THROW(invalid_argument("stoi"));
  if (errno == ERANGE)
    _PSYCHICSTD_THROW(out_of_range("stoi"));
  return (int)v;
}
