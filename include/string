template <typename C, typename T, typename A>
auto operator<=>(const basic_string<C, T, A>& a,
                 const basic_string<C, T, A>& b) noexcept {
  int r = a.compare(b);
  return r < 0   ? strong_ordering::less
         : r > 0 ? strong_ordering::greater
                 : strong_ordering::equal;
}
