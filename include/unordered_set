#pragma once
#include <__psychicstd_functors>
#include <cstddef>
#include <initializer_list>
#include <iterator>
#include <memory>
#include <utility>

namespace std {

template <typename Key, typename Hash = hash<Key>,
          typename KeyEqual = equal_to<Key>,
          typename Allocator = allocator<Key>>
class unordered_set {
  struct Node {
    Key key;
    Node* next = nullptr;
    explicit Node(const Key& k) : key(k) {}
    explicit Node(Key&& k) : key(static_cast<Key&&>(k)) {}
  };

  static Node** _alloc(size_t n) {
    Node** b = new Node*[n];
    for (size_t i = 0; i < n; ++i)
      b[i] = nullptr;
    return b;
  }

  size_t nbuckets_ = 16;
  Node** buckets_ = _alloc(16);
  size_t size_ = 0;
  Hash hasher_;
  KeyEqual equal_;

  size_t bucket(const Key& k) const { return hasher_(k) % nbuckets_; }

  void destroy() {
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        delete n;
        n = next;
      }
      buckets_[i] = nullptr;
    }
    size_ = 0;
  }

  void _rehash(size_t nb) {
    Node** nbuckets = _alloc(nb);
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        size_t b = hasher_(n->key) % nb;
        n->next = nbuckets[b];
        nbuckets[b] = n;
        n = next;
      }
    }
    delete[] buckets_;
    buckets_ = nbuckets;
    nbuckets_ = nb;
  }
  void _maybe_rehash() {
    if (size_ + 1 > nbuckets_)
      _rehash(nbuckets_ * 2);
  }

public:
  using key_type = Key;
  using value_type = Key;
  using size_type = size_t;
  using difference_type = ptrdiff_t;
  using hasher = Hash;
  using key_equal = KeyEqual;
  using allocator_type = Allocator;
  using reference = value_type&;
  using const_reference = const value_type&;

  struct iterator {
    using value_type = Key;
    using difference_type = ptrdiff_t;
    using pointer = const Key*;
    using reference = const Key&;
    using iterator_category = forward_iterator_tag;

    const unordered_set* set_ = nullptr;
    size_t bucket_ = 0;
    Node* node_ = nullptr;

    iterator() = default;
    iterator(const unordered_set* s, size_t b, Node* n)
        : set_(s), bucket_(b), node_(n) {}

    const Key& operator*() const { return node_->key; }
    const Key* operator->() const { return &node_->key; }

    iterator& operator++() {
      node_ = node_->next;
      while (!node_ && ++bucket_ < set_->nbuckets_)
        node_ = set_->buckets_[bucket_];
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    bool operator==(const iterator& o) const {
      return node_ == o.node_ && bucket_ == o.bucket_;
    }
    bool operator!=(const iterator& o) const { return !(*this == o); }
  };
  using const_iterator = iterator;
  using local_iterator = iterator;
  using const_local_iterator = const_iterator;

  unordered_set() = default;
  explicit unordered_set(size_t, const Hash& h = Hash(),
                         const KeyEqual& eq = KeyEqual(),
                         const Allocator& = Allocator())
      : hasher_(h), equal_(eq) {}
  explicit unordered_set(const Allocator&) {}
  unordered_set(initializer_list<Key> il) {
    for (const auto& k : il)
      insert(k);
  }
  template <typename It> unordered_set(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  unordered_set(const unordered_set& o) { *this = o; }
  unordered_set(unordered_set&& o) noexcept { swap_(o); }
  ~unordered_set() {
    destroy();
    delete[] buckets_;
  }

  void swap_(unordered_set& o) noexcept {
    Node** tb = buckets_;
    buckets_ = o.buckets_;
    o.buckets_ = tb;
    size_t tn = nbuckets_;
    nbuckets_ = o.nbuckets_;
    o.nbuckets_ = tn;
    size_t ts = size_;
    size_ = o.size_;
    o.size_ = ts;
  }

  unordered_set& operator=(const unordered_set& o) {
    if (this != &o) {
      destroy();
      for (size_t i = 0; i < o.nbuckets_; ++i) {
        for (Node* n = o.buckets_[i]; n; n = n->next)
          insert(n->key);
      }
    }
    return *this;
  }
  unordered_set& operator=(unordered_set&& o) noexcept {
    swap_(o);
    return *this;
  }

  iterator begin() const {
    for (size_t i = 0; i < nbuckets_; ++i)
      if (buckets_[i])
        return {this, i, buckets_[i]};
    return end();
  }
  iterator end() const { return {this, nbuckets_, nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  bool empty() const noexcept { return size_ == 0; }
  size_type size() const noexcept { return size_; }
  size_type bucket_count() const noexcept { return nbuckets_; }
  float load_factor() const noexcept {
    return static_cast<float>(size_) / static_cast<float>(nbuckets_);
  }
  void rehash(size_type count) {
    if (count > nbuckets_)
      _rehash(count);
  }
  void reserve(size_type count) { rehash(count); }

  void clear() { destroy(); }

  pair<iterator, bool> insert(const Key& k) {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next) {
      if (equal_(n->key, k))
        return {{this, b, n}, false};
    }
    _maybe_rehash();
    b = bucket(k);
    Node* n = new Node(k);
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {{this, b, n}, true};
  }
  pair<iterator, bool> insert(Key&& k) {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next) {
      if (equal_(n->key, k))
        return {{this, b, n}, false};
    }
    _maybe_rehash();
    b = bucket(k);
    Node* n = new Node(static_cast<Key&&>(k));
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {{this, b, n}, true};
  }
  // Hint versions (hint ignored)
  iterator insert(const_iterator, const Key& k) { return insert(k).first; }
  iterator insert(const_iterator, Key&& k) {
    return insert(static_cast<Key&&>(k)).first;
  }

  template <typename... Args> pair<iterator, bool> emplace(Args&&... args) {
    return insert(Key(static_cast<Args&&>(args)...));
  }
  template <typename It> void insert(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }

  iterator find(const Key& k) const {
    size_t b = bucket(k);
    for (Node* n = buckets_[b]; n; n = n->next)
      if (equal_(n->key, k))
        return {this, b, n};
    return end();
  }

  size_type count(const Key& k) const { return find(k) != end() ? 1 : 0; }

  iterator erase(const_iterator pos) {
    size_t b = bucket(*pos);
    Node** pp = &buckets_[b];
    while (*pp && (*pp)->key != *pos)
      pp = &(*pp)->next;
    if (!*pp)
      return end();
    Node* n = *pp;
    Node* next = n->next;
    *pp = next;
    delete n;
    --size_;
    iterator it{this, b, next};
    while (!it.node_ && ++it.bucket_ < nbuckets_)
      it.node_ = buckets_[it.bucket_];
    return it;
  }

  size_type erase(const Key& k) {
    size_t b = bucket(k);
    Node** pp = &buckets_[b];
    while (*pp) {
      if (equal_((*pp)->key, k)) {
        Node* del = *pp;
        *pp = del->next;
        delete del;
        --size_;
        return 1;
      }
      pp = &(*pp)->next;
    }
    return 0;
  }
};

// unordered_multiset — node-based chaining (allows duplicates)
template <typename Key, typename Hash = hash<Key>,
          typename KeyEqual = equal_to<Key>,
          typename Allocator = allocator<Key>>
class unordered_multiset {
  struct Node {
    Key key;
    Node* next = nullptr;
    explicit Node(const Key& k) : key(k) {}
    explicit Node(Key&& k) : key(static_cast<Key&&>(k)) {}
  };

  static Node** _alloc(size_t n) {
    Node** b = new Node*[n];
    for (size_t i = 0; i < n; ++i)
      b[i] = nullptr;
    return b;
  }

  size_t nbuckets_ = 16;
  Node** buckets_ = _alloc(16);
  size_t size_ = 0;
  Hash hasher_;
  KeyEqual equal_;

  size_t bucket(const Key& k) const { return hasher_(k) % nbuckets_; }

  void destroy() {
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        delete n;
        n = next;
      }
      buckets_[i] = nullptr;
    }
    size_ = 0;
  }

  void _rehash(size_t nb) {
    Node** nbuckets = _alloc(nb);
    for (size_t i = 0; i < nbuckets_; ++i) {
      Node* n = buckets_[i];
      while (n) {
        Node* next = n->next;
        size_t b = hasher_(n->key) % nb;
        n->next = nbuckets[b];
        nbuckets[b] = n;
        n = next;
      }
    }
    delete[] buckets_;
    buckets_ = nbuckets;
    nbuckets_ = nb;
  }
  void _maybe_rehash() {
    if (size_ + 1 > nbuckets_)
      _rehash(nbuckets_ * 2);
  }

  void swap_(unordered_multiset& o) noexcept {
    Node** tb = buckets_;
    buckets_ = o.buckets_;
    o.buckets_ = tb;
    size_t tn = nbuckets_;
    nbuckets_ = o.nbuckets_;
    o.nbuckets_ = tn;
    size_t ts = size_;
    size_ = o.size_;
    o.size_ = ts;
  }

public:
  using key_type = Key;
  using value_type = Key;
  using allocator_type = Allocator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;

  struct iterator {
    using value_type = Key;
    using difference_type = ptrdiff_t;
    using pointer = const Key*;
    using reference = const Key&;
    using iterator_category = forward_iterator_tag;

    const unordered_multiset* set_ = nullptr;
    size_t bucket_ = 0;
    Node* node_ = nullptr;

    iterator() = default;
    iterator(const unordered_multiset* s, size_t b, Node* n)
        : set_(s), bucket_(b), node_(n) {}

    const Key& operator*() const { return node_->key; }
    const Key* operator->() const { return &node_->key; }
    iterator& operator++() {
      node_ = node_->next;
      while (!node_ && ++bucket_ < set_->nbuckets_)
        node_ = set_->buckets_[bucket_];
      return *this;
    }
    iterator operator++(int) {
      auto t = *this;
      ++*this;
      return t;
    }
    bool operator==(const iterator& o) const { return node_ == o.node_; }
    bool operator!=(const iterator& o) const { return node_ != o.node_; }
  };
  using const_iterator = iterator;

  unordered_multiset() = default;
  unordered_multiset(initializer_list<Key> il) {
    for (const auto& k : il)
      insert(k);
  }
  template <typename It> unordered_multiset(It first, It last) {
    for (; first != last; ++first)
      insert(*first);
  }
  unordered_multiset(const unordered_multiset& o) { *this = o; }
  unordered_multiset(unordered_multiset&& o) noexcept { swap_(o); }
  ~unordered_multiset() {
    destroy();
    delete[] buckets_;
  }

  unordered_multiset& operator=(const unordered_multiset& o) {
    if (this != &o) {
      destroy();
      for (size_t i = 0; i < o.nbuckets_; ++i)
        for (Node* n = o.buckets_[i]; n; n = n->next)
          insert(n->key);
    }
    return *this;
  }
  unordered_multiset& operator=(unordered_multiset&& o) noexcept {
    swap_(o);
    return *this;
  }

  iterator begin() const {
    for (size_t i = 0; i < nbuckets_; ++i)
      if (buckets_[i])
        return {this, i, buckets_[i]};
    return end();
  }
  iterator end() const { return {this, nbuckets_, nullptr}; }
  const_iterator cbegin() const { return begin(); }
  const_iterator cend() const { return end(); }

  bool empty() const noexcept { return size_ == 0; }
  size_type size() const noexcept { return size_; }

  iterator insert(const Key& k) {
    _maybe_rehash();
    size_t b = bucket(k);
    Node* n = new Node(k);
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {this, b, n};
  }
  iterator insert(Key&& k) {
    _maybe_rehash();
    size_t b = bucket(k);
    Node* n = new Node(static_cast<Key&&>(k));
    n->next = buckets_[b];
    buckets_[b] = n;
    ++size_;
    return {this, b, n};
  }

  size_type count(const Key& k) const {
    size_t b = bucket(k);
    size_type n = 0;
    for (Node* p = buckets_[b]; p; p = p->next)
      if (equal_(p->key, k))
        ++n;
    return n;
  }
  void clear() { destroy(); }
};

} // namespace std
