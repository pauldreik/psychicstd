namespace std {

// setw
struct _setw {
  int n;
};
inline _setw setw(int n) { return {n}; }
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _setw m) {
  os.width(m.n);
  return os;
}

// setfill
template <typename Char> struct _setfill {
  Char c;
};
template <typename Char> _setfill<Char> setfill(Char c) { return {c}; }
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _setfill<Char> m) {
  os.fill(m.c);
  return os;
}

// setprecision
struct _setprecision {
  int n;
};
inline _setprecision setprecision(int n) { return {n}; }
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _setprecision m) {
  os.precision(m.n);
  return os;
}

// setbase
struct _setbase {
  int base;
};
inline _setbase setbase(int b) { return {b}; }
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _setbase m) {
  if (m.base == 8)
    os.setf(ios_base::oct, ios_base::basefield);
  else if (m.base == 16)
    os.setf(ios_base::hex, ios_base::basefield);
  else
    os.setf(ios_base::dec, ios_base::basefield);
  return os;
}

// setiosflags / resetiosflags
struct _setiosflags {
  ios_base::fmtflags mask;
};
struct _resetiosflags {
  ios_base::fmtflags mask;
};
inline _setiosflags setiosflags(ios_base::fmtflags m) { return {m}; }
inline _resetiosflags resetiosflags(ios_base::fmtflags m) { return {m}; }
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _setiosflags m) {
  os.setf(m.mask);
  return os;
}
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _resetiosflags m) {
  os.unsetf(m.mask);
  return os;
}

template <typename Char, typename Traits, typename Alloc> struct _quoted_out {
  const basic_string<Char, Traits, Alloc>& value;
  Char delim;
  Char escape;
};
template <typename Char, typename Traits, typename Alloc> struct _quoted_in {
  basic_string<Char, Traits, Alloc>& value;
  Char delim;
  Char escape;
};
template <typename Char, typename Traits, typename Alloc>
_quoted_out<Char, Traits, Alloc>
quoted(const basic_string<Char, Traits, Alloc>& value, Char delim = Char('"'),
       Char escape = Char('\\')) {
  return {value, delim, escape};
}
template <typename Char, typename Traits, typename Alloc>
_quoted_in<Char, Traits, Alloc> quoted(basic_string<Char, Traits, Alloc>& value,
                                       Char delim = Char('"'),
                                       Char escape = Char('\\')) {
  return {value, delim, escape};
}
template <typename Char, typename Traits, typename Alloc>
basic_ostream<Char, Traits>&
operator<<(basic_ostream<Char, Traits>& os,
           const _quoted_out<Char, Traits, Alloc>& value) {
  os << value.delim;
  for (Char c : value.value) {
    if (c == value.delim || c == value.escape)
      os << value.escape;
    os << c;
  }
  return os << value.delim;
}
template <typename Char, typename Traits, typename Alloc>
basic_ostream<Char, Traits>&
operator<<(basic_ostream<Char, Traits>& os,
           const _quoted_in<Char, Traits, Alloc>& value) {
  return os << _quoted_out<Char, Traits, Alloc>{value.value, value.delim,
                                                value.escape};
}
template <typename Char, typename Traits, typename Alloc>
basic_istream<Char, Traits>&
operator>>(basic_istream<Char, Traits>& is,
           const _quoted_in<Char, Traits, Alloc>& value) {
  Char c{};
  if (!(is >> c))
    return is;
  value.value.clear();
  if (c != value.delim) {
    value.value.push_back(c);
    return is;
  }
  bool escaped = false;
  while (is.get(c)) {
    if (!escaped && c == value.delim)
      break;
    if (!escaped && c == value.escape) {
      escaped = true;
      continue;
    }
    value.value.push_back(c);
    escaped = false;
  }
  return is;
}

template <typename Char> struct _put_time {
  const tm* time;
  const Char* format;
};
template <typename Char>
_put_time<Char> put_time(const tm* time, const Char* format) {
  return {time, format};
}
template <typename Char, typename Traits>
basic_ostream<Char, Traits>& operator<<(basic_ostream<Char, Traits>& os,
                                        _put_time<Char> value) {
  const Char* end = value.format;
  while (*end)
    ++end;
  use_facet<time_put<Char>>(os.getloc())
      .put(ostreambuf_iterator<Char, Traits>(os), os, Char(' '), value.time,
           value.format, end);
  return os;
}

} // namespace std
