}

template <typename It1, typename It2, typename OutIt>
OutIt set_difference(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      *out++ = *f1++;
    else if (*f2 < *f1)
      ++f2;
    else {
      ++f1;
      ++f2;
    }
  }
  return copy(f1, l1, out);
}
template <typename It1, typename It2, typename OutIt, typename Compare>
OutIt set_difference(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out, Compare cmp) {
  while (f1 != l1 && f2 != l2) {
    if (cmp(*f1, *f2))
      *out++ = *f1++;
    else if (cmp(*f2, *f1))
      ++f2;
    else {
      ++f1;
      ++f2;
    }
  }
  return copy(f1, l1, out);
}

template <typename It1, typename It2, typename OutIt>
OutIt set_symmetric_difference(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      *out++ = *f1++;
    else if (*f2 < *f1)
      *out++ = *f2++;
    else {
      ++f1;
      ++f2;
    }
  }
  out = copy(f1, l1, out);
  return copy(f2, l2, out);
}

