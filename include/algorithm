namespace std {

template <typename It1, typename It2>
constexpr It2 swap_ranges(It1 first1, It1 last1, It2 first2) {
  for (; first1 != last1; ++first1, ++first2)
    swap(*first1, *first2);
  return first2;
}

// min / max / clamp
template <typename T> constexpr const T& min(const T& a, const T& b) {
  return b < a ? b : a;
}
template <typename T> constexpr const T& max(const T& a, const T& b) {
  return a < b ? b : a;
}
template <typename T, typename Compare>
constexpr const T& min(const T& a, const T& b, Compare cmp) {
  return cmp(b, a) ? b : a;
}
template <typename T, typename Compare>
constexpr const T& max(const T& a, const T& b, Compare cmp) {
  return cmp(a, b) ? b : a;
}

template <typename T> constexpr T min(initializer_list<T> il) {
  const T* p = il.begin();
  const T* result = p;
  for (++p; p != il.end(); ++p)
    if (*p < *result)
      result = p;
  return *result;
}
template <typename T> constexpr T max(initializer_list<T> il) {
  const T* p = il.begin();
  const T* result = p;
  for (++p; p != il.end(); ++p)
    if (*result < *p)
      result = p;
  return *result;
}

template <typename T>
constexpr const T& clamp(const T& v, const T& lo, const T& hi) {
  return v < lo ? lo : (hi < v ? hi : v);
}
template <typename T, typename Compare>
constexpr const T& clamp(const T& v, const T& lo, const T& hi, Compare cmp) {
  return cmp(v, lo) ? lo : (cmp(hi, v) ? hi : v);
}

// iter_swap
template <typename It1, typename It2> constexpr void iter_swap(It1 a, It2 b) {
  swap(*a, *b);
}

// find / find_if / find_if_not
template <typename It, typename T>
constexpr It find(It first, It last, const T& value) {
  for (; first != last; ++first)
    if (*first == value)
      return first;
  return last;
}
template <typename It, typename Pred>
constexpr It find_if(It first, It last, Pred pred) {
  for (; first != last; ++first)
    if (pred(*first))
      return first;
  return last;
}
template <typename It, typename Pred>
constexpr It find_if_not(It first, It last, Pred pred) {
  for (; first != last; ++first)
    if (!pred(*first))
      return first;
  return last;
}
template <typename It1, typename It2>
constexpr It1 find_first_of(It1 first, It1 last, It2 search_first,
                            It2 search_last) {
  for (; first != last; ++first)
    for (It2 it = search_first; it != search_last; ++it)
      if (*first == *it)
        return first;
  return last;
}
template <typename It1, typename It2, typename Pred>
constexpr It1 find_first_of(It1 first, It1 last, It2 search_first,
                            It2 search_last, Pred pred) {
  for (; first != last; ++first)
    for (It2 it = search_first; it != search_last; ++it)
      if (pred(*first, *it))
        return first;
  return last;
}

// count / count_if
template <typename It, typename T>
constexpr typename iterator_traits<It>::difference_type count(It first, It last,
                                                              const T& value) {
  typename iterator_traits<It>::difference_type n = 0;
  for (; first != last; ++first)
    if (*first == value)
      ++n;
  return n;
}
template <typename It, typename Pred>
constexpr typename iterator_traits<It>::difference_type
count_if(It first, It last, Pred pred) {
  typename iterator_traits<It>::difference_type n = 0;
  for (; first != last; ++first)
    if (pred(*first))
      ++n;
  return n;
}

// all_of / any_of / none_of
template <typename It, typename Pred>
constexpr bool all_of(It first, It last, Pred pred) {
  for (; first != last; ++first)
    if (!pred(*first))
      return false;
  return true;
}
template <typename It, typename Pred>
constexpr bool any_of(It first, It last, Pred pred) {
  for (; first != last; ++first)
    if (pred(*first))
      return true;
  return false;
}
template <typename It, typename Pred>
constexpr bool none_of(It first, It last, Pred pred) {
  for (; first != last; ++first)
    if (pred(*first))
      return false;
  return true;
}

// for_each
template <typename It, typename F>
constexpr F for_each(It first, It last, F f) {
  for (; first != last; ++first)
    f(*first);
  return f;
}
template <typename It, typename Size, typename F>
constexpr It for_each_n(It first, Size n, F f) {
  for (Size i = 0; i < n; ++i) {
    f(*first);
    ++first;
  }
  return first;
}

// copy / copy_if / copy_n / copy_backward
template <typename In, typename Out>
constexpr Out copy(In first, In last, Out d_first) {
  for (; first != last; ++first) {
    *d_first = *first;
    ++d_first;
  }
  return d_first;
}
template <typename In, typename Out, typename Pred>
constexpr Out copy_if(In first, In last, Out d_first, Pred pred) {
  for (; first != last; ++first)
    if (pred(*first)) {
      *d_first = *first;
      ++d_first;
    }
  return d_first;
}
template <typename In, typename Size, typename Out>
constexpr Out copy_n(In first, Size n, Out d_first) {
  for (Size i = 0; i < n; ++i) {
    *d_first = *first;
    ++first;
    ++d_first;
  }
  return d_first;
}
template <typename In, typename Out>
constexpr Out copy_backward(In first, In last, Out d_last) {
  while (first != last)
    *--d_last = *--last;
  return d_last;
}

// move / move_backward
template <typename In, typename Out>
constexpr Out move(In first, In last, Out d_first) {
  for (; first != last; ++first) {
    *d_first = static_cast<remove_reference_t<decltype(*first)>&&>(*first);
    ++d_first;
  }
  return d_first;
}
template <typename In, typename Out>
constexpr Out move_backward(In first, In last, Out d_last) {
  while (first != last)
    *--d_last = static_cast<remove_reference_t<decltype(*first)>&&>(*--last);
  return d_last;
}

// fill / fill_n
template <typename It, typename T>
constexpr void fill(It first, It last, const T& value) {
  for (; first != last; ++first)
    *first = value;
}
template <typename It, typename Size, typename T>
constexpr It fill_n(It first, Size n, const T& value) {
  for (Size i = 0; i < n; ++i) {
    *first = value;
    ++first;
  }
  return first;
}

// transform
template <typename In, typename Out, typename UnaryOp>
constexpr Out transform(In first, In last, Out d_first, UnaryOp op) {
  for (; first != last; ++first) {
    *d_first = op(*first);
    ++d_first;
  }
  return d_first;
}
template <typename In1, typename In2, typename Out, typename BinOp>
constexpr Out transform(In1 first1, In1 last1, In2 first2, Out d_first,
                        BinOp op) {
  for (; first1 != last1; ++first1) {
    *d_first = op(*first1, *first2);
    ++first2;
    ++d_first;
  }
  return d_first;
}

// generate / generate_n
template <typename It, typename Gen>
constexpr void generate(It first, It last, Gen g) {
  for (; first != last; ++first)
    *first = g();
}
template <typename It, typename Size, typename Gen>
constexpr It generate_n(It first, Size n, Gen g) {
  for (Size i = 0; i < n; ++i) {
    *first = g();
    ++first;
  }
  return first;
}

// remove / remove_if / remove_copy / remove_copy_if
template <typename It, typename T>
constexpr It remove(It first, It last, const T& value) {
  first = find(first, last, value);
  if (first == last)
    return first;
  It out = first;
  ++first;
  for (; first != last; ++first)
    if (!(*first == value)) {
      *out = static_cast<decltype(*first)&&>(*first);
      ++out;
    }
  return out;
}
template <typename It, typename Pred>
constexpr It remove_if(It first, It last, Pred pred) {
  first = find_if(first, last, pred);
  if (first == last)
    return first;
  It out = first;
  ++first;
  for (; first != last; ++first)
    if (!pred(*first)) {
      *out = static_cast<decltype(*first)&&>(*first);
      ++out;
    }
  return out;
}
template <typename In, typename Out, typename T>
constexpr Out remove_copy(In first, In last, Out d_first, const T& value) {
  for (; first != last; ++first)
    if (!(*first == value)) {
      *d_first = *first;
      ++d_first;
    }
  return d_first;
}
template <typename In, typename Out, typename Pred>
constexpr Out remove_copy_if(In first, In last, Out d_first, Pred pred) {
  for (; first != last; ++first)
    if (!pred(*first)) {
      *d_first = *first;
      ++d_first;
    }
  return d_first;
}

// replace / replace_if
template <typename It, typename T>
constexpr void replace(It first, It last, const T& old_v, const T& new_v) {
  for (; first != last; ++first)
    if (*first == old_v)
      *first = new_v;
}
template <typename It, typename Pred, typename T>
constexpr void replace_if(It first, It last, Pred pred, const T& new_v) {
  for (; first != last; ++first)
    if (pred(*first))
      *first = new_v;
}

// unique / unique_copy
template <typename It> constexpr It unique(It first, It last) {
  if (first == last)
    return last;
  It result = first;
  while (++first != last)
    if (!(*result == *first)) {
      ++result;
      *result = static_cast<decltype(*first)&&>(*first);
    }
  return ++result;
}
template <typename It, typename BinPred>
constexpr It unique(It first, It last, BinPred pred) {
  if (first == last)
    return last;
  It result = first;
  while (++first != last)
    if (!pred(*result, *first)) {
      ++result;
      *result = static_cast<decltype(*first)&&>(*first);
    }
  return ++result;
}

// reverse / reverse_copy
template <typename It> constexpr void reverse(It first, It last) {
  while (first != last && first != --last)
    iter_swap(first++, last);
}
template <typename In, typename Out>
constexpr Out reverse_copy(In first, In last, Out d_first) {
  while (first != last) {
    *d_first++ = *--last;
  }
  return d_first;
}

// rotate
template <typename It> constexpr It rotate(It first, It n_first, It last) {
  if (first == n_first)
    return last;
  if (n_first == last)
    return first;
  reverse(first, n_first);
  reverse(n_first, last);
  reverse(first, last);
  // compute new middle
  It result = first;
  for (It it = n_first; it != last; ++it) {
    ++result;
  }
  return result;
}

// equal
template <typename It1, typename It2>
constexpr bool equal(It1 first1, It1 last1, It2 first2) {
  for (; first1 != last1; ++first1) {
    if (!(*first1 == *first2))
      return false;
    ++first2;
  }
  return true;
}
template <typename It1, typename It2, typename BinPred>
constexpr bool equal(It1 first1, It1 last1, It2 first2, BinPred pred) {
  for (; first1 != last1; ++first1) {
    if (!pred(*first1, *first2))
      return false;
    ++first2;
  }
  return true;
}
template <typename It1, typename It2>
constexpr bool equal(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (; first1 != last1 && first2 != last2; ++first1) {
    if (!(*first1 == *first2))
      return false;
    ++first2;
  }
  return first1 == last1 && first2 == last2;
}

template <typename It1, typename It2, typename BinPred>
constexpr bool equal(It1 first1, It1 last1, It2 first2, It2 last2,
                     BinPred pred) {
  for (; first1 != last1 && first2 != last2; ++first1) {
    if (!pred(*first1, *first2))
      return false;
    ++first2;
  }
  return first1 == last1 && first2 == last2;
}

// mismatch
template <typename It1, typename It2>
pair<It1, It2> mismatch(It1 first1, It1 last1, It2 first2) {
  for (; first1 != last1 && *first1 == *first2; ++first1) {
    ++first2;
  }
  return {first1, first2};
}
template <typename It1, typename It2>
pair<It1, It2> mismatch(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (; first1 != last1 && first2 != last2 && *first1 == *first2; ++first1) {
    ++first2;
  }
  return {first1, first2};
}

// lexicographical_compare
template <typename It1, typename It2>
constexpr bool lexicographical_compare(It1 first1, It1 last1, It2 first2,
                                       It2 last2) {
  for (; first2 != last2; ++first2) {
    if (first1 == last1 || *first1 < *first2)
      return true;
    if (*first2 < *first1)
      return false;
    ++first1;
  }
  return false;
}
template <typename It1, typename It2, typename Compare>
constexpr bool lexicographical_compare(It1 first1, It1 last1, It2 first2,
                                       It2 last2, Compare cmp) {
  for (; first2 != last2; ++first2) {
    if (first1 == last1 || cmp(*first1, *first2))
      return true;
    if (cmp(*first2, *first1))
      return false;
    ++first1;
  }
  return false;
}

// lower_bound / upper_bound / binary_search / equal_range
template <typename It, typename T>
constexpr It lower_bound(It first, It last, const T& value) {
  auto n = last - first;
  while (n > 0) {
    auto half = n / 2;
    It mid = first + half;
    if (*mid < value) {
      first = mid + 1;
      n -= half + 1;
    } else
      n = half;
  }
  return first;
}
template <typename It, typename T, typename Compare>
constexpr It lower_bound(It first, It last, const T& value, Compare cmp) {
  auto n = last - first;
  while (n > 0) {
    auto half = n / 2;
    It mid = first + half;
    if (cmp(*mid, value)) {
      first = mid + 1;
      n -= half + 1;
    } else
      n = half;
  }
  return first;
}
template <typename It, typename T>
constexpr It upper_bound(It first, It last, const T& value) {
  auto n = last - first;
  while (n > 0) {
    auto half = n / 2;
    It mid = first + half;
    if (!(value < *mid)) {
      first = mid + 1;
      n -= half + 1;
    } else
      n = half;
  }
  return first;
}
template <typename It, typename T, typename Compare>
constexpr It upper_bound(It first, It last, const T& value, Compare cmp) {
  auto n = last - first;
  while (n > 0) {
    auto half = n / 2;
    It mid = first + half;
    if (!cmp(value, *mid)) {
      first = mid + 1;
      n -= half + 1;
    } else
      n = half;
  }
  return first;
}
template <typename It, typename T>
constexpr bool binary_search(It first, It last, const T& value) {
  first = lower_bound(first, last, value);
  return first != last && !(value < *first);
}
template <typename It, typename T, typename Compare>
constexpr bool binary_search(It first, It last, const T& value, Compare cmp) {
  first = lower_bound(first, last, value, cmp);
  return first != last && !cmp(value, *first);
}
template <typename It, typename T>
pair<It, It> equal_range(It first, It last, const T& value) {
  return {lower_bound(first, last, value), upper_bound(first, last, value)};
}
template <typename It, typename T, typename Compare>
pair<It, It> equal_range(It first, It last, const T& value, Compare cmp) {
  return {lower_bound(first, last, value, cmp),
          upper_bound(first, last, value, cmp)};
}

// is_sorted / is_sorted_until
template <typename It> constexpr bool is_sorted(It first, It last) {
  if (first == last)
    return true;
  for (It next = first; ++next != last; first = next)
    if (*next < *first)
      return false;
  return true;
}
template <typename It, typename Compare>
constexpr bool is_sorted(It first, It last, Compare cmp) {
  if (first == last)
    return true;
  for (It next = first; ++next != last; first = next)
    if (cmp(*next, *first))
      return false;
  return true;
}

// sort — a plain heapsort, on purpose. Still O(N log N) worst case, but ~2.5x
// cheaper to instantiate than an introsort (one algorithm, not quicksort +
// median-of-3 + insertion + heapsort fallback). The price is a larger runtime
// constant, which this library trades away for compile speed.
namespace detail {
template <typename It, typename Compare>
void heap_sift(It first, ptrdiff_t root, ptrdiff_t n, Compare cmp) {
  for (;;) {
    ptrdiff_t child = 2 * root + 1;
    if (child >= n)
      break;
    if (child + 1 < n && cmp(*(first + child), *(first + child + 1)))
      ++child;
    if (!cmp(*(first + root), *(first + child)))
      break;
    iter_swap(first + root, first + child);
    root = child;
  }
}
template <typename It, typename Compare>
void heap_sort(It first, It last, Compare cmp) {
  ptrdiff_t n = last - first;
  for (ptrdiff_t start = n / 2; start-- > 0;)
    heap_sift(first, start, n, cmp);
  for (ptrdiff_t end = n; --end > 0;) {
    iter_swap(first, first + end);
    heap_sift(first, 0, end, cmp);
  }
}

// Three-way quickselect. Keeping values equivalent to the pivot together
// avoids quadratic behaviour for duplicate-heavy ranges.
template <typename It, typename Compare>
constexpr void select_nth(It first, It nth, It last, Compare cmp) {
  while (first != last && nth != last) {
    auto count = last - first;
    if (count < 2)
      return;

    It pivot = last - 1;
    iter_swap(first + count / 2, pivot);

    It less = first;
    for (It it = first; it != pivot; ++it) {
      if (cmp(*it, *pivot)) {
        if (it != less)
          iter_swap(it, less);
        ++less;
      }
    }
    iter_swap(less, pivot);

    It equal_end = less + 1;
    for (It it = equal_end; it != last; ++it) {
      // The first partition established !cmp(*it, *less), so this is
      // equivalent to testing equality under the strict weak ordering.
      if (!cmp(*less, *it)) {
        if (it != equal_end)
          iter_swap(it, equal_end);
        ++equal_end;
      }
    }

    if (nth < less)
      last = less;
    else if (nth >= equal_end)
      first = equal_end;
    else
      return;
  }
}
} // namespace detail

template <typename It> constexpr void sort(It first, It last) {
  if (last - first > 1)
    detail::heap_sort(first, last,
                      [](const auto& a, const auto& b) { return a < b; });
}
template <typename It, typename Compare>
constexpr void sort(It first, It last, Compare cmp) {
  if (last - first > 1)
    detail::heap_sort(first, last, cmp);
}

template <typename It> constexpr void stable_sort(It first, It last) {
  sort(first, last);
}
template <typename It, typename Compare>
constexpr void stable_sort(It first, It last, Compare cmp) {
  sort(first, last, cmp);
}

// partial_sort (simple: full sort then done)
template <typename It>
constexpr void partial_sort(It first, It middle, It last) {
  sort(first, last);
  (void)middle;
}
template <typename It, typename Compare>
constexpr void partial_sort(It first, It middle, It last, Compare cmp) {
  sort(first, last, cmp);
  (void)middle;
}

// nth_element
template <typename It> constexpr void nth_element(It first, It nth, It last) {
  detail::select_nth(first, nth, last,
                     [](const auto& a, const auto& b) { return a < b; });
}
template <typename It, typename Compare>
constexpr void nth_element(It first, It nth, It last, Compare cmp) {
  detail::select_nth(first, nth, last, cmp);
}

// partition
template <typename It, typename Pred>
constexpr It partition(It first, It last, Pred pred) {
  first = find_if_not(first, last, pred);
  if (first == last)
    return first;
  for (It i = first + 1; i != last; ++i)
    if (pred(*i)) {
      iter_swap(i, first);
      ++first;
    }
  return first;
}

// merge
template <typename In1, typename In2, typename Out>
constexpr Out merge(In1 first1, In1 last1, In2 first2, In2 last2, Out d_first) {
  for (; first1 != last1 && first2 != last2; ++d_first) {
    if (*first2 < *first1)
      *d_first = *first2++;
    else
      *d_first = *first1++;
  }
  d_first = copy(first1, last1, d_first);
  return copy(first2, last2, d_first);
}

// includes / set operations
template <typename It1, typename It2>
constexpr bool includes(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (; first2 != last2; ++first2) {
    first1 = lower_bound(first1, last1, *first2);
    if (first1 == last1 || *first2 < *first1)
      return false;
    ++first1;
  }
  return true;
}

// max_element / min_element / minmax_element
template <typename It> constexpr It max_element(It first, It last) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (*result < *first)
      result = first;
  return result;
}
template <typename It, typename Compare>
constexpr It max_element(It first, It last, Compare cmp) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (cmp(*result, *first))
      result = first;
  return result;
}
template <typename It> constexpr It min_element(It first, It last) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (*first < *result)
      result = first;
  return result;
}
template <typename It, typename Compare>
constexpr It min_element(It first, It last, Compare cmp) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (cmp(*first, *result))
      result = first;
  return result;
}
template <typename It> pair<It, It> minmax_element(It first, It last) {
  return {min_element(first, last), max_element(first, last)};
}

// search / search_n
template <typename It1, typename It2>
constexpr It1 search(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (;; ++first1) {
    It1 it = first1;
    for (It2 it2 = first2;; ++it2) {
      if (it2 == last2)
        return first1;
      if (it == last1)
        return last1;
      if (!(*it == *it2))
        break;
      ++it;
    }
  }
}

// adjacent_find
template <typename It> constexpr It adjacent_find(It first, It last) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (*first == *next)
      return first;
  return last;
}
template <typename It, typename BinaryPredicate>
constexpr It adjacent_find(It first, It last, BinaryPredicate pred) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (pred(*first, *next))
      return first;
  return last;
}

