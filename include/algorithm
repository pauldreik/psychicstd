// sort — a plain heapsort, on purpose. Still O(N log N) worst case, but ~2.5x
// cheaper to instantiate than an introsort (one algorithm, not quicksort +
// median-of-3 + insertion + heapsort fallback). The price is a larger runtime
// constant, which this library trades away for compile speed.
namespace detail {
template <typename It, typename Compare>
void heap_sift(It first, ptrdiff_t root, ptrdiff_t n, Compare cmp) {
  for (;;) {
    ptrdiff_t child = 2 * root + 1;
    if (child >= n)
      break;
    if (child + 1 < n && cmp(*(first + child), *(first + child + 1)))
      ++child;
    if (!cmp(*(first + root), *(first + child)))
      break;
    iter_swap(first + root, first + child);
    root = child;
  }
}
template <typename It, typename Compare>
void heap_sort(It first, It last, Compare cmp) {
  ptrdiff_t n = last - first;
  for (ptrdiff_t start = n / 2; start-- > 0;)
    heap_sift(first, start, n, cmp);
  for (ptrdiff_t end = n; --end > 0;) {
    iter_swap(first, first + end);
    heap_sift(first, 0, end, cmp);
  }
}

// Three-way quickselect. Keeping values equivalent to the pivot together
// avoids quadratic behaviour for duplicate-heavy ranges.
template <typename It, typename Compare>
constexpr void select_nth(It first, It nth, It last, Compare cmp) {
  while (first != last && nth != last) {
    auto count = last - first;
    if (count < 2)
      return;

    It pivot = last - 1;
    iter_swap(first + count / 2, pivot);

    It less = first;
    for (It it = first; it != pivot; ++it) {
      if (cmp(*it, *pivot)) {
        if (it != less)
          iter_swap(it, less);
        ++less;
      }
    }
    iter_swap(less, pivot);

    It equal_end = less + 1;
    for (It it = equal_end; it != last; ++it) {
      // The first partition established !cmp(*it, *less), so this is
      // equivalent to testing equality under the strict weak ordering.
      if (!cmp(*less, *it)) {
        if (it != equal_end)
          iter_swap(it, equal_end);
        ++equal_end;
      }
    }

    if (nth < less)
      last = less;
    else if (nth >= equal_end)
      first = equal_end;
    else
      return;
  }
}
} // namespace detail

template <typename It> constexpr void sort(It first, It last) {
  if (last - first > 1)
    detail::heap_sort(first, last,
                      [](const auto& a, const auto& b) { return a < b; });
}
template <typename It, typename Compare>
constexpr void sort(It first, It last, Compare cmp) {
  if (last - first > 1)
    detail::heap_sort(first, last, cmp);
}

template <typename It> constexpr void stable_sort(It first, It last) {
  stable_sort(first, last,
              [](const auto& a, const auto& b) { return a < b; });
}
template <typename It, typename Compare>
constexpr void stable_sort(It first, It last, Compare cmp) {
  // Insertion sort is deliberately used here: it is stable, works with
  // move-only values, and keeps this header's implementation small.
  if (first == last)
    return;
  for (It current = first + 1; current != last; ++current) {
    It position = current;
    while (position != first) {
      It previous = position - 1;
      if (!cmp(*position, *previous))
        break;
      iter_swap(position, previous);
      position = previous;
    }
  }
}

// partial_sort (simple: full sort then done)
template <typename It>
constexpr void partial_sort(It first, It middle, It last) {
  sort(first, last);
  (void)middle;
}
template <typename It, typename Compare>
constexpr void partial_sort(It first, It middle, It last, Compare cmp) {
  sort(first, last, cmp);
  (void)middle;
}

template <typename In, typename Out>
constexpr Out partial_sort_copy(In first, In last, Out d_first, Out d_last) {
  return partial_sort_copy(first, last, d_first, d_last,
                           [](const auto& a, const auto& b) { return a < b; });
}
template <typename In, typename Out, typename Compare>
constexpr Out partial_sort_copy(In first, In last, Out d_first, Out d_last,
                                Compare cmp) {
  if (d_first == d_last)
    return d_first;
  Out out = d_first;
  for (; first != last && out != d_last; ++first) {
    *out = *first;
    ++out;
  }
  if (out == d_first)
    return d_first;
  make_heap(d_first, out, cmp);
  for (; first != last; ++first) {
    if (cmp(*first, *d_first)) {
      pop_heap(d_first, out, cmp);
      *(out - 1) = *first;
      push_heap(d_first, out, cmp);
    }
  }
  sort_heap(d_first, out, cmp);
  return out;
}

// nth_element
template <typename It> constexpr void nth_element(It first, It nth, It last) {
  detail::select_nth(first, nth, last,
                     [](const auto& a, const auto& b) { return a < b; });
}
template <typename It, typename Compare>
constexpr void nth_element(It first, It nth, It last, Compare cmp) {
  detail::select_nth(first, nth, last, cmp);
}

// partition
template <typename It, typename Pred>
constexpr It partition(It first, It last, Pred pred) {
  first = find_if_not(first, last, pred);
  if (first == last)
    return first;
  for (It i = first + 1; i != last; ++i)
    if (pred(*i)) {
      iter_swap(i, first);
      ++first;
    }
  return first;
}

// merge
template <typename In1, typename In2, typename Out>
constexpr Out merge(In1 first1, In1 last1, In2 first2, In2 last2, Out d_first) {
  for (; first1 != last1 && first2 != last2; ++d_first) {
    if (*first2 < *first1)
      *d_first = *first2++;
    else
      *d_first = *first1++;
  }
  d_first = copy(first1, last1, d_first);
  return copy(first2, last2, d_first);
}

// includes / set operations
template <typename It1, typename It2>
constexpr bool includes(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (; first2 != last2; ++first2) {
    first1 = lower_bound(first1, last1, *first2);
    if (first1 == last1 || *first2 < *first1)
      return false;
    ++first1;
  }
  return true;
}

// max_element / min_element / minmax_element
template <typename It> constexpr It max_element(It first, It last) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (*result < *first)
      result = first;
  return result;
}
template <typename It, typename Compare>
constexpr It max_element(It first, It last, Compare cmp) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (cmp(*result, *first))
      result = first;
  return result;
}
template <typename It> constexpr It min_element(It first, It last) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (*first < *result)
      result = first;
  return result;
}
template <typename It, typename Compare>
constexpr It min_element(It first, It last, Compare cmp) {
  if (first == last)
    return last;
  It result = first;
  for (++first; first != last; ++first)
    if (cmp(*first, *result))
      result = first;
  return result;
}
template <typename It> pair<It, It> minmax_element(It first, It last) {
  return {min_element(first, last), max_element(first, last)};
}

// search / search_n
template <typename It1, typename It2>
constexpr It1 search(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (;; ++first1) {
    It1 it = first1;
    for (It2 it2 = first2;; ++it2) {
      if (it2 == last2)
        return first1;
      if (it == last1)
        return last1;
      if (!(*it == *it2))
        break;
      ++it;
    }
  }
}

// adjacent_find
template <typename It> constexpr It adjacent_find(It first, It last) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (*first == *next)
      return first;
  return last;
}
template <typename It, typename BinaryPredicate>
constexpr It adjacent_find(It first, It last, BinaryPredicate pred) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (pred(*first, *next))
      return first;
  return last;
}

