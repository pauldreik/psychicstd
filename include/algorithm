// inplace_merge
template <typename It>
constexpr void inplace_merge(It first, It middle, It last) {
  // simple O(n) extra space implementation
  // fall back to rotate-based in-place
  if (first == middle || middle == last)
    return;
  It first2 = middle;
  while (first != middle && first2 != last) {
    if (*first2 < *first) {
      // rotate *first2 into position
      rotate(first, first2, first2 + 1);
      ++first;
      ++middle;
      ++first2;
    } else {
      ++first;
    }
  }
}
template <typename It, typename Compare>
constexpr void inplace_merge(It first, It middle, It last, Compare cmp) {
  if (first == middle || middle == last)
    return;
  It first2 = middle;
  while (first != middle && first2 != last) {
    if (cmp(*first2, *first)) {
      rotate(first, first2, first2 + 1);
      ++first;
      ++middle;
      ++first2;
    } else {
      ++first;
    }
  }
}

// next_permutation
template <typename BidirIt>
constexpr bool next_permutation(BidirIt first, BidirIt last) {
  if (first == last || first == --last)
    return false;
  BidirIt it = last;
  while (true) {
    BidirIt it1 = it;
    if (*--it < *it1) {
      BidirIt it2 = last;
      while (!(*it < *it2))
        --it2;
      swap(*it, *it2);
      reverse(it1, ++last);
      return true;
    }
    if (it == first) {
      reverse(first, ++last);
      return false;
    }
  }
}
template <typename BidirIt, typename Compare>
constexpr bool next_permutation(BidirIt first, BidirIt last, Compare cmp) {
  if (first == last || first == --last)
    return false;
  BidirIt it = last;
  while (true) {
    BidirIt it1 = it;
    if (cmp(*--it, *it1)) {
      BidirIt it2 = last;
      while (!cmp(*it, *it2))
        --it2;
      swap(*it, *it2);
      reverse(it1, ++last);
      return true;
    }
    if (it == first) {
      reverse(first, ++last);
      return false;
    }
  }
}

template <typename BidirIt>
constexpr bool prev_permutation(BidirIt first, BidirIt last) {
  return prev_permutation(first, last,
                          [](const auto& a, const auto& b) { return a < b; });
}
template <typename BidirIt, typename Compare>
constexpr bool prev_permutation(BidirIt first, BidirIt last, Compare cmp) {
  if (first == last || first == --last)
    return false;
  BidirIt it = last;
  while (true) {
    BidirIt it1 = it;
    if (cmp(*it1, *--it)) {
      BidirIt it2 = last;
      while (!cmp(*it2, *it))
        --it2;
      swap(*it, *it2);
      reverse(it1, ++last);
      return true;
    }
    if (it == first) {
      reverse(first, ++last);
      return false;
    }
  }
}

template <typename RandomIt, typename URBG>
void shuffle(RandomIt first, RandomIt last, URBG&& g) {
  if (first == last)
    return;
  for (auto i = last - first; i > 1; --i) {
    auto offset = static_cast<decltype(i)>(g() % i);
    iter_swap(first + (i - 1), first + offset);
  }
}

template <typename In, typename Out, typename Distance, typename URBG>
Out sample(In first, In last, Out out, Distance n, URBG&& g) {
  auto remaining = distance(first, last);
  if (n <= 0)
    return out;
  for (; first != last && n > 0; ++first, --remaining) {
    if (g() % remaining < n) {
      *out++ = *first;
      --n;
    }
  }
  return out;
}

// is_permutation
template <typename It1, typename It2>
constexpr bool is_permutation(It1 first1, It1 last1, It2 first2) {
  // skip matching prefix
  for (; first1 != last1; ++first1) {
    if (!(*first1 == *first2))
      break;
    ++first2;
  }
  if (first1 == last1)
    return true;
  It2 last2 = first2;
  for (auto it = first1; it != last1; ++it)
    ++last2;
  for (auto it = first1; it != last1; ++it) {
    // already counted?
    bool seen = false;
    for (auto jt = first1; jt != it; ++jt)
      if (*jt == *it) {
        seen = true;
        break;
      }
    if (seen)
      continue;
    // count occurrences in each range
    auto c1 = count(it, last1, *it);
    auto c2 = count(first2, last2, *it);
    if (c1 != c2)
      return false;
  }
  return true;
}
template <typename It1, typename It2, typename BinaryPredicate>
constexpr bool is_permutation(It1, It1, It2, It2, BinaryPredicate);

template <typename It1, typename It2>
constexpr bool is_permutation(It1 first1, It1 last1, It2 first2, It2 last2) {
  return is_permutation(first1, last1, first2, last2,
                        [](const auto& a, const auto& b) { return a == b; });
}
template <typename It1, typename It2, typename BinaryPredicate>
constexpr bool is_permutation(It1 first1, It1 last1, It2 first2, It2 last2,
                              BinaryPredicate pred) {
  if (distance(first1, last1) != distance(first2, last2))
    return false;
  for (; first1 != last1 && pred(*first1, *first2); ++first1, ++first2)
    ;
  if (first1 == last1)
    return true;
  for (auto it = first1; it != last1; ++it) {
    bool seen = false;
    for (auto jt = first1; jt != it; ++jt)
      if (pred(*jt, *it)) {
        seen = true;
        break;
      }
    if (seen)
      continue;
    auto eq = [&](const auto& x) { return pred(*it, x); };
    auto c1 = count_if(it, last1, eq);
    auto c2 = count_if(first2, last2, eq);
    if (c1 != c2)
      return false;
  }
  return true;
}

// set_union / set_intersection / set_difference / set_symmetric_difference
template <typename It1, typename It2, typename OutIt>
constexpr OutIt set_union(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      *out++ = *f1++;
    else if (*f2 < *f1)
      *out++ = *f2++;
    else {
      *out++ = *f1++;
      ++f2;
    }
  }
  out = copy(f1, l1, out);
  return copy(f2, l2, out);
}
template <typename It1, typename It2, typename OutIt, typename Compare>
constexpr OutIt set_union(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out,
                          Compare cmp) {
  while (f1 != l1 && f2 != l2) {
    if (cmp(*f1, *f2))
      *out++ = *f1++;
    else if (cmp(*f2, *f1))
      *out++ = *f2++;
    else {
      *out++ = *f1++;
      ++f2;
    }
  }
  out = copy(f1, l1, out);
  return copy(f2, l2, out);
}

template <typename It1, typename It2, typename OutIt>
constexpr OutIt set_intersection(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      ++f1;
    else if (*f2 < *f1)
      ++f2;
    else {
      *out++ = *f1++;
      ++f2;
    }
  }
  return out;
}
template <typename It1, typename It2, typename OutIt, typename Compare>
constexpr OutIt set_intersection(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out,
                                 Compare cmp) {
  while (f1 != l1 && f2 != l2) {
    if (cmp(*f1, *f2))
      ++f1;
    else if (cmp(*f2, *f1))
      ++f2;
    else {
      *out++ = *f1++;
      ++f2;
    }
  }
  return out;
}

template <typename It1, typename It2, typename OutIt>
constexpr OutIt set_difference(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      *out++ = *f1++;
    else if (*f2 < *f1)
      ++f2;
    else {
      ++f1;
      ++f2;
    }
  }
  return copy(f1, l1, out);
}
template <typename It1, typename It2, typename OutIt, typename Compare>
constexpr OutIt set_difference(It1 f1, It1 l1, It2 f2, It2 l2, OutIt out,
                               Compare cmp) {
  while (f1 != l1 && f2 != l2) {
    if (cmp(*f1, *f2))
      *out++ = *f1++;
    else if (cmp(*f2, *f1))
      ++f2;
    else {
      ++f1;
      ++f2;
    }
  }
  return copy(f1, l1, out);
}

template <typename It1, typename It2, typename OutIt>
constexpr OutIt set_symmetric_difference(It1 f1, It1 l1, It2 f2, It2 l2,
                                         OutIt out) {
  while (f1 != l1 && f2 != l2) {
    if (*f1 < *f2)
      *out++ = *f1++;
    else if (*f2 < *f1)
      *out++ = *f2++;
    else {
      ++f1;
      ++f2;
    }
  }
  out = copy(f1, l1, out);
  return copy(f2, l2, out);
}
template <typename It1, typename It2, typename OutIt, typename Compare>
