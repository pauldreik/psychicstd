}

// search / search_n
template <typename It1, typename It2>
constexpr It1 search(It1 first1, It1 last1, It2 first2, It2 last2) {
  for (;; ++first1) {
    It1 it = first1;
    for (It2 it2 = first2;; ++it2) {
      if (it2 == last2)
        return first1;
      if (it == last1)
        return last1;
      if (!(*it == *it2))
        break;
      ++it;
    }
  }
}

template <typename It1, typename It2, typename Pred>
constexpr It1 search(It1 first1, It1 last1, It2 first2, It2 last2, Pred pred) {
  for (;; ++first1) {
    It1 it = first1;
    for (It2 it2 = first2;; ++it2) {
      if (it2 == last2)
        return first1;
      if (it == last1)
        return last1;
      if (!pred(*it, *it2))
        break;
      ++it;
    }
  }
}

template <typename It1, typename It2>
constexpr It1 find_end(It1 first1, It1 last1, It2 first2, It2 last2) {
  return find_end(first1, last1, first2, last2,
                  [](const auto& a, const auto& b) { return a == b; });
}
template <typename It1, typename It2, typename Pred>
constexpr It1 find_end(It1 first1, It1 last1, It2 first2, It2 last2,
                       Pred pred) {
  if (first2 == last2)
    return last1;
  It1 result = last1;
  for (; first1 != last1;) {
    It1 candidate = search(first1, last1, first2, last2, pred);
    if (candidate == last1)
      break;
    result = candidate;
    first1 = candidate;
    ++first1;
  }
  return result;
}

template <typename It, typename Size, typename T>
constexpr It search_n(It first, It last, Size count, const T& value) {
  return search_n(first, last, count, value,
                  [](const auto& a, const auto& b) { return a == b; });
}
template <typename It, typename Size, typename T, typename Pred>
constexpr It search_n(It first, It last, Size count, const T& value,
                      Pred pred) {
  if (count <= 0)
    return first;
  for (; first != last; ++first) {
    if (!pred(*first, value))
      continue;
    It candidate = first;
    Size matched = 0;
    for (; candidate != last && matched < count; ++candidate, ++matched)
      if (!pred(*candidate, value))
        break;
    if (matched == count)
      return first;
    if (candidate == last)
      return last;
  }
  return last;
}

template <typename In, typename Out, typename T>
constexpr Out replace_copy(In first, In last, Out out, const T& old_value,
                           const T& new_value) {
  for (; first != last; ++first, ++out)
    *out = *first == old_value ? new_value : *first;
  return out;
}
template <typename In, typename Out, typename Pred, typename T>
constexpr Out replace_copy_if(In first, In last, Out out, Pred pred,
                              const T& new_value) {
  for (; first != last; ++first, ++out)
    *out = pred(*first) ? new_value : *first;
  return out;
}

template <typename In, typename Out>
constexpr Out unique_copy(In first, In last, Out out) {
  return unique_copy(first, last, out,
                     [](const auto& a, const auto& b) { return a == b; });
}
template <typename In, typename Out, typename Pred>
constexpr Out unique_copy(In first, In last, Out out, Pred pred) {
  if (first == last)
    return out;
  auto value = *first++;
  *out++ = value;
  for (; first != last; ++first) {
    if (pred(value, *first))
      continue;
    value = *first;
    *out++ = value;
  }
  return out;
}

template <typename In, typename Out>
constexpr Out rotate_copy(In first, In middle, In last, Out out) {
  out = copy(middle, last, out);
  return copy(first, middle, out);
}

// adjacent_find
template <typename It> constexpr It adjacent_find(It first, It last) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (*first == *next)
      return first;
  return last;
}
template <typename It, typename BinaryPredicate>
constexpr It adjacent_find(It first, It last, BinaryPredicate pred) {
  if (first == last)
    return last;
  for (It next = first; ++next != last; first = next)
    if (pred(*first, *next))
      return first;
  return last;
}

