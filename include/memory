template <typename T, typename... Args>
unique_ptr<T> make_unique(Args&&... args)
    // Constrained per [unique.ptr.create]; without this, make_unique<T[]>(n)
    // prefers the exact-match variadic overload and hard-errors on new T(...).
  requires(!is_array_v<T>)
{
  // forward
  return unique_ptr<T>(new T(static_cast<Args&&>(args)...));
}
template <typename T>
unique_ptr<T> make_unique(size_t n)
  requires(is_array_v<T>)
{
  using Elem = remove_extent_t<T>;
  return unique_ptr<T>(new Elem[n]());
}

// Control block for shared_ptr.  Defined outside the template so that
// shared_ptr<T>::ctrl_ and shared_ptr<U>::ctrl_ have the same type; this
// allows the converting constructors to copy ctrl_ directly without casts.
namespace __detail {
struct __sp_ctrl {
  long count = 1;
  // One implicit weak reference keeps the control block alive while strong
  // owners exist. Explicit weak users add to this count.
  long weak_count = 1;
  virtual void destroy() noexcept = 0;
  virtual void* get_deleter(const type_info&) noexcept { return nullptr; }
  virtual ~__sp_ctrl() = default;
};
inline void __sp_weak_add(__sp_ctrl* ctrl) noexcept {
  __atomic_add_fetch(&ctrl->weak_count, 1, __ATOMIC_RELAXED);
}
inline void __sp_weak_release(__sp_ctrl* ctrl) noexcept {
  if (__atomic_sub_fetch(&ctrl->weak_count, 1, __ATOMIC_ACQ_REL) == 0)
    delete ctrl;
}
inline bool __sp_strong_add_if_live(__sp_ctrl* ctrl) noexcept {
  long count = __atomic_load_n(&ctrl->count, __ATOMIC_RELAXED);
  while (count != 0) {
    if (__atomic_compare_exchange_n(&ctrl->count, &count, count + 1, true,
                                    __ATOMIC_RELAXED, __ATOMIC_RELAXED))
      return true;
  }
  return false;
}
template <typename U> struct __sp_ctrl_impl : __sp_ctrl {
  U* obj;
  explicit __sp_ctrl_impl(U* p) : obj(p) {}
  void destroy() noexcept override { delete obj; }
};
template <typename U, typename D> struct __sp_ctrl_del : __sp_ctrl {
  U* obj;
  D del;
  template <typename E>
  __sp_ctrl_del(U* p, E&& d) : obj(p), del(static_cast<E&&>(d)) {}
  void destroy() noexcept override { del(obj); }
  void* get_deleter(const type_info& type) noexcept override {
#if _PSYCHICSTD_HAS_RTTI
    return type == typeid(D) ? addressof(del) : nullptr;
#else
    (void)type;
    return nullptr;
#endif
  }
};

template <typename T, typename Alloc> struct __sp_alloc_del {
  Alloc alloc;
  typename allocator_traits<Alloc>::pointer allocation;

  void operator()(T* p) noexcept {
    allocator_traits<Alloc>::destroy(alloc, p);
    allocator_traits<Alloc>::deallocate(alloc, allocation, 1);
  }
};
struct __esft_tag {};
} // namespace __detail

template <typename T> class shared_ptr;

class bad_weak_ptr : public exception {
public:
  const char* what() const noexcept override { return "bad_weak_ptr"; }
};

template <typename T> class enable_shared_from_this {
  mutable __detail::__sp_ctrl* ctrl_ = nullptr;
  mutable T* ptr_ = nullptr;

  template <typename U> friend class shared_ptr;

  void __accept(__detail::__sp_ctrl* ctrl, T* ptr) const noexcept {
    if (!ctrl_ || __atomic_load_n(&ctrl_->count, __ATOMIC_RELAXED) == 0) {
      if (ctrl_)
        __detail::__sp_weak_release(ctrl_);
      ctrl_ = ctrl, ptr_ = ptr;
      __detail::__sp_weak_add(ctrl_);
    }
  }

protected:
  constexpr enable_shared_from_this() noexcept = default;
  enable_shared_from_this(const enable_shared_from_this&) noexcept {}
  enable_shared_from_this& operator=(const enable_shared_from_this&) noexcept {
    return *this;
  }
  ~enable_shared_from_this() {
    if (ctrl_)
      __detail::__sp_weak_release(ctrl_);
  }

public:
  shared_ptr<T> shared_from_this();
  shared_ptr<const T> shared_from_this() const;
};

// shared_ptr — the control-block count is atomic; individual pointer objects
// still must not be concurrently mutated.
template <typename T> class shared_ptr {
  // Allow shared_ptr<U> to read our private members directly.  Required by
  // the converting constructors and the aliasing constructor below.
  template <typename U> friend class shared_ptr;
  template <typename U> friend class enable_shared_from_this;
  template <typename D, typename U>
  friend D* get_deleter(const shared_ptr<U>&) noexcept;

  T* ptr_ = nullptr;
  __detail::__sp_ctrl* ctrl_ = nullptr;

  void inc() noexcept {
    if (ctrl_)
      __atomic_add_fetch(&ctrl_->count, 1, __ATOMIC_RELAXED);
  }
  void dec() noexcept {
    auto* ctrl = ctrl_;
    if (ctrl && __atomic_sub_fetch(&ctrl->count, 1, __ATOMIC_ACQ_REL) == 0) {
      ctrl->destroy();
      __detail::__sp_weak_release(ctrl);
      ctrl_ = nullptr;
      ptr_ = nullptr;
    }
  }

  template <typename U> void init_esft(U* p) noexcept {
    using V = remove_cv_t<U>;
    if constexpr (is_base_of_v<enable_shared_from_this<V>, V>)
      static_cast<enable_shared_from_this<V>*>(p)->__accept(ctrl_, p);
  }

  shared_ptr(__detail::__sp_ctrl* ctrl, T* ptr, __detail::__esft_tag)
      : ptr_(ptr), ctrl_(ctrl) {
    if (!ctrl_ || !__detail::__sp_strong_add_if_live(ctrl_)) {
      ptr_ = nullptr;
      ctrl_ = nullptr;
      _PSYCHICSTD_THROW(bad_weak_ptr{});
    }
  }

public:
  using element_type = T;

  constexpr shared_ptr() noexcept = default;
  constexpr shared_ptr(nullptr_t) noexcept {}

  template <typename U>
  explicit shared_ptr(U* p)
      : ptr_(p), ctrl_(new __detail::__sp_ctrl_impl<U>(p)) {
    init_esft(p);
  }
  template <typename U, typename D>
  shared_ptr(U* p, D d)
      : ptr_(p), ctrl_(new __detail::__sp_ctrl_del<U, D>(p, d)) {
    init_esft(p);
  }

  shared_ptr(const shared_ptr& o) noexcept : ptr_(o.ptr_), ctrl_(o.ctrl_) {
    inc();
  }
  shared_ptr(shared_ptr&& o) noexcept : ptr_(o.ptr_), ctrl_(o.ctrl_) {
    o.ptr_ = nullptr;
    o.ctrl_ = nullptr;
  }

  // Converting copy constructor: share the control block with o.
  // The previous implementation used reinterpret_cast<shared_ptr<T>&>(o) to
  // read ctrl_, which is strict-aliasing UB that GCC -O2 miscompiles.
  template <typename U>
  shared_ptr(const shared_ptr<U>& o) noexcept : ptr_(o.ptr_), ctrl_(o.ctrl_) {
    inc();
  }

  // Converting move constructor: transfer ownership without touching the
  // reference count.
  template <typename U>
  shared_ptr(shared_ptr<U>&& o) noexcept : ptr_(o.ptr_), ctrl_(o.ctrl_) {
    o.ptr_ = nullptr;
    o.ctrl_ = nullptr;
  }

  template <typename U, typename D> shared_ptr(unique_ptr<U, D>&& o) {
    U* owned = o.get();
    if (owned) {
      ctrl_ = new __detail::__sp_ctrl_del<U, D>(
          owned, static_cast<D&&>(o.get_deleter()));
      ptr_ = owned;
      init_esft(owned);
      o.release();
    }
  }

  // Aliasing constructor: share ownership with r but store a different pointer.
  // Used by static_pointer_cast / dynamic_pointer_cast.
  template <typename U>
  shared_ptr(const shared_ptr<U>& r, T* p) noexcept : ptr_(p), ctrl_(r.ctrl_) {
    inc();
  }

  ~shared_ptr() { dec(); }

  shared_ptr& operator=(const shared_ptr& o) noexcept {
    if (this != &o) {
      dec();
      ptr_ = o.ptr_;
      ctrl_ = o.ctrl_;
      inc();
    }
    return *this;
  }
  shared_ptr& operator=(shared_ptr&& o) noexcept {
    dec();
    ptr_ = o.ptr_;
    ctrl_ = o.ctrl_;
    o.ptr_ = nullptr;
    o.ctrl_ = nullptr;
    return *this;
  }
  template <typename U, typename D>
  shared_ptr& operator=(unique_ptr<U, D>&& o) {
    shared_ptr(static_cast<unique_ptr<U, D>&&>(o)).swap(*this);
    return *this;
  }
  shared_ptr& operator=(nullptr_t) noexcept {
    dec();
    ptr_ = nullptr;
    ctrl_ = nullptr;
    return *this;
  }

  template <typename U = T>
    requires(!is_void<U>::value)
  U& operator*() const noexcept {
    return *ptr_;
  }
  T* operator->() const noexcept { return ptr_; }
  T* get() const noexcept { return ptr_; }
  explicit operator bool() const noexcept { return ptr_ != nullptr; }
  long use_count() const noexcept {
    return ctrl_ ? __atomic_load_n(&ctrl_->count, __ATOMIC_RELAXED) : 0;
  }
  bool unique() const noexcept { return use_count() == 1; }

  void reset() noexcept {
    dec();
    ptr_ = nullptr;
    ctrl_ = nullptr;
  }
  template <typename U> void reset(U* p) { shared_ptr(p).swap(*this); }
  template <typename U, typename D> void reset(U* p, D d) {
    shared_ptr(p, d).swap(*this);
  }

  void swap(shared_ptr& o) noexcept {
    T* tp = ptr_;
    __detail::__sp_ctrl* tc = ctrl_;
    ptr_ = o.ptr_;
    ctrl_ = o.ctrl_;
    o.ptr_ = tp;
    o.ctrl_ = tc;
  }

  bool owner_before(const shared_ptr& o) const noexcept {
    return ctrl_ < o.ctrl_;
  }
};

template <typename T>
shared_ptr<T> enable_shared_from_this<T>::shared_from_this() {
  return shared_ptr<T>(ctrl_, ptr_, {});
}

template <typename T>
shared_ptr<const T> enable_shared_from_this<T>::shared_from_this() const {
  return shared_ptr<const T>(ctrl_, ptr_, {});
}

template <typename D, typename T>
D* get_deleter(const shared_ptr<T>& value) noexcept {
#if _PSYCHICSTD_HAS_RTTI
  if (!value.ctrl_)
    return nullptr;
  return static_cast<D*>(value.ctrl_->get_deleter(typeid(D)));
#else
  (void)value;
  return nullptr;
#endif
}

template <typename T, typename U>
bool operator==(const shared_ptr<T>& a, const shared_ptr<U>& b) noexcept {
  return a.get() == b.get();
}
template <typename T>
bool operator==(const shared_ptr<T>& a, nullptr_t) noexcept {
  return !a;
}
template <typename T>
bool operator==(nullptr_t, const shared_ptr<T>& a) noexcept {
  return !a;
}
template <typename T, typename U>
bool operator!=(const shared_ptr<T>& a, const shared_ptr<U>& b) noexcept {
  return !(a == b);
}

template <typename T, typename... Args>
shared_ptr<T> make_shared(Args&&... args) {
  // forward
  return shared_ptr<T>(new T(static_cast<Args&&>(args)...));
}

template <typename T, typename Alloc, typename... Args>
shared_ptr<T> allocate_shared(const Alloc& alloc, Args&&... args) {
  using object_alloc =
      typename allocator_traits<Alloc>::template rebind_alloc<T>;
  object_alloc object_allocator(alloc);
  using object_pointer = typename allocator_traits<object_alloc>::pointer;
  object_pointer allocation =
      allocator_traits<object_alloc>::allocate(object_allocator, 1);
  T* object = to_address(allocation);
  _PSYCHICSTD_TRY {
    allocator_traits<object_alloc>::construct(object_allocator, object,
                                              static_cast<Args&&>(args)...);
  }
  _PSYCHICSTD_CATCH(...) {
    allocator_traits<object_alloc>::deallocate(object_allocator, allocation, 1);
    _PSYCHICSTD_RETHROW;
  }
  return shared_ptr<T>(
      object, __detail::__sp_alloc_del<T, object_alloc>{
                  static_cast<object_alloc&&>(object_allocator), allocation});
}

template <typename T, typename U>
shared_ptr<T> static_pointer_cast(const shared_ptr<U>& p) noexcept {
  return shared_ptr<T>(p, static_cast<T*>(p.get()));
}
template <typename T, typename U>
shared_ptr<T> const_pointer_cast(const shared_ptr<U>& p) noexcept {
  return shared_ptr<T>(p, const_cast<T*>(p.get()));
}
template <typename T, typename U>
shared_ptr<T> dynamic_pointer_cast(const shared_ptr<U>& p) noexcept {
  T* q = dynamic_cast<T*>(p.get());
  return q ? shared_ptr<T>(p, q) : shared_ptr<T>();
}

// weak_ptr stub (Catch2 may need this via some headers)
template <typename T> class weak_ptr {
public:
  weak_ptr() noexcept = default;
  weak_ptr(const shared_ptr<T>& sp) noexcept : ptr_(sp.get()) {}
  shared_ptr<T> lock() const noexcept {
    return ptr_ ? shared_ptr<T>(ptr_) : shared_ptr<T>();
  }
  bool expired() const noexcept { return ptr_ == nullptr; }

private:
  T* ptr_ = nullptr;
};

