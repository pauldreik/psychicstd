#pragma once
#include <__psychicstd_config>
#include <__psychicstd_except>
#include <__psychicstd_iterator_core>
#include <__psychicstd_traits_core>
#include <compare>
#include <cstddef>
#include <iosfwd>
namespace std {

template <typename Char, typename Traits = char_traits<Char>>
struct basic_string_view {
  using traits_type = Traits;
  using value_type = Char;
  using pointer = const Char*;
  using const_pointer = const Char*;
  using reference = const Char&;
  using const_reference = const Char&;
  using const_iterator = const Char*;
  using iterator = const_iterator;
  using const_reverse_iterator = std::reverse_iterator<const_iterator>;
  using reverse_iterator = const_reverse_iterator;
  using size_type = size_t;
  using difference_type = ptrdiff_t;

  static constexpr size_type npos = size_type(-1);

  constexpr basic_string_view() noexcept : data_(nullptr), size_(0) {}
  constexpr basic_string_view(const Char* s, size_type n) noexcept
      : data_(s), size_(n) {}
  constexpr basic_string_view(const Char* s) noexcept
      : data_(s), size_(_length(s)) {}
  constexpr basic_string_view(nullptr_t) = delete;

private:
  static constexpr size_type _length(const Char* s) noexcept {
    if (!s)
      return 0;
    if constexpr (__psychicstd_detail::is_same_v<Char, char>) {
      return __builtin_strlen(s);
    } else {
      size_type n = 0;
      while (s[n])
        ++n;
      return n;
    }
  }

public:
  constexpr const Char* data() const noexcept { return data_; }
  constexpr size_type size() const noexcept { return size_; }
  constexpr size_type length() const noexcept { return size_; }
  constexpr bool empty() const noexcept { return size_ == 0; }
  constexpr const Char& operator[](size_type i) const noexcept {
    return data_[i];
  }
  constexpr const Char& at(size_type i) const {
    if (i >= size_)
      _PSYCHICSTD_THROW_HELPER(__throw_out_of_range, "basic_string_view::at");
    return data_[i];
  }
  constexpr const Char& front() const noexcept { return data_[0]; }
  constexpr const Char& back() const noexcept { return data_[size_ - 1]; }

  constexpr iterator begin() const noexcept { return data_; }
  constexpr iterator end() const noexcept { return data_ + size_; }
  constexpr const_iterator cbegin() const noexcept { return begin(); }
  constexpr const_iterator cend() const noexcept { return end(); }
  constexpr reverse_iterator rbegin() const noexcept {
    return reverse_iterator(end());
  }
  constexpr reverse_iterator rend() const noexcept {
    return reverse_iterator(begin());
  }
  constexpr const_reverse_iterator crbegin() const noexcept { return rbegin(); }
  constexpr const_reverse_iterator crend() const noexcept { return rend(); }

  constexpr basic_string_view substr(size_type pos, size_type n = npos) const {
    if (pos > size_)
      _PSYCHICSTD_THROW_HELPER(__throw_out_of_range,
                               "basic_string_view::substr");
    if (n > size_ - pos)
      n = size_ - pos;
    return {data_ + pos, n};
  }

  constexpr size_type copy(Char* destination, size_type count,
                           size_type pos = 0) const {
    if (pos > size_)
      _PSYCHICSTD_THROW_HELPER(__throw_out_of_range, "basic_string_view::copy");
    if (count > size_ - pos)
      count = size_ - pos;
    for (size_type i = 0; i < count; ++i)
      destination[i] = data_[pos + i];
    return count;
  }

  constexpr size_type find(Char c, size_type pos = 0) const noexcept {
    for (size_type i = pos; i < size_; ++i)
      if (data_[i] == c)
        return i;
    return npos;
  }

  constexpr size_type find(basic_string_view sv,
                           size_type pos = 0) const noexcept {
    if (sv.size_ == 0)
      return pos <= size_ ? pos : npos;
    if (sv.size_ > size_)
      return npos;
    for (size_type i = pos; i <= size_ - sv.size_; ++i)
      if (__builtin_memcmp(data_ + i, sv.data_, sv.size_) == 0)
        return i;
    return npos;
  }
  constexpr size_type find(const Char* s, size_type pos,
                           size_type count) const noexcept {
    return find(basic_string_view(s, count), pos);
  }

  constexpr size_type rfind(Char c, size_type pos = npos) const noexcept {
    if (size_ == 0)
      return npos;
    size_type start = pos < size_ ? pos : size_ - 1;
    for (size_type i = start + 1; i-- > 0;)
      if (data_[i] == c)
        return i;
    return npos;
  }

  constexpr size_type rfind(basic_string_view sv,
                            size_type pos = npos) const noexcept {
    if (sv.size_ > size_)
      return npos;
    size_type start = pos < size_ - sv.size_ ? pos : size_ - sv.size_;
    for (size_type i = start + 1; i-- > 0;)
      if (__builtin_memcmp(data_ + i, sv.data_, sv.size_) == 0)
        return i;
    return npos;
  }
  constexpr size_type rfind(const Char* s, size_type pos,
                            size_type count) const noexcept {
    return rfind(basic_string_view(s, count), pos);
  }

  constexpr size_type find_first_of(Char c, size_type pos = 0) const noexcept {
    return find(c, pos);
  }
  constexpr size_type find_first_of(basic_string_view sv,
                                    size_type pos = 0) const noexcept {
    for (size_type i = pos; i < size_; ++i)
      if (sv.find(data_[i]) != npos)
        return i;
    return npos;
  }
  constexpr size_type find_first_of(const Char* s, size_type pos,
                                    size_type count) const noexcept {
    return find_first_of(basic_string_view(s, count), pos);
  }

  constexpr size_type find_last_of(Char c,
                                   size_type pos = npos) const noexcept {
    return rfind(c, pos);
  }
  constexpr size_type find_last_of(basic_string_view sv,
                                   size_type pos = npos) const noexcept {
    if (size_ == 0)
      return npos;
    size_type start = pos < size_ ? pos : size_ - 1;
    for (size_type i = start + 1; i-- > 0;)
      if (sv.find(data_[i]) != npos)
        return i;
    return npos;
  }
  constexpr size_type find_last_of(const Char* s, size_type pos,
                                   size_type count) const noexcept {
    return find_last_of(basic_string_view(s, count), pos);
  }

  constexpr size_type find_first_not_of(Char c,
                                        size_type pos = 0) const noexcept {
    for (size_type i = pos; i < size_; ++i)
      if (data_[i] != c)
        return i;
    return npos;
  }
  constexpr size_type find_first_not_of(basic_string_view sv,
                                        size_type pos = 0) const noexcept {
    for (size_type i = pos; i < size_; ++i)
      if (sv.find(data_[i]) == npos)
        return i;
    return npos;
  }
  constexpr size_type find_first_not_of(const Char* s, size_type pos,
                                        size_type count) const noexcept {
    return find_first_not_of(basic_string_view(s, count), pos);
  }

  constexpr size_type find_last_not_of(Char c,
                                       size_type pos = npos) const noexcept {
    if (size_ == 0)
      return npos;
    size_type start = pos < size_ ? pos : size_ - 1;
    for (size_type i = start + 1; i-- > 0;)
      if (data_[i] != c)
        return i;
    return npos;
  }
  constexpr size_type find_last_not_of(basic_string_view sv,
                                       size_type pos = npos) const noexcept {
    if (size_ == 0)
      return npos;
    size_type start = pos < size_ ? pos : size_ - 1;
    for (size_type i = start + 1; i-- > 0;)
      if (sv.find(data_[i]) == npos)
        return i;
    return npos;
  }
  constexpr size_type find_last_not_of(const Char* s, size_type pos,
                                       size_type count) const noexcept {
    return find_last_not_of(basic_string_view(s, count), pos);
  }

  constexpr int compare(basic_string_view o) const noexcept {
    size_type n = size_ < o.size_ ? size_ : o.size_;
    int r = n ? __builtin_memcmp(data_, o.data_, n) : 0;
    if (r != 0)
      return r;
    if (size_ < o.size_)
      return -1;
    if (size_ > o.size_)
      return 1;
    return 0;
  }
  constexpr int compare(size_type pos, size_type count,
                        basic_string_view o) const {
    return substr(pos, count).compare(o);
  }
  constexpr int compare(size_type pos1, size_type count1, basic_string_view o,
                        size_type pos2, size_type count2 = npos) const {
    return substr(pos1, count1).compare(o.substr(pos2, count2));
  }
  constexpr int compare(size_type pos, size_type count, const Char* s,
                        size_type count2) const {
    return substr(pos, count).compare(basic_string_view(s, count2));
  }

  constexpr bool starts_with(basic_string_view sv) const noexcept {
    return size_ >= sv.size_ &&
           (sv.size_ == 0 || __builtin_memcmp(data_, sv.data_, sv.size_) == 0);
  }
  constexpr bool ends_with(basic_string_view sv) const noexcept {
    return size_ >= sv.size_ &&
           (sv.size_ == 0 || __builtin_memcmp(data_ + size_ - sv.size_,
                                              sv.data_, sv.size_) == 0);
  }
  constexpr bool contains(basic_string_view sv) const noexcept {
    return find(sv) != npos;
  }

  constexpr void remove_prefix(size_type n) noexcept {
    data_ += n;
    size_ -= n;
  }
  constexpr void remove_suffix(size_type n) noexcept { size_ -= n; }

private:
  const Char* data_;
  size_type size_;
};

template <typename C, typename T>
constexpr bool operator==(
    basic_string_view<C, T> a,
    __psychicstd_detail::type_identity_t<basic_string_view<C, T>> b) noexcept {
  return a.size() == b.size() &&
         (a.size() == 0 || __builtin_memcmp(a.data(), b.data(), a.size()) == 0);
}
template <typename C, typename T>
constexpr auto operator<=>(
    basic_string_view<C, T> a,
    __psychicstd_detail::type_identity_t<basic_string_view<C, T>> b) noexcept {
  return a.compare(b) <=> 0;
}

using string_view = basic_string_view<char>;
using wstring_view = basic_string_view<wchar_t>;
using u8string_view = basic_string_view<char8_t>;
using u16string_view = basic_string_view<char16_t>;
using u32string_view = basic_string_view<char32_t>;

inline namespace literals {
inline namespace string_view_literals {
#pragma GCC diagnostic push
#ifdef __clang__
#pragma clang diagnostic ignored "-Wunknown-warning-option"
#pragma clang diagnostic ignored "-Wuser-defined-literals"
#endif
#pragma GCC diagnostic ignored "-Wliteral-suffix"
constexpr string_view operator""sv(const char* s, size_t n) noexcept {
  return {s, n};
}
#pragma GCC diagnostic pop
} // namespace string_view_literals
} // namespace literals

template <typename Char, typename StreamTraits, typename StringTraits>
basic_ostream<Char, StreamTraits>&
operator<<(basic_ostream<Char, StreamTraits>& os,
           basic_string_view<Char, StringTraits> sv) {
  return os.__put(sv.data(), (streamsize)sv.size());
}

} // namespace std
